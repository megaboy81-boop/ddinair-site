---
import '../styles/global.css';
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = '디디에어컨 | 남양주 에어컨 설치·판매·수리 전문',
  description = '남양주·다산신도시 에어컨 전문 설치 업체. 천장형 4WAY·스탠드·벽걸이 설치, 에어컨 수리·이전. 당일 출장 가능. 2000건+ 시공 실적.',
  ogImage = '/images/bg/h1.jpg'
} = Astro.props;
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : null;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname.replace(/\/$/, '');
const navLinks = [
  { href: `${base}/cases`,   label: '시공사례' },
  { href: `${base}/pricing`, label: '설치비용' },
  { href: `${base}/info`,    label: '에어컨정보' },
  { href: `${base}/subsidy`, label: '지원사업' },
  { href: `${base}/contact`, label: '상담신청' },
];
---
<!DOCTYPE html>
<html lang='ko'>
<head>
  <meta charset='UTF-8' />
  <meta name='viewport' content='width=device-width, initial-scale=1.0' />
  <title>{title}</title>
  <meta name='description' content={description} />
  <meta name='keywords' content='남양주에어컨설치,다산신도시에어컨,에어컨설치업체,천장형에어컨,4WAY에어컨,에어컨청소,에어컨수리,DD에어컨,구리에어컨,하남에어컨' />
  <meta name='robots' content='index, follow' />
  <link rel='canonical' href={canonicalURL?.toString() ?? Astro.url.href} />
  <meta property='og:type' content='website' />
  <meta property='og:title' content={title} />
  <meta property='og:description' content={description} />
  <meta property='og:image' content={`${base}${ogImage}`} />
  <meta property='og:locale' content='ko_KR' />
  <meta property='og:site_name' content='DD에어컨' />
  <meta name='twitter:card' content='summary_large_image' />
  <meta name='twitter:title' content={title} />
  <meta name='twitter:description' content={description} />
  <meta name='twitter:image' content={`${base}${ogImage}`} />
  <meta name='site-base' content={base} />
  <script type='application/ld+json' set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["LocalBusiness","HVACBusiness"],
    "name": "DD에어컨",
    "description": "남양주·다산신도시 에어컨 전문 설치·판매·청소 업체",
    "telephone": "010-7237-2122",
    "url": "https://megaboy81-boop.github.io/ddinair-site/",
    "sameAs": ["https://blog.naver.com/ddinair"],
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "진건읍 고재로 186 1층",
      "addressLocality": "남양주시",
      "addressRegion": "경기도",
      "addressCountry": "KR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 37.6262,
      "longitude": 127.1889
    },
    "openingHours": "Mo-Su 08:00-20:00",
    "priceRange": "₩₩"
  })} />

  <link rel='preconnect' href='https://fonts.googleapis.com' />
  <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
  <!-- 폰트: 비블로킹 로드 -->
  <link rel='preload' as='style' href='https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap' onload="this.rel='stylesheet'" />
  <noscript><link rel='stylesheet' href='https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap' /></noscript>
  <link rel='preload' as='style' href='https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css' onload="this.rel='stylesheet'" />
  <noscript><link rel='stylesheet' href='https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css' /></noscript>
  <!-- CDN — GSAP + Lenis (defer: 렌더 블로킹 없음) -->
  <Fragment set:html={'<script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"><\/script><script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"><\/script><script defer src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/dist/lenis.min.js"><\/script>'} />

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: auto; }
    body {
      font-family: 'Pretendard Variable','Pretendard',-apple-system,BlinkMacSystemFont,system-ui,sans-serif;
      background: #ffffff;
      color: #09090b;
      overflow-x: hidden;
    }
    .font-display { font-family: 'Cormorant Garamond', Georgia, serif; }

    /* ── Header/Nav (NOVA style) ── */
    header#main-header {
      position: fixed; top: 0; left: 0; right: 0; z-index: 50;
      padding: 20px 48px;
      display: flex; align-items: center; justify-content: space-between;
      transition: background 0.3s ease, border-color 0.3s ease;
      border-bottom: 1px solid transparent;
      color: white;
    }
    header#main-header.scrolled {
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom-color: #e4e4e7;
      color: #09090b;
    }
    .header-logo {
      font-size: 22px; font-weight: 900; letter-spacing: -0.04em;
      text-decoration: none; color: inherit; transition: color 0.3s;
    }
    .header-nav {
      display: none;
    }
    @media (min-width: 768px) {
      .header-nav {
        display: flex; gap: 40px; list-style: none; align-items: center;
      }
    }
    .header-nav a {
      font-size: 13px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
      text-decoration: none; color: inherit; opacity: 0.8;
      transition: opacity 0.2s, color 0.2s;
    }
    .header-nav a:hover { opacity: 1; color: #71717a; }
    .header-nav a.nav-active { color: #2563eb; opacity: 1; }
    .header-nav a.nav-active:hover { color: #2563eb; }
    .header-nav a.nav-subsidy { color: #ef4444; opacity: 1; font-size: 17px; }
    .scrolled .header-nav a.nav-subsidy { color: #ef4444; }
    .header-nav a.nav-subsidy:hover { color: #71717a; }
    .header-cta {
      display: none;
      font-size: 13px; font-weight: 600; letter-spacing: 0.08em;
      text-decoration: none; color: inherit; opacity: 0.8; transition: opacity 0.2s;
    }
    @media (min-width: 768px) { .header-cta { display: block; } }
    .header-cta:hover { opacity: 1; }
    .header-hamburger {
      display: flex; flex-direction: column; gap: 5px; cursor: pointer;
      background: none; border: none; padding: 4px;
    }
    @media (min-width: 768px) { .header-hamburger { display: none; } }
    .header-hamburger span {
      display: block; width: 24px; height: 1.5px;
      background: currentColor; transition: all 0.3s;
    }

    /* ── Mobile Nav Overlay ── */
    .nav-mobile {
      display: none; position: fixed; inset: 0; z-index: 49;
      background: rgba(255,255,255,0.98); backdrop-filter: blur(20px);
      flex-direction: column; align-items: center; justify-content: center; gap: 32px;
    }
    .nav-mobile.open { display: flex; }
    .nav-mobile a {
      font-size: 22px; font-weight: 700; letter-spacing: -0.02em;
      text-decoration: none; color: #09090b; transition: color 0.2s;
    }
    .nav-mobile a:hover { color: #71717a; }
    .nav-mobile a.nav-active { color: #2563eb; }

    /* ── Buttons (NOVA style) ── */
    .btn-dark {
      display: inline-flex; align-items: center; gap: 8px;
      background: #09090b; color: white;
      padding: 14px 28px; border-radius: 9999px;
      font-size: 13px; font-weight: 600; letter-spacing: 0.04em;
      text-decoration: none; border: none; cursor: pointer;
      transition: background 0.2s, transform 0.2s;
    }
    .btn-dark:hover { background: #27272a; transform: translateY(-1px); }

    .btn-outline {
      display: inline-flex; align-items: center; gap: 8px;
      background: transparent; color: inherit;
      padding: 14px 28px; border-radius: 9999px;
      font-size: 13px; font-weight: 600; letter-spacing: 0.04em;
      text-decoration: none; border: 1px solid rgba(255,255,255,0.3); cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
    }
    .btn-outline:hover { border-color: rgba(255,255,255,0.7); background: rgba(255,255,255,0.08); }

    .btn-outline-dark {
      display: inline-flex; align-items: center; gap: 8px;
      background: transparent; color: #09090b;
      padding: 14px 28px; border-radius: 9999px;
      font-size: 13px; font-weight: 600; letter-spacing: 0.04em;
      text-decoration: none; border: 1px solid #e4e4e7; cursor: pointer;
      transition: border-color 0.2s;
    }
    .btn-outline-dark:hover { border-color: #09090b; }

    /* ── Section common ── */
    .section-container { max-width: 1400px; margin: 0 auto; }
    .section-label-sm {
      font-size: 11px; font-weight: 700; letter-spacing: 0.3em; text-transform: uppercase;
      color: #a1a1aa; display: block; margin-bottom: 12px;
    }
    .section-label-sm.light { color: rgba(255,255,255,0.5); }

    /* ── Cards ── */
    .card-image-wrap {
      position: relative; overflow: hidden; border-radius: 16px; background: #f4f4f5;
    }
    .card-image-wrap img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform 0.6s ease;
    }
    .card-image-wrap:hover img { transform: scale(1.04); }

    /* ── Reveal animations ── */
    .reveal { opacity: 0; transform: translateY(24px); }
    .reveal-left { opacity: 0; transform: translateX(-40px); }
    .reveal-scale { opacity: 0; transform: scale(0.95); }

    /* ── Stats (dark section) ── */
    .stat-row {
      border-bottom: 1px solid rgba(255,255,255,0.1);
      padding: 32px 0;
      display: flex; justify-content: space-between; align-items: center;
      transition: border-color 0.3s; cursor: default;
    }
    .stat-row:hover { border-bottom-color: rgba(255,255,255,0.4); }

    /* ── Marquee ── */
    .marquee-outer {
      overflow: hidden; background: #09090b;
      border-top: 1px solid rgba(255,255,255,0.06);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .marquee-track { display: flex; white-space: nowrap; animation: marqueeAnim 30s linear infinite; }
    .marquee-item {
      font-family: 'Cormorant Garamond', serif; font-size: 13px; font-style: italic;
      letter-spacing: 0.3em; color: rgba(255,255,255,0.4); padding: 14px 40px; flex-shrink: 0;
    }
    @keyframes marqueeAnim { from { transform: translateX(0); } to { transform: translateX(-50%); } }

    /* ── Float CTA ── */
    .float-cta {
      position: fixed; bottom: 28px; right: 24px; z-index: 200;
      display: flex; flex-direction: column; align-items: flex-end; gap: 10px;
    }
    .float-btn {
      width: 50px; height: 50px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      text-decoration: none; transition: all 0.3s;
      box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    }
    .float-btn:hover { transform: scale(1.1); }

    /* ── Footer ── */
    footer {
      background: #ffffff;
      border-top: 1px solid #e4e4e7;
      padding: 80px 48px 40px;
    }
    .footer-grid {
      max-width: 1400px; margin: 0 auto;
      display: grid; grid-template-columns: 3fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 60px;
    }
    .footer-logo { font-size: 22px; font-weight: 900; letter-spacing: -0.04em; color: #09090b; margin-bottom: 12px; }
    .footer-desc { font-size: 13px; color: #71717a; line-height: 1.8; }
    .footer-heading { font-size: 11px; font-weight: 700; letter-spacing: 0.25em; text-transform: uppercase; color: #09090b; margin-bottom: 16px; }
    .footer-links { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .footer-links a { font-size: 13px; color: #71717a; text-decoration: none; transition: color 0.2s; }
    .footer-links a:hover { color: #09090b; }
    .footer-bottom {
      max-width: 1400px; margin: 0 auto;
      padding-top: 24px; border-top: 1px solid #e4e4e7;
      display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;
    }
    .footer-copy { font-size: 11px; color: #a1a1aa; }

    /* ══ 서브페이지 호환 CSS (기존 스타일 복원) ══ */
    :root {
      --dark: #09090b;
      --dark2: #18181b;
      --black: #09090b;
      --blue: #2563eb;
      --blue-deep: #1d4ed8;
      --blue-light: #93c5fd;
      --blue-glow: rgba(37,99,235,0.12);
      --cream: #f0f4f8;
      --text-dim: rgba(255,255,255,0.55);
      --text-muted: rgba(255,255,255,0.35);
    }
    .section-label {
      display: block; font-size: 10px; letter-spacing: 0.5em; text-transform: uppercase;
      color: #2563eb; margin-bottom: 16px;
    }
    .section-divider {
      width: 40px; height: 1px;
      background: linear-gradient(90deg, #2563eb, #93c5fd);
      margin: 20px auto;
    }
    .blue-gradient {
      background: linear-gradient(90deg, #2563eb, #93c5fd, #2563eb);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .btn-primary {
      display: inline-block; background: linear-gradient(135deg, #2563eb, #1d4ed8);
      color: white; padding: 16px 40px; font-size: 11px; letter-spacing: 0.25em;
      text-transform: uppercase; text-decoration: none; transition: all 0.3s;
      border: none; cursor: pointer; font-family: inherit;
    }
    .btn-primary:hover { box-shadow: 0 12px 32px rgba(37,99,235,0.4); }

    /* ── 페이지 헤더 이미지 애니메이션 ── */
    @keyframes heroImgIn {
      from { opacity: 0; transform: translateX(50px); }
      to   { opacity: 1; transform: translateX(0); }
    }
    .hero-img-anim {
      animation: heroImgIn 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both;
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      header#main-header { padding: 16px 20px; }
      footer { padding: 60px 20px 32px; }
      .footer-grid { grid-template-columns: 1fr; gap: 32px; }
      .footer-bottom { flex-direction: column; align-items: flex-start; }
      /* 페이지 헤더 그리드: 모바일 1컬럼, 이미지 숨김 */
      .header-grid { grid-template-columns: 1fr !important; }
      .header-grid > div:last-child { display: none !important; }
      .hero-img-anim { animation: none; }
    }
  </style>
</head>
<body>
  <!-- HEADER -->
  <header id="main-header">
    <a href={`${base}/`} class="header-logo">디디에어컨</a>
    <ul class="header-nav">
      {navLinks.map(({ href, label }) => (
        <li><a href={href} class={currentPath === href ? 'nav-active' : (href.includes('/subsidy') ? 'nav-subsidy' : '')}>{label}</a></li>
      ))}
    </ul>
    <a href="tel:010-7237-2122" class="header-cta">010-7237-2122</a>
    <button class="header-hamburger" id="hamburger" aria-label="메뉴">
      <span></span><span></span><span></span>
    </button>
  </header>

  <!-- 모바일 메뉴 -->
  <div class="nav-mobile" id="mobile-nav">
    <a href={`${base}/`} onclick="closeMobileNav()" class={currentPath === base || currentPath === `${base}/` ? 'nav-active' : ''}>홈</a>
    {navLinks.map(({ href, label }) => (
      <a href={href} onclick="closeMobileNav()" class={currentPath === href ? 'nav-active' : ''}>{label}</a>
    ))}
    <a href="tel:010-7237-2122" onclick="closeMobileNav()" style="color:#2563eb;">010-7237-2122</a>
  </div>

  <slot />

  <!-- 플로팅 CTA -->
  <div class="float-cta">
    <a href="https://open.kakao.com/o/s257GQoi" target="_blank" rel="noopener" class="float-btn" style="background:#FEE500;" title="카카오톡 문의">
      <svg width="20" height="20" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 5.85 2 10.6c0 2.956 1.768 5.558 4.444 7.18-.165.615-.597 2.23-.684 2.576-.108.432.158.426.332.31.136-.092 2.168-1.47 3.046-2.065.609.087 1.232.133 1.862.133 5.523 0 10-3.85 10-8.6C22 5.85 17.523 2 12 2z" fill="#3C1E1E"/></svg>
    </a>
    <a href="https://blog.naver.com/ddinair" target="_blank" rel="noopener" class="float-btn" style="background:#03C75A;overflow:hidden;padding:0;" title="네이버 블로그">
      <!-- 네이버 블로그 공식 아이콘 (blog 말풍선) -->
      <svg width="50" height="50" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
        <rect width="100" height="100" rx="22" fill="#03C75A"/>
        <rect x="14" y="10" width="72" height="60" rx="10" fill="white"/>
        <polygon points="35,70 50,88 65,70" fill="white"/>
        <text x="50" y="55" font-family="Arial,sans-serif" font-weight="700" font-size="30" fill="#E8630A" text-anchor="middle">blog</text>
      </svg>
    </a>
    <a href="tel:010-7237-2122" class="float-btn" style="background:#2563eb;" title="전화 문의">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.83 10.8 19.79 19.79 0 01.77 2.18 2 2 0 012.77 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.78a16 16 0 006.29 6.29l1.15-1.15a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
      </svg>
    </a>
  </div>

  <!-- FOOTER -->
  <footer>
    <div class="footer-grid">
      <div>
        <div class="footer-logo">디디에어컨</div>
        <p class="footer-desc">남양주·다산신도시 에어컨 전문<br/>설치·판매·수리·이전</p>
        <p style="font-size:12px;color:#a1a1aa;margin-top:16px;line-height:1.8;">
          경기도 남양주시 진건읍 고재로 186 1층<br/>TEL: 010-7237-2122
        </p>
        <div style="margin-top:20px;display:flex;gap:8px;">
          <a href="https://blog.naver.com/ddinair" target="_blank" rel="noopener"
             style="width:34px;height:34px;border-radius:50%;background:#f4f4f5;display:flex;align-items:center;justify-content:center;" title="네이버 블로그">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#09090b"><path d="M16.273 12.845L7.376 0H0v24h7.727V11.155L16.624 24H24V0h-7.727z"/></svg>
          </a>
          <a href="https://open.kakao.com/o/s257GQoi" target="_blank" rel="noopener"
             style="width:34px;height:34px;border-radius:50%;background:#FEE500;display:flex;align-items:center;justify-content:center;" title="카카오톡">
            <svg width="16" height="16" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 5.85 2 10.6c0 2.956 1.768 5.558 4.444 7.18-.165.615-.597 2.23-.684 2.576-.108.432.158.426.332.31.136-.092 2.168-1.47 3.046-2.065.609.087 1.232.133 1.862.133 5.523 0 10-3.85 10-8.6C22 5.85 17.523 2 12 2z" fill="#3C1E1E"/></svg>
          </a>
