---
import '../styles/global.css';
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = 'DD에어컨 | 남양주 에어컨 전문 설치·판매·청소',
  description = '남양주·다산신도시 에어컨 전문 업체 DD에어컨. 천장형 4WAY·스탠드·벽걸이 설치, 에어컨 청소·수리·이전. 당일 출장 가능. 70건+ 시공 실적.',
  ogImage = '/images/bg/h1.jpg'
} = Astro.props;
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : null;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang='ko'>
<head>
  <meta charset='UTF-8' />
  <meta name='viewport' content='width=device-width, initial-scale=1.0' />
  <title>{title}</title>
  <meta name='description' content={description} />
  <meta name='keywords' content='남양주에어컨설치,다산신도시에어컨,에어컨설치업체,천장형에어컨,4WAY에어컨,에어컨청소,에어컨수리,DD에어컨,구리에어컨,하남에어컨' />
  <meta name='robots' content='index, follow' />
  <link rel='canonical' href={canonicalURL?.toString() ?? Astro.url.href} />
  <meta property='og:type' content='website' />
  <meta property='og:title' content={title} />
  <meta property='og:description' content={description} />
  <meta property='og:image' content={`${base}${ogImage}`} />
  <meta property='og:locale' content='ko_KR' />
  <meta property='og:site_name' content='DD에어컨' />
  <meta name='twitter:card' content='summary_large_image' />
  <meta name='twitter:title' content={title} />
  <meta name='twitter:description' content={description} />
  <meta name='twitter:image' content={`${base}${ogImage}`} />
  <script type='application/ld+json' set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["LocalBusiness","HVACBusiness"],
    "name": "DD에어컨",
    "description": "남양주·다산신도시 에어컨 전문 설치·판매·청소 업체",
    "telephone": "010-7237-2122",
    "url": "https://megaboy81-boop.github.io/ddinair-site/",
    "sameAs": ["https://blog.naver.com/ddinair"],
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "진건읍 고재로 186 1층",
      "addressLocality": "남양주시",
      "addressRegion": "경기도",
      "addressCountry": "KR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 37.6262,
      "longitude": 127.1889
    },
    "openingHours": "Mo-Su 08:00-20:00",
    "priceRange": "₩₩"
  })} />

  <link rel='preconnect' href='https://fonts.googleapis.com' />
  <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
  <link href='https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap' rel='stylesheet' />
  <link rel='stylesheet' href='https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css' />
  <!-- CDN — GSAP + Lenis + SplitType -->
  <Fragment set:html={'<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"><\/script><script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"><\/script><script src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/dist/lenis.min.js"><\/script><script src="https://unpkg.com/split-type@0.3.4/umd/index.min.js"><\/script>'} />

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --black: #03070F;
      --dark: #05090F;
      --dark2: #080D15;
      --blue: #4FC3F7;
      --blue-deep: #1E88E5;
      --blue-light: #81D4FA;
      --blue-glow: rgba(79,195,247,0.15);
      --cream: #F0F4F8;
      --text-dim: rgba(255,255,255,0.55);
      --text-muted: rgba(255,255,255,0.35);
    }
    html { scroll-behavior: auto; }
    body {
      font-family: 'Pretendard Variable','Pretendard',-apple-system,BlinkMacSystemFont,system-ui,sans-serif;
      background: var(--dark);
      color: #e8f0f8;
      overflow-x: hidden;
    }
    .font-display { font-family: 'Cormorant Garamond', Georgia, serif; }
    .blue-gradient {
      background: linear-gradient(90deg, var(--blue), var(--blue-light), var(--blue));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .section-label {
      display: block; font-size: 10px; letter-spacing: 0.5em; text-transform: uppercase;
      color: var(--blue); margin-bottom: 16px;
    }
    .section-divider {
      width: 40px; height: 1px;
      background: linear-gradient(90deg, var(--blue), var(--blue-light));
      margin: 20px auto;
    }
    .btn-primary {
      display: inline-block;
      background: linear-gradient(135deg, var(--blue-deep), #0D47A1);
      color: white; padding: 16px 40px;
      font-size: 11px; letter-spacing: 0.25em; text-transform: uppercase;
      text-decoration: none; transition: all 0.3s ease; border: none; cursor: pointer;
      font-family: inherit; position: relative; overflow: hidden;
    }
    .btn-primary::after {
      content:''; position:absolute; inset:0;
      background: linear-gradient(135deg,rgba(255,255,255,0.15),transparent);
      opacity:0; transition: opacity 0.3s;
    }
    .btn-primary:hover::after { opacity:1; }
    .btn-primary:hover { box-shadow: 0 16px 40px rgba(79,195,247,0.35); }
    .btn-outline {
      display: inline-block; border: 1px solid rgba(255,255,255,0.45);
      color: rgba(255,255,255,0.85); padding: 16px 40px;
      font-size: 11px; letter-spacing: 0.25em; text-transform: uppercase;
      text-decoration: none; transition: all 0.3s;
    }
    .btn-outline:hover { border-color: white; color: white; background: rgba(255,255,255,0.06); }
    .btn-blue {
      display: inline-block; border: 1px solid rgba(79,195,247,0.5); color: var(--blue);
      padding: 16px 40px; font-size: 11px; letter-spacing: 0.25em; text-transform: uppercase;
      text-decoration: none; transition: all 0.3s; background: transparent;
    }
    .btn-blue:hover { background: rgba(79,195,247,0.1); border-color: var(--blue); }

    /* ── 마키 ── */
    .marquee-outer { overflow: hidden; background: var(--dark2); border-top: 1px solid rgba(79,195,247,0.08); border-bottom: 1px solid rgba(79,195,247,0.08); }
    .marquee-track { display: flex; white-space: nowrap; animation: marqueeAnim 28s linear infinite; }
    .marquee-item { font-family: 'Cormorant Garamond',serif; font-size: 13px; font-style: italic; letter-spacing: 0.3em; color: rgba(79,195,247,0.5); padding: 13px 36px; flex-shrink: 0; }
    @keyframes marqueeAnim { from { transform: translateX(0); } to { transform: translateX(-50%); } }

    /* ── 네비 ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      padding: 20px 8vw;
      display: flex; align-items: center; justify-content: space-between;
      transition: background 0.5s ease, padding 0.3s ease;
    }
    nav.scrolled {
      background: rgba(5,9,15,0.94);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      padding: 14px 8vw;
      border-bottom: 1px solid rgba(79,195,247,0.1);
    }
    .nav-logo {
      display: flex; align-items: center; gap: 10px;
      text-decoration: none; color: white;
    }
    .nav-logo img { height: 40px; width: auto; object-fit: contain; filter: drop-shadow(0 0 8px rgba(79,195,247,0.3)); }
    .nav-logo span { font-size: 15px; font-weight: 600; letter-spacing: 0.05em; color: white; }
    .nav-links { display: flex; gap: 36px; list-style: none; }
    .nav-links a {
      text-decoration: none; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
      color: rgba(255,255,255,0.65); transition: color 0.3s;
    }
    .nav-links a:hover, .nav-links a.active { color: var(--blue); }
    .nav-cta {
      font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
      text-decoration: none; color: var(--blue);
      border: 1px solid rgba(79,195,247,0.4); padding: 9px 22px;
      transition: all 0.3s;
    }
    .nav-cta:hover { background: rgba(79,195,247,0.1); border-color: var(--blue); }
    .nav-hamburger {
      display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 4px;
    }
    .nav-hamburger span { display: block; width: 24px; height: 1.5px; background: white; transition: all 0.3s; }

    /* ── 모바일 메뉴 ── */
    .nav-mobile {
      display: none; position: fixed; inset: 0; z-index: 99;
      background: rgba(5,9,15,0.97); backdrop-filter: blur(20px);
      flex-direction: column; align-items: center; justify-content: center; gap: 36px;
    }
    .nav-mobile.open { display: flex; }
    .nav-mobile a {
      font-size: 20px; letter-spacing: 0.15em; text-transform: uppercase;
      text-decoration: none; color: rgba(255,255,255,0.8); transition: color 0.2s;
    }
    .nav-mobile a:hover { color: var(--blue); }

    /* ── 가로 갤러리 ── */
    .hgal-track { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; gap: 2px; -ms-overflow-style: none; scrollbar-width: none; cursor: grab; }
    .hgal-track::-webkit-scrollbar { display: none; }
    .hgal-track:active { cursor: grabbing; }
    .hgal-item { flex-shrink: 0; width: 38vw; height: 60vh; overflow: hidden; scroll-snap-align: start; position: relative; }
    .hgal-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; display: block; }
    .hgal-item:hover img { transform: scale(1.05); }
    .hgal-label { position: absolute; bottom: 0; left: 0; right: 0; padding: 16px 20px; background: linear-gradient(to top, rgba(5,9,15,0.85), transparent); color: rgba(255,255,255,0.75); font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; transform: translateY(4px); opacity: 0; transition: all 0.3s; }
    .hgal-item:hover .hgal-label { opacity: 1; transform: translateY(0); }
    @media (max-width: 768px) { .hgal-item { width: 78vw; height: 52vw; } }

    /* ── Stats ── */
    .stat-item { text-align: center; padding: 40px 20px; position: relative; }
    .stat-item + .stat-item::before {
      content:''; position:absolute; left:0; top:50%; transform:translateY(-50%);
      width:1px; height:40px; background:rgba(79,195,247,0.15);
    }
    .stat-num {
      font-family: 'Cormorant Garamond',serif;
      font-size: clamp(52px, 8vw, 80px);
      font-weight: 300;
      background: linear-gradient(135deg, var(--blue), var(--blue-light));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      line-height: 1; display: block;
    }
    .stat-label {
      font-size: 10px; letter-spacing: 0.4em; text-transform: uppercase;
      color: rgba(255,255,255,0.4); margin-top: 10px; display: block;
    }

    /* ── 리뷰 카드 ── */
    .review-card {
      background: rgba(255,255,255,0.025);
      border: 1px solid rgba(255,255,255,0.07);
      padding: 36px;
      transition: border-color 0.4s, background 0.4s;
      opacity: 0; transform: translateY(40px);
    }
    .review-card:hover {
      border-color: rgba(79,195,247,0.2);
      background: rgba(79,195,247,0.03);
    }

    /* ── GSAP 애니메이션 초기 상태 ── */
    .gsap-fade { opacity: 0; transform: translateY(30px); }
    .gsap-fade-left { opacity: 0; transform: translateX(-30px); }
    .clip-reveal { clip-path: inset(0 100% 0 0); }
    .char { display: inline-block; }
    .magnetic { transition: transform 0.3s cubic-bezier(0.23, 1, 0.32, 1), box-shadow 0.3s; }

    /* ── 히어로 타이틀 애니메이션 ── */
    .title-slide-up {
      transform: translateY(110%);
      animation: titleSlideUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes titleSlideUp { to { transform: translateY(0); } }

    /* ── 스크롤 유도 바운스 ── */
    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(6px); }
    }

    /* ── 푸터 ── */
    footer {
      background: var(--black);
      border-top: 1px solid rgba(79,195,247,0.08);
      padding: 60px 8vw 40px;
    }
    footer a { color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.3s; }
    footer a:hover { color: var(--blue); }
    .footer-inner {
      max-width: 1100px; margin: 0 auto;
      display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 40px; margin-bottom: 50px;
    }
    .footer-logo { font-family: 'Cormorant Garamond',serif; font-size: 24px; font-weight: 300; color: white; margin-bottom: 12px; }
    .footer-desc { font-size: 13px; color: rgba(255,255,255,0.4); line-height: 1.8; }
    .footer-heading { font-size: 10px; letter-spacing: 0.4em; text-transform: uppercase; color: var(--blue); margin-bottom: 16px; }
    .footer-links { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .footer-links a { font-size: 13px; }
    .footer-bottom {
      max-width: 1100px; margin: 0 auto;
      padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.06);
      display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;
    }
    .footer-copy { font-size: 11px; color: rgba(255,255,255,0.25); }

    /* ── 플로팅 CTA ── */
    .float-cta {
      position: fixed; bottom: 28px; right: 24px; z-index: 200;
      display: flex; flex-direction: column; align-items: flex-end; gap: 10px;
    }
    .float-btn {
      width: 52px; height: 52px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      text-decoration: none; transition: all 0.3s;
      box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    }
    .float-tel { background: linear-gradient(135deg, var(--blue-deep), #0D47A1); }
    .float-tel:hover { transform: scale(1.1); box-shadow: 0 12px 32px rgba(79,195,247,0.4); }
    .float-blog { background: #03C75A; }
    .float-blog:hover { transform: scale(1.1); }

    /* ── 모바일 bg show ── */
    @media (max-width: 900px) {
      .mobile-bg { display: block !important; }
    }

    /* ── 반응형 ── */
    @media (max-width: 768px) {
      .nav-links, .nav-cta { display: none; }
      .nav-hamburger { display: flex; }
      .footer-inner { grid-template-columns: 1fr; gap: 32px; }
      .stat-item + .stat-item::before { display: none; }
      .stat-item { padding: 28px 16px; border-bottom: 1px solid rgba(79,195,247,0.08); }
    }
  </style>
</head>
<body>
  <!-- NAV -->
  <nav id="main-nav">
    <a href={`${base}/`} class="nav-logo">
      <img src={`${base}/images/logo.png`} alt="DD에어컨 로고" />
      <span>디디에어컨</span>
    </a>
    <ul class="nav-links">
      <li><a href={`${base}/`}>홈</a></li>
      <li><a href={`${base}/cases`}>시공사례</a></li>
      <li><a href={`${base}/pricing`}>설치비용</a></li>
      <li><a href={`${base}/info`}>에어컨정보</a></li>
      <li><a href={`${base}/subsidy`} style="color:var(--blue);font-weight:600;">정부지원사업</a></li>
      <li><a href={`${base}/contact`}>상담신청</a></li>
    </ul>
    <a href="tel:010-7237-2122" class="nav-cta">010-7237-2122</a>
    <button class="nav-hamburger" id="hamburger" aria-label="메뉴 열기">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- 모바일 메뉴 -->
  <div class="nav-mobile" id="mobile-nav">
    <a href={`${base}/`} onclick="closeMobileNav()">홈</a>
    <a href={`${base}/cases`} onclick="closeMobileNav()">시공사례</a>
    <a href={`${base}/pricing`} onclick="closeMobileNav()">설치비용</a>
    <a href={`${base}/info`} onclick="closeMobileNav()">에어컨정보</a>
    <a href={`${base}/subsidy`} onclick="closeMobileNav()" style="color:var(--blue);">정부지원사업</a>
