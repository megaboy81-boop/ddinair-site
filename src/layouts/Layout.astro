  <script is:inline>
    // Lenis smooth scroll
    const LenisClass = window.Lenis;
    if (LenisClass) {
      const lenis = new LenisClass({ lerp: 0.1, smooth: true });
      const gsapLib = window.gsap;
      const STLib = window.ScrollTrigger;
      if (gsapLib && STLib) {
        gsapLib.ticker.add((time) => lenis.raf(time * 1000));
        gsapLib.ticker.lagSmoothing(0);
        lenis.on('scroll', STLib.update);
      } else {
        function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
        requestAnimationFrame(raf);
      }
    }

    // Nav 스크롤
    const nav = document.getElementById('main-nav');
    window.addEventListener('scroll', () => nav?.classList.toggle('scrolled', window.scrollY > 60), { passive: true });

    // 햄버거 메뉴
    const hamburger = document.getElementById('hamburger');
    const mobileNav = document.getElementById('mobile-nav');
    hamburger?.addEventListener('click', () => {
      mobileNav.classList.toggle('open');
      document.body.style.overflow = mobileNav.classList.contains('open') ? 'hidden' : '';
    });
    function closeMobileNav() {
      mobileNav.classList.remove('open');
      document.body.style.overflow = '';
    }
    window.closeMobileNav = closeMobileNav;

    // Active nav link
    const currentPath = window.location.pathname;
    document.querySelectorAll('.nav-links a').forEach(a => {
      const href = a.getAttribute('href') || '';
      if (href === currentPath || (href !== '/' && currentPath.includes(href.split('/').pop() || ''))) {
        a.classList.add('active');
      }
    });
  </script>
</body>
