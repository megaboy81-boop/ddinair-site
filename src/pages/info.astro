        <div style="position:relative;padding:36px 32px;border:1px solid rgba(79,195,247,0.12);background:rgba(79,195,247,0.02);overflow:hidden;">
          <div style="position:absolute;right:16px;bottom:12px;font-family:'Cormorant Garamond',serif;font-size:72px;font-weight:300;color:rgba(79,195,247,0.04);line-height:1;pointer-events:none;user-select:none;">{i + 1}</div>
          <div style="font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:var(--blue);margin-bottom:10px;">{s.step}</div>
          <h3 style="font-size:16px;font-weight:600;color:white;margin-bottom:12px;">{s.title}</h3>
          <p style="font-size:13px;color:rgba(255,255,255,0.5);line-height:1.7;margin:0;">{s.desc}</p>
          {i < installSteps.length - 1 && (
            <div style="position:absolute;bottom:-1px;right:20px;font-size:16px;color:rgba(79,195,247,0.25);">↓</div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

