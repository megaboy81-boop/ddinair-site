}

/* 1WAY vs 4WAY */
.way-compare-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

/* 4WAY 설치조건 + 장점 */
.fourway-bottom-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

/* 냉매 */
.refrigerant-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

/* 이전설치 상단 */
.reloc-top-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

/* 이전 과정 스텝 */
.reloc-steps-grid {
  display: grid;
