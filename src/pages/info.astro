---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const title = '에어컨 정보 | 시스템에어컨 완벽 가이드 — DD에어컨';
const description = '시스템에어컨 vs 일반에어컨 비교, 냉매 종류, 에너지효율등급 안내. DD에어컨 전문가 가이드.';

const compareTable = [
  { item: '설치 위치', system: '천장·벽 매립형', normal: '벽걸이·바닥형' },
  { item: '외관', system: '매립돼 보이지 않음', normal: '실내에 노출됨' },
  { item: '냉방 방향', system: '4방향 균일 분배', normal: '1방향 집중' },
  { item: '소음', system: '매우 조용 (천장 내부)', normal: '상대적으로 큰 편' },
  { item: '설치 비용', system: '높음 (공사 필요)', normal: '낮음 (간단 설치)' },
  { item: '유지보수', system: '전문가 청소 권장', normal: '필터 자가 청소 가능' },
  { item: '에너지 효율', system: '대용량 공간에 유리', normal: '소형 공간에 유리' },
  { item: '적합 공간', system: '거실·사무실·음식점', normal: '침실·소형 공간' },
];
---
<Layout title={title} description={description}>

<!-- 페이지 헤더 -->
<section style="background:var(--dark);padding:160px 8vw 80px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 70% 50%,rgba(79,195,247,0.05),transparent 60%);"></div>
  <div style="max-width:1100px;margin:0 auto;position:relative;">
    <span class="section-label">AC Knowledge</span>
    <h1 class="font-display" style="font-size:clamp(38px,6vw,80px);font-weight:300;color:white;line-height:1;letter-spacing:0.02em;margin-bottom:24px;">
      에어컨 정보<br/><span class="blue-gradient" style="font-style:italic;">전문가 가이드</span>
    </h1>
    <p style="font-size:16px;color:rgba(255,255,255,0.55);font-weight:300;line-height:1.9;max-width:560px;">
      시스템에어컨 선택에 필요한 핵심 정보를<br/>DD에어컨 전문가가 쉽게 정리했습니다.
    </p>
  </div>
</section>

<!-- 시스템에어컨 vs 일반 비교 -->
<section style="background:var(--dark);padding:0 8vw 80px;position:relative;z-index:2;">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="margin-bottom:40px;">
      <span class="section-label">비교 분석</span>
      <h2 class="font-display" style="font-size:clamp(26px,3.5vw,48px);font-weight:300;color:white;">시스템에어컨 vs 일반에어컨</h2>
      <div class="section-divider" style="margin-left:0;"></div>
    </div>

    <div style="border:1px solid rgba(79,195,247,0.1);overflow:hidden;">
      <div style="display:grid;grid-template-columns:140px 1fr 1fr;background:rgba(79,195,247,0.08);border-bottom:1px solid rgba(79,195,247,0.15);">
        <div style="padding:14px 20px;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:rgba(255,255,255,0.4);">구분</div>
        <div style="padding:14px 20px;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:var(--blue);">시스템에어컨</div>
        <div style="padding:14px 20px;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:rgba(255,255,255,0.5);">일반에어컨</div>
      </div>
      {compareTable.map((row, i) => (
        <div style={} onmouseover="this.style.background='rgba(79,195,247,0.04)'" onmouseout={}>
          <div style="padding:16px 20px;font-size:12px;color:rgba(255,255,255,0.4);font-weight:500;">{row.item}</div>
          <div style="padding:16px 20px;font-size:13px;color:var(--blue);">{row.system}</div>
          <div style="padding:16px 20px;font-size:13px;color:rgba(255,255,255,0.55);">{row.normal}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- 냉매 종류 -->
<section style="background:var(--dark2);padding:80px 8vw;border-top:1px solid rgba(79,195,247,0.08);">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <span class="section-label">Refrigerant</span>
      <h2 class="font-display" style="font-size:clamp(26px,3.5vw,48px);font-weight:300;color:white;">냉매 종류 안내</h2>
      <div class="section-divider"></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
      <div style="padding:40px 36px;border:1px solid rgba(79,195,247,0.3);background:rgba(79,195,247,0.04);position:relative;">
        <div style="position:absolute;top:20px;right:20px;font-size:9px;letter-spacing:0.3em;text-transform:uppercase;color:var(--blue);border:1px solid rgba(79,195,247,0.4);padding:4px 10px;">현재 표준</div>
        <div style="font-family:'Cormorant Garamond',serif;font-size:48px;font-weight:300;color:var(--blue);margin-bottom:12px;line-height:1;">R32</div>
        <div style="font-size:13px;font-weight:600;color:white;margin-bottom:12px;">차세대 친환경 냉매</div>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:8px;">
          <li style="font-size:13px;color:rgba(255,255,255,0.55);display:flex;align-items:center;gap:8px;">
            <span style="color:var(--blue);font-size:10px;">▸</span> 지구온난화지수(GWP) 낮음 (675)
          </li>
          <li style="font-size:13px;color:rgba(255,255,255,0.55);display:flex;align-items:center;gap:8px;">
            <span style="color:var(--blue);font-size:10px;">▸</span> 에너지 효율 우수
          </li>
          <li style="font-size:13px;color:rgba(255,255,255,0.55);display:flex;align-items:center;gap:8px;">
            <span style="color:var(--blue);font-size:10px;">▸</span> 단일 냉매라 재활용 용이
          </li>
          <li style="font-size:13px;color:rgba(255,255,255,0.55);display:flex;align-items:center;gap:8px;">
            <span style="color:var(--blue);font-size:10px;">▸</span> 2020년 이후 출시 제품 주류
          </li>
        </ul>
      </div>
      <div style="padding:40px 36px;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.02);">
        <div style="font-family:'Cormorant Garamond',serif;font-size:48px;font-weight:300;color:rgba(255,255,255,0.5);margin-bottom:12px;line-height:1;">R410A</div>
        <div style="font-size:13px;font-weight:600;color:white;margin-bottom:12px;">구형 표준 냉매</div>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:8px;">
          <li style="font-size:13px;color:rgba(255,255,255,0.45);display:flex;align-items:center;gap:8px;">
            <span style="color:rgba(255,255,255,0.3);font-size:10px;">▸</span> GWP 높음 (2088)
          </li>
          <li style="font-size:13px;color:rgba(255,255,255,0.45);display:flex;align-items:center;gap:8px;">
            <span style="color:rgba(255,255,255,0.3);font-size:10px;">▸</span> 2010~2019년 제품에 주로 사용
          </li>
          <li style="font-size:13px;color:rgba(255,255,255,0.45);display:flex;align-items:center;gap:8px;">
            <span style="color:rgba(255,255,255,0.3);font-size:10px;">▸</span> 혼합 냉매라 재활용 어려움
          </li>
          <li style="font-size:13px;color:rgba(255,255,255,0.45);display:flex;align-items:center;gap:8px;">
            <span style="color:rgba(255,255,255,0.3);font-size:10px;">▸</span> 단계적 사용 감소 추세
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- 에너지효율등급 -->
<section style="background:var(--dark);padding:80px 8vw;border-top:1px solid rgba(79,195,247,0.08);">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <span class="section-label">Energy Rating</span>
      <h2 class="font-display" style="font-size:clamp(26px,3.5vw,48px);font-weight:300;color:white;">에너지효율등급 안내</h2>
      <div class="section-divider"></div>
      <p style="font-size:14px;color:rgba(255,255,255,0.4);margin-top:12px;line-height:1.8;">
        등급이 낮을수록(1등급이 최고) 전기료 절약 + 정부지원 혜택이 큽니다.
      </p>
    </div>
    <div style="display:flex;flex-direction:column;gap:10px;max-width:700px;margin:0 auto;">
      <div style="display:flex;align-items:center;gap:20px;padding:16px 24px;background:rgba(79,195,247,0.15);border:1px solid rgba(79,195,247,0.5);">
        <div style="font-family:'Cormorant Garamond',serif;font-size:36px;font-weight:600;color:var(--blue);width:40px;text-align:center;">1</div>
        <div style="flex:1;">
          <div style="font-size:13px;font-weight:600;color:white;margin-bottom:2px;">최고 효율 — 전기료 최저, 정부지원 40%</div>
          <div style="font-size:12px;color:rgba(255,255,255,0.5);">에너지 소비효율 최상위 10% 제품</div>
        </div>
        <div style="font-size:10px;letter-spacing:0.2em;color:var(--blue);border:1px solid rgba(79,195,247,0.5);padding:4px 10px;">추천</div>
      </div>
      <div style="display:flex;align-items:center;gap:20px;padding:16px 24px;background:rgba(79,195,247,0.07);border:1px solid rgba(79,195,247,0.25);">
        <div style="font-family:'Cormorant Garamond',serif;font-size:36px;font-weight:600;color:rgba(79,195,247,0.7);width:40px;text-align:center;">2</div>
        <div style="flex:1;">
          <div style="font-size:13px;font-weight:600;color:white;margin-bottom:2px;">고효율 — 정부지원 30%</div>
          <div style="font-size:12px;color:rgba(255,255,255,0.5);">평균 대비 에너지 소비 20% 이상 절약</div>
        </div>
        <div style="font-size:10px;letter-spacing:0.2em;color:rgba(79,195,247,0.7);border:1px solid rgba(79,195,247,0.3);padding:4px 10px;">지원가능</div>
      </div>
      <div style="display:flex;align-items:center;gap:20px;padding:16px 24px;border:1px solid rgba(255,255,255,0.08);">
        <div style="font-family:'Cormorant Garamond',serif;font-size:36px;font-weight:600;color:rgba(255,255,255,0.4);width:40px;text-align:center;">3</div>
        <div style="flex:1;">
          <div style="font-size:13px;font-weight:600;color:rgba(255,255,255,0.7);margin-bottom:2px;">중효율 — 정부지원 미해당</div>
          <div style="font-size:12px;color:rgba(255,255,255,0.4);">평균 수준의 에너지 소비</div>
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:20px;padding:16px 24px;border:1px solid rgba(255,255,255,0.06);">
        <div style="font-family:'Cormorant Garamond',serif;font-size:36px;font-weight:600;color:rgba(255,255,255,0.25);width:40px;text-align:center;">4</div>
        <div style="flex:1;">
          <div style="font-size:13px;font-weight:600;color:rgba(255,255,255,0.5);margin-bottom:2px;">저효율 — 전기료 부담 증가</div>
          <div style="font-size:12px;color:rgba(255,255,255,0.3);">평균 대비 에너지 소비 높음</div>
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:20px;padding:16px 24px;border:1px solid rgba(255,255,255,0.04);opacity:0.7;">
        <div style="font-family:'Cormorant Garamond',serif;font-size:36px;font-weight:600;color:rgba(255,255,255,0.2);width:40px;text-align:center;">5</div>
        <div style="flex:1;">
          <div style="font-size:13px;font-weight:600;color:rgba(255,255,255,0.4);margin-bottom:2px;">최저 효율 — 전기료 가장 높음</div>
          <div style="font-size:12px;color:rgba(255,255,255,0.25);">판매 중단 또는 구형 제품</div>
        </div>
      </div>
    </div>
    <p style="text-align:center;font-size:12px;color:rgba(255,255,255,0.3);margin-top:20px;">
      * 에너지효율 1~2등급 제품은 정부지원 대상 — <a href="{base}/subsidy" style="color:var(--blue);text-decoration:none;">정부지원사업 자세히 보기</a>
    </p>
  </div>
</section>

<!-- CTA -->
<section style="background:var(--dark2);padding:80px 8vw;border-top:1px solid rgba(79,195,247,0.08);">
  <div style="max-width:700px;margin:0 auto;text-align:center;">
    <span class="section-label">Expert Consultation</span>
    <h2 class="font-display" style="font-size:clamp(28px,4vw,52px);font-weight:300;color:white;margin-bottom:16px;">
      어떤 에어컨이 맞는지<br/><span class="blue-gradient" style="font-style:italic;">전문가에게 물어보세요</span>
    </h2>
    <div class="section-divider"></div>
    <p style="font-size:14px;color:rgba(255,255,255,0.45);margin-top:20px;margin-bottom:36px;line-height:1.8;">
      공간 크기, 예산, 사용 환경에 맞는 최적의 에어컨을 추천해드립니다.<br/>정부지원 가능 여부도 함께 확인해드립니다.
    </p>
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <a href="tel:010-7237-2122" class="btn-primary" style="padding:18px 48px;font-size:11px;">전화 상담 010-7237-2122</a>
      <a href="{base}/contact" class="btn-outline" style="padding:17px 40px;font-size:11px;">온라인 문의</a>
    </div>
  </div>
</section>

</Layout>

<style>
@media (max-width: 768px) {
  div[style*="grid-template-columns:1fr 1fr"] {
    grid-template-columns: 1fr !important;
  }
  div[style*="grid-template-columns:140px 1fr 1fr"] {
    grid-template-columns: 100px 1fr 1fr !important;
  }
}
</style>

<script is:inline>
window.addEventListener('load', function() {
  if (typeof Lenis !== 'undefined') {
    const lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
    function raf(t) { lenis.raf(t); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);
  }
});
</script>
