---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const title = '에어컨 정보 | 전문가 가이드 — 디디에어컨';
const description = '천장형 4WAY 카세트 에어컨 완전 가이드, LG·삼성 제품 비교, 에너지등급별 가격, 이전설치 안내, 냉매 종류. 디디에어컨 전문가 가이드.';

const compareTable = [
  { item: '설치 위치', system: '천장·벽 매립형', normal: '벽걸이·바닥형' },
  { item: '외관', system: '매립돼 보이지 않음', normal: '실내에 노출됨' },
  { item: '냉방 방향', system: '4방향 균일 분배', normal: '1방향 집중' },
  { item: '소음', system: '매우 조용 (천장 내부)', normal: '상대적으로 큰 편' },
  { item: '설치 비용', system: '높음 (공사 필요)', normal: '낮음 (간단 설치)' },
  { item: '유지보수', system: '전문가 청소 권장', normal: '필터 자가 청소 가능' },
  { item: '에너지 효율', system: '대용량 공간에 유리', normal: '소형 공간에 유리' },
  { item: '적합 공간', system: '거실·사무실·음식점', normal: '침실·소형 공간' },
];

const lgProducts = [
  { model: 'FH07JVS2W', space: '7평형', grade: '1등급', cooling: '2.6kW', price: '문의', desc: '소형 공간용 입문 모델. 저소음 39dB 이하.' },
  { model: 'FQ15BK2WA', space: '15평형', grade: '1등급', cooling: '5.0kW', price: '140~160만원', desc: '1인실·소규모 사무실에 최적.' },
  { model: 'FQ22BK2WA', space: '23평형', grade: '1등급', cooling: '7.5kW', price: '190~220만원', desc: '중형 거실·카페에 적합한 주력 모델.' },
  { model: 'FQ31BK2WA', space: '30평형', grade: '1등급', cooling: '10.0kW', price: '230~260만원', desc: '대형 공간·상업시설 전용 고용량.' },
];

const samsungProducts = [
  { model: 'AC060AN4FBH1', space: '18평형', grade: '1등급', cooling: '6.0kW', price: '150~170만원', desc: '무풍쾌적 기술 적용. 중형 공간용.' },
  { model: 'AC090AN4FBH1', space: '25평형', grade: '1등급', cooling: '9.0kW', price: '190~210만원', desc: 'AI 절전 모드 탑재. 거실·사무실 최적.' },
  { model: 'AC110AN4FBH1', space: '30평형', grade: '1등급', cooling: '11.0kW', price: '230~250만원', desc: '대용량 상업 공간 전용 무풍 모델.' },
  { model: 'AC145BS4PHH7', space: '40평형', grade: '1등급', cooling: '14.5kW', price: '280~330만원', desc: '초대형 공간 최고 용량 프리미엄 모델.' },
];

const spaceGuide = [
  { range: '10평 이하', lg: '벽걸이 권장', samsung: '벽걸이 권장', note: '천장형 불필요' },
  { range: '15~20평', lg: 'FQ15BK2WA', samsung: 'AC060AN4FBH1', note: '가장 많이 선택' },
  { range: '22~28평', lg: 'FQ22BK2WA', samsung: 'AC090AN4FBH1', note: '디디에어컨 주력' },
  { range: '28~35평', lg: 'FQ31BK2WA', samsung: 'AC110AN4FBH1', note: '고용량 상업 공간' },
  { range: '35평 이상', lg: '멀티형 별도 설계', samsung: '멀티형 별도 설계', note: '현장 실사 필수' },
];

const spaceCards = [
  {
    icon: '🛏',
    label: '소형 방·침실',
    range: '10평 이하',
    rec: '벽걸이 10~13평형',
    desc: '소형 공간에 최적. 설치 간단, 비용 합리적. 자가 필터 청소로 유지비 낮음.',
    highlight: false,
  },
  {
    icon: '🛋',
    label: '거실·중형 공간',
    range: '15~25평',
    rec: '스탠드 또는 천장형 4WAY',
    desc: '공간 활용·인테리어 중시 시 천장형 4WAY, 이동·유연성 원할 시 스탠드형 추천.',
    highlight: false,
  },
  {
    icon: '🏢',
    label: '상업 공간·사무실',
    range: '20~40평',
    rec: '천장형 4WAY 카세트',
    desc: '디디에어컨 주력 시공 분야. 4방향 균일 기류로 사각지대 없는 냉난방. 카페·치과·셀렉샵에 최적.',
    highlight: true,
  },
  {
    icon: '🏭',
    label: '대형 상업 공간',
    range: '40평 이상',
    rec: '멀티형 시스템 (별도 설계)',
    desc: '복수의 실내기를 하나의 실외기에 연결하는 멀티형. 현장 방문 실사 후 설계·견적 필요.',
    highlight: false,
  },
];

const installSteps = [
  {
    step: 'STEP 1',
    title: '현장 방문 실사',
    desc: '도면 확인, 천장 구조 파악, 배관 경로 및 실외기 위치 설계. 슬라브 두께·장애물 여부 현장 측정.',
  },
  {
    step: 'STEP 2',
    title: '앙카 고정',
    desc: '콘크리트 슬라브에 앙카 볼트 체결. 실내기 하중을 안전하게 지지하는 핵심 공정. 수평·수직 정밀 확인.',
  },
  {
    step: 'STEP 3',
    title: '코어 타공',
    desc: '배관·드레인·전선 통로 확보를 위해 외벽 또는 슬라브를 코어 드릴로 타공. 방수 마감 동시 처리.',
  },
  {
    step: 'STEP 4',
    title: '실내기 설치',
    desc: '천장 개구부에 실내기 고정, 레이저 레벨링으로 수평 정밀 조정. 그릴·패널 마감 처리.',
  },
  {
    step: 'STEP 5',
    title: '배관·드레인 연결',
    desc: '냉매 배관 플레어 가공 및 체결, 드레인 배관 구배(경사) 확보로 결로수 완전 배출. 단열재 래핑.',
  },
  {
    step: 'STEP 6',
    title: '냉매 충전·시운전',
    desc: '진공 펌프로 배관 내부 완전 건조 후 냉매 정량 충전. 냉방·난방 실측 테스트, 전류·압력 이상 여부 최종 확인.',
  },
];
---
<Layout title={title} description={description}>

<!-- 페이지 헤더 — 다크 유지 -->
<section style="background:#09090b;padding:160px 8vw 80px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 70% 50%,rgba(79,195,247,0.05),transparent 60%);"></div>
  <div style="max-width:1100px;margin:0 auto;position:relative;">
    <div class="header-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;">
      <div>
        <span class="section-label">AC Knowledge</span>
        <h1 class="font-display" style="font-size:clamp(38px,6vw,80px);font-weight:300;color:white;line-height:1;letter-spacing:0.02em;margin-bottom:24px;">
          에어컨 정보<br/><span class="blue-gradient" style="font-style:italic;">전문가 가이드</span>
        </h1>
        <p style="font-size:16px;color:rgba(255,255,255,0.55);font-weight:300;line-height:1.9;max-width:560px;">
          천장형 4WAY 카세트 시스템에어컨 설치·이전에 필요한<br/>핵심 정보를 디디에어컨 전문가가 쉽게 정리했습니다.
        </p>
      </div>
      <div id="info-hero-img" style="position:relative;opacity:0;transform:translateX(50px);">
        <div style="position:relative;border-radius:4px;overflow:hidden;">
          <img
            src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?q=85&w=1000&auto=format&fit=crop"
            alt="시스템에어컨 에너지효율등급 안내"
            style="width:100%;aspect-ratio:4/3;object-fit:cover;display:block;"
            loading="eager"
          />
          <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(37,99,235,0.12),transparent);"></div>
          <div style="position:absolute;bottom:0;left:0;right:0;padding:20px 24px;background:linear-gradient(to top,rgba(0,0,0,0.7),transparent);">
            <p style="font-size:11px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#93c5fd;margin-bottom:4px;">AC KNOWLEDGE</p>
            <p style="font-size:14px;font-weight:600;color:white;">삼성·LG 시스템에어컨 · 1등급 전문</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function() {
    var el = document.getElementById('info-hero-img');
    if (el && window.innerWidth > 768) {
      if (typeof gsap !== 'undefined') {
        gsap.to(el, { opacity:1, x:0, duration:1.1, delay:0.4, ease:'power3.out' });
      }
    }
  })();
</script>

<style>
  @media (max-width: 768px) {
    .header-grid { grid-template-columns: 1fr !important; }
    .header-grid > div:last-child { display: none; }
  }
</style>

<!-- LG vs 삼성 제품 카드 그리드 -->
<section style="background:#ffffff;padding:0 8vw 80px;border-top:1px solid #e4e4e7;">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <span class="section-label">Product Guide</span>
      <h2 class="font-display" style="font-size:clamp(26px,3.5vw,48px);font-weight:300;color:#09090b;">LG · 삼성 주요 제품</h2>
      <div class="section-divider"></div>
      <p style="font-size:14px;color:#71717a;margin-top:12px;line-height:1.8;">1등급 냉난방 인버터 기준 / 공급가 기준 (설치비 별도)</p>
    </div>

    <!-- LG 제품 -->
    <div style="margin-bottom:48px;">
      <div style="display:flex;align-items:center;gap:16px;margin-bottom:24px;">
        <div style="font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:600;color:#09090b;letter-spacing:0.05em;">LG</div>
        <div style="font-size:11px;color:#71717a;letter-spacing:0.2em;text-transform:uppercase;">휘센 4WAY 카세트</div>
        <div style="flex:1;height:1px;background:rgba(79,195,247,0.15);"></div>
        <div style="font-size:10px;color:var(--blue);border:1px solid rgba(79,195,247,0.4);padding:4px 12px;letter-spacing:0.15em;">인버터 1등급</div>
      </div>
      <div class="product-grid">
        {lgProducts.map((p, i) => (
          <div class="product-card" style={i === 2 ? 'border-color:rgba(79,195,247,0.45);background:#eff6ff;' : ''}>
            {i === 2 && (
              <div style="position:absolute;top:14px;right:14px;font-size:9px;letter-spacing:0.25em;text-transform:uppercase;color:var(--blue);border:1px solid rgba(79,195,247,0.4);padding:3px 8px;">인기</div>
            )}
            <div style="font-size:10px;letter-spacing:0.2em;color:#a1a1aa;margin-bottom:6px;text-transform:uppercase;">모델명</div>
            <div style="font-family:'Cormorant Garamond',serif;font-size:20px;color:#09090b;font-weight:500;margin-bottom:16px;letter-spacing:0.05em;">LG {p.model}</div>
            <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px;">
              <span style="font-size:11px;padding:4px 10px;border:1px solid rgba(79,195,247,0.25);color:var(--blue);">{p.space}</span>
              <span style="font-size:11px;padding:4px 10px;border:1px solid rgba(79,195,247,0.25);color:var(--blue);">냉방 {p.cooling}</span>
              <span style="font-size:11px;padding:4px 10px;border:1px solid #e4e4e7;color:#71717a;">{p.grade}</span>
            </div>
            <p style="font-size:12px;color:#52525b;line-height:1.7;margin:0 0 16px;">{p.desc}</p>
            <div style="border-top:1px solid #e4e4e7;padding-top:14px;">
              <div style="font-size:10px;color:#a1a1aa;letter-spacing:0.1em;margin-bottom:4px;">공급가 기준</div>
              <div style="font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:300;color:{p.price === '문의' ? '#71717a' : '#09090b'};">{p.price}</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- 삼성 제품 -->
    <div>
      <div style="display:flex;align-items:center;gap:16px;margin-bottom:24px;">
        <div style="font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:600;color:#09090b;letter-spacing:0.05em;">Samsung</div>
        <div style="font-size:11px;color:#71717a;letter-spacing:0.2em;text-transform:uppercase;">무풍 4WAY 카세트</div>
        <div style="flex:1;height:1px;background:rgba(79,195,247,0.15);"></div>
        <div style="font-size:10px;color:var(--blue);border:1px solid rgba(79,195,247,0.4);padding:4px 12px;letter-spacing:0.15em;">인버터 1등급</div>
      </div>
      <div class="product-grid">
        {samsungProducts.map((p, i) => (
          <div class="product-card" style={i === 1 ? 'border-color:rgba(79,195,247,0.45);background:#eff6ff;' : ''}>
            {i === 1 && (
              <div style="position:absolute;top:14px;right:14px;font-size:9px;letter-spacing:0.25em;text-transform:uppercase;color:var(--blue);border:1px solid rgba(79,195,247,0.4);padding:3px 8px;">인기</div>
            )}
            <div style="font-size:10px;letter-spacing:0.2em;color:#a1a1aa;margin-bottom:6px;text-transform:uppercase;">모델명</div>
            <div style="font-family:'Cormorant Garamond',serif;font-size:20px;color:#09090b;font-weight:500;margin-bottom:16px;letter-spacing:0.05em;">Samsung {p.model}</div>
            <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px;">
              <span style="font-size:11px;padding:4px 10px;border:1px solid rgba(79,195,247,0.25);color:var(--blue);">{p.space}</span>
              <span style="font-size:11px;padding:4px 10px;border:1px solid rgba(79,195,247,0.25);color:var(--blue);">냉방 {p.cooling}</span>
              <span style="font-size:11px;padding:4px 10px;border:1px solid #e4e4e7;color:#71717a;">{p.grade}</span>
            </div>
            <p style="font-size:12px;color:#52525b;line-height:1.7;margin:0 0 16px;">{p.desc}</p>
            <div style="border-top:1px solid #e4e4e7;padding-top:14px;">
              <div style="font-size:10px;color:#a1a1aa;letter-spacing:0.1em;margin-bottom:4px;">공급가 기준</div>
              <div style="font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:300;color:#09090b;">{p.price}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
    <p style="font-size:12px;color:#a1a1aa;margin-top:20px;text-align:center;line-height:1.7;">
      * 공급가 기준 가격으로 설치비·부자재비 별도. 정확한 견적은 현장 실사 후 안내드립니다.
    </p>
  </div>
</section>

<!-- 브랜드별 장단점 비교 -->
<section style="background:#f8f8f8;padding:80px 8vw;border-top:1px solid #e4e4e7;">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <span class="section-label">Brand Compare</span>
      <h2 class="font-display" style="font-size:clamp(26px,3.5vw,48px);font-weight:300;color:#09090b;">LG vs 삼성 — 장단점 비교</h2>
      <div class="section-divider"></div>
      <p style="font-size:14px;color:#71717a;margin-top:12px;line-height:1.8;">어떤 브랜드가 내 공간에 맞는지 핵심만 정리했습니다.</p>
    </div>
    <div class="brand-compare-grid">
      <!-- LG -->
      <div>
        <div style="font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:600;color:#09090b;margin-bottom:4px;">LG 휘센</div>
        <div style="font-size:11px;color:#a1a1aa;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:24px;">4WAY 카세트</div>
        <div style="padding:28px 32px;border:1px solid rgba(79,195,247,0.25);background:#f8f9ff;margin-bottom:16px;">
          <div style="font-size:10px;letter-spacing:0.25em;text-transform:uppercase;color:var(--blue);margin-bottom:16px;">장점</div>
          <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:12px;">
            <li style="font-size:13px;color:#52525b;display:flex;align-items:flex-start;gap:10px;">
              <span style="color:var(--blue);flex-shrink:0;margin-top:2px;">+</span>
              <span><strong style="color:#09090b;">듀얼베인 기류 제어</strong> — 4방향 베인 독립 제어로 기류 정밀 설정</span>
            </li>
            <li style="font-size:13px;color:#52525b;display:flex;align-items:flex-start;gap:10px;">
              <span style="color:var(--blue);flex-shrink:0;margin-top:2px;">+</span>
              <span><strong style="color:#09090b;">자동 청소 기능</strong> 내장 — 사용 후 자동 건조로 위생 관리</span>
            </li>
            <li style="font-size:13px;color:#52525b;display:flex;align-items:flex-start;gap:10px;">
              <span style="color:var(--blue);flex-shrink:0;margin-top:2px;">+</span>
              <span><strong style="color:#09090b;">에너지 효율 우수</strong> — 1등급 기준 연간 전기요금 절감 탁월</span>
            </li>
            <li style="font-size:13px;color:#52525b;display:flex;align-items:flex-start;gap:10px;">
              <span style="color:var(--blue);flex-shrink:0;margin-top:2px;">+</span>
              <span><strong style="color:#09090b;">저소음 39dB 이하</strong> — 상업 공간 쾌적도 우수</span>
            </li>
            <li style="font-size:13px;color:#52525b;display:flex;align-items:flex-start;gap:10px;">
              <span style="color:var(--blue);flex-shrink:0;margin-top:2px;">+</span>
              <span><strong style="color:#09090b;">LG전자 직영 A/S망</strong> 전국 강력 서비스 네트워크</span>
            </li>
          </ul>
        </div>
