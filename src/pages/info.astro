          <p style="font-size:13px;color:#52525b;line-height:1.7;margin:0;">{s.desc}</p>
          {i < installSteps.length - 1 && (
            <div style="position:absolute;bottom:-1px;right:20px;font-size:16px;color:rgba(79,195,247,0.3);">↓</div>
          )}
        </div>
      ))}
    </div>
