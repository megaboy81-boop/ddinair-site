---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const title = 'DD에어컨 문의하기 | 에어컨 설치·청소·수리 신청';
const description = '남양주·다산신도시 에어컨 설치 문의. DD에어컨 서비스 신청 및 연락처 안내.';

const serviceAreas = [
  '남양주시', '다산신도시', '구리시', '하남시',
  '의정부시', '노원구', '도봉구', '강북구',
  '성북구', '중랑구', '서울 전역',
];

const KAKAO_URL = 'https://open.kakao.com/o/ddinair';
---
<Layout title={title} description={description}>

<!-- 페이지 헤더 -->
<section style="background:#09090b;padding:160px 8vw 80px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 70% 50%,rgba(79,195,247,0.05),transparent 60%);"></div>
  <div style="max-width:1100px;margin:0 auto;position:relative;">
    <div class="header-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;">
      <div>
        <span class="section-label">Contact Us</span>
        <h1 class="font-display" style="font-size:clamp(42px,7vw,88px);font-weight:300;color:white;line-height:0.95;letter-spacing:0.02em;margin-bottom:24px;">
          문의하기<br/><span class="blue-gradient" style="font-style:italic;">빠르게 연결</span>
        </h1>
        <p style="font-size:16px;color:rgba(255,255,255,0.5);font-weight:300;line-height:1.8;">
          전화·카카오톡·온라인 신청으로<br/>빠르게 안내드립니다.
        </p>
      </div>
      <div id="contact-hero-img" class="hero-img-anim" style="position:relative;">
        <div style="position:relative;border-radius:4px;overflow:hidden;">
          <img
            src="https://images.unsplash.com/photo-1423666639041-f56000c27a9a?q=85&w=1000&auto=format&fit=crop"
            alt="에어컨 설치 상담 전화"
            style="width:100%;aspect-ratio:4/3;object-fit:cover;display:block;"
            loading="eager"
          />
          <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(37,99,235,0.12),transparent);"></div>
          <div style="position:absolute;bottom:0;left:0;right:0;padding:20px 24px;background:linear-gradient(to top,rgba(0,0,0,0.7),transparent);">
            <p style="font-size:11px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#93c5fd;margin-bottom:4px;">CONTACT</p>
            <p style="font-size:14px;font-weight:600;color:white;">평일·주말·공휴일 08:00–20:00</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 연락처 + 온라인 신청 폼 -->
<section style="background:#ffffff;padding:64px 8vw 80px;position:relative;z-index:2;">
  <div style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start;" class="contact-main-grid">

    <!-- 왼쪽: 연락처 카드들 -->
    <div>
      <!-- 전화 카드 -->
      <div style="border:1px solid #e4e4e7;padding:40px;margin-bottom:16px;background:#ffffff;transition:border-color 0.3s;" onmouseover="this.style.borderColor='rgba(79,195,247,0.5)'" onmouseout="this.style.borderColor='#e4e4e7'">
        <div style="font-size:10px;letter-spacing:0.4em;text-transform:uppercase;color:#2563eb;margin-bottom:12px;">Phone</div>
        <a href="tel:010-7237-2122" style="text-decoration:none;display:block;font-family:'Cormorant Garamond',serif;font-size:clamp(28px,4vw,42px);font-weight:700;color:#09090b;letter-spacing:0.05em;margin-bottom:10px;transition:color 0.3s;" onmouseover="this.style.color='#2563eb'" onmouseout="this.style.color='#09090b'">
          010-7237-2122
        </a>
        <p style="font-size:12px;color:#71717a;">평일·주말·공휴일 08:00 ~ 20:00</p>
        <a href="tel:010-7237-2122" class="btn-primary" style="display:inline-block;margin-top:20px;padding:14px 32px;font-size:11px;">전화 연결하기</a>
      </div>

      <!-- 카카오톡 카드 -->
      <div style="border:1px solid #e4e4e7;padding:32px;margin-bottom:16px;background:#ffffff;transition:border-color 0.3s;" onmouseover="this.style.borderColor='rgba(254,229,0,0.7)'" onmouseout="this.style.borderColor='#e4e4e7'">
        <div style="font-size:10px;letter-spacing:0.4em;text-transform:uppercase;color:#2563eb;margin-bottom:12px;">KakaoTalk</div>
        <p style="font-size:14px;color:#52525b;margin-bottom:16px;">카카오톡 오픈채팅으로 바로 문의하세요</p>
        <a href={KAKAO_URL} target="_blank" rel="noopener"
           style="display:inline-flex;align-items:center;gap:8px;text-decoration:none;font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:#7a5f00;border:1px solid rgba(254,229,0,0.7);padding:10px 20px;background:#FEF9C3;transition:all 0.3s;"
           onmouseover="this.style.background='#FEF08A'" onmouseout="this.style.background='#FEF9C3'">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#7a5f00">
            <path d="M12 2C6.477 2 2 5.85 2 10.6c0 2.956 1.768 5.558 4.444 7.18-.165.615-.597 2.23-.684 2.576-.108.432.158.426.332.31.136-.092 2.168-1.47 3.046-2.065.609.087 1.232.133 1.862.133 5.523 0 10-3.85 10-8.6C22 5.85 17.523 2 12 2z"/>
          </svg>
          카카오톡 오픈채팅
        </a>
      </div>

      <!-- 블로그 카드 -->
      <div style="border:1px solid #e4e4e7;padding:32px;margin-bottom:16px;background:#ffffff;transition:border-color 0.3s;" onmouseover="this.style.borderColor='rgba(3,199,90,0.4)'" onmouseout="this.style.borderColor='#e4e4e7'">
        <div style="font-size:10px;letter-spacing:0.4em;text-transform:uppercase;color:#2563eb;margin-bottom:12px;">Naver Blog</div>
        <p style="font-size:14px;color:#52525b;margin-bottom:16px;">시공사례·가격 정보를 블로그에서 확인하세요</p>
        <a href="https://blog.naver.com/ddinair" target="_blank" rel="noopener"
           style="display:inline-flex;align-items:center;gap:8px;text-decoration:none;font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:#03C75A;border:1px solid rgba(3,199,90,0.4);padding:10px 20px;transition:all 0.3s;"
           onmouseover="this.style.background='rgba(3,199,90,0.08)'" onmouseout="this.style.background='transparent'">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <rect width="24" height="24" rx="4" fill="#03C75A"/>
            <path d="M13.5 12.3L10.2 7H7v10h3.5v-5.3L13.8 17H17V7h-3.5v5.3z" fill="white"/>
          </svg>
          blog.naver.com/ddinair
        </a>
      </div>

      <!-- 주소 카드 -->
      <div style="border:1px solid #e4e4e7;padding:32px;background:#ffffff;">
        <div style="font-size:10px;letter-spacing:0.4em;text-transform:uppercase;color:#2563eb;margin-bottom:12px;">Address</div>
        <p style="font-size:15px;color:#09090b;font-weight:500;margin-bottom:6px;">경기도 남양주시 진건읍 고재로 186 1층</p>
        <p style="font-size:12px;color:#71717a;margin-bottom:20px;">DD에어컨 (영문: DD Aircon)</p>
        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px;">
          <a href="https://map.naver.com/v5/search/남양주 진건읍 고재로 186" target="_blank" rel="noopener"
             style="display:inline-flex;align-items:center;gap:6px;text-decoration:none;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#374151;border:1px solid #d1d5db;padding:8px 16px;transition:all 0.3s;"
             onmouseover="this.style.borderColor='rgba(79,195,247,0.5)';this.style.color='#2563eb'" onmouseout="this.style.borderColor='#d1d5db';this.style.color='#374151'">
            네이버 지도 열기 →
          </a>
          <a href="https://map.kakao.com/link/search/남양주시 진건읍 고재로 186" target="_blank" rel="noopener"
             style="display:inline-flex;align-items:center;gap:6px;text-decoration:none;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#374151;border:1px solid #d1d5db;padding:8px 16px;transition:all 0.3s;"
             onmouseover="this.style.borderColor='rgba(79,195,247,0.5)';this.style.color='#2563eb'" onmouseout="this.style.borderColor='#d1d5db';this.style.color='#374151'">
            카카오 지도 열기 →
          </a>
        </div>
        <!-- 서비스 권역 -->
        <div style="font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#2563eb;margin-bottom:10px;">Service Area</div>
        <div style="display:flex;flex-wrap:wrap;gap:6px;">
          {serviceAreas.map(area => (
            <span style="font-size:11px;color:#2563eb;background:#eff6ff;border:1px solid #bfdbfe;padding:4px 10px;border-radius:2px;">{area}</span>
          ))}
        </div>
      </div>
    </div>

    <!-- 오른쪽: 온라인 상담 신청 폼 -->
    <div>
      <div style="border:1px solid #e4e4e7;padding:40px;background:#ffffff;">
        <div style="font-size:10px;letter-spacing:0.4em;text-transform:uppercase;color:#2563eb;margin-bottom:8px;">Online Request</div>
        <h2 class="font-display" style="font-size:clamp(22px,2.5vw,32px);font-weight:300;color:#09090b;margin-bottom:6px;">온라인 상담 신청</h2>
        <p style="font-size:12px;color:#71717a;margin-bottom:28px;line-height:1.7;">
          양식 작성 후 보내기 → 내용 확인 → 카카오톡으로 전달
        </p>

        <form id="contact-form" style="display:flex;flex-direction:column;gap:14px;" onsubmit="handleSubmit(event)">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;" class="form-row-2">
            <div>
              <label style="display:block;font-size:10px;letter-spacing:0.25em;text-transform:uppercase;color:#374151;margin-bottom:7px;">이름 *</label>
              <input type="text" name="name" required placeholder="홍길동"
                style="background:#f8f8f8;border:1px solid #d1d5db;color:#09090b;padding:12px 14px;font-size:14px;font-family:inherit;outline:none;width:100%;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#2563eb';this.style.background='#fff'" onblur="this.style.borderColor='#d1d5db';this.style.background='#f8f8f8'" />
            </div>
            <div>
              <label style="display:block;font-size:10px;letter-spacing:0.25em;text-transform:uppercase;color:#374151;margin-bottom:7px;">연락처 *</label>
              <input type="tel" name="tel" required placeholder="010-0000-0000"
                style="background:#f8f8f8;border:1px solid #d1d5db;color:#09090b;padding:12px 14px;font-size:14px;font-family:inherit;outline:none;width:100%;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#2563eb';this.style.background='#fff'" onblur="this.style.borderColor='#d1d5db';this.style.background='#f8f8f8'" />
            </div>
          </div>
          <div>
            <label style="display:block;font-size:10px;letter-spacing:0.25em;text-transform:uppercase;color:#374151;margin-bottom:7px;">설치 주소 *</label>
            <input type="text" name="address" required placeholder="경기도 남양주시 ..."
              style="background:#f8f8f8;border:1px solid #d1d5db;color:#09090b;padding:12px 14px;font-size:14px;font-family:inherit;outline:none;width:100%;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='#2563eb';this.style.background='#fff'" onblur="this.style.borderColor='#d1d5db';this.style.background='#f8f8f8'" />
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;" class="form-row-2">
            <div>
              <label style="display:block;font-size:10px;letter-spacing:0.25em;text-transform:uppercase;color:#374151;margin-bottom:7px;">에어컨 종류</label>
              <select name="ac_type"
                style="background:#f8f8f8;border:1px solid #d1d5db;color:#09090b;padding:12px 14px;font-size:14px;font-family:inherit;outline:none;width:100%;-webkit-appearance:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#2563eb'" onblur="this.style.borderColor='#d1d5db'">
                <option value="">선택하세요</option>
                <option>천장형 4WAY</option>
                <option>천장형 1WAY</option>
                <option>스탠드형</option>
                <option>벽걸이형</option>
                <option>기타</option>
              </select>
            </div>
            <div>
              <label style="display:block;font-size:10px;letter-spacing:0.25em;text-transform:uppercase;color:#374151;margin-bottom:7px;">서비스 종류</label>
              <select name="service_type"
                style="background:#f8f8f8;border:1px solid #d1d5db;color:#09090b;padding:12px 14px;font-size:14px;font-family:inherit;outline:none;width:100%;-webkit-appearance:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#2563eb'" onblur="this.style.borderColor='#d1d5db'">
                <option value="">선택하세요</option>
                <option>신규 설치</option>
                <option>이전 설치</option>
                <option>에어컨 청소</option>
                <option>수리·수검</option>
                <option>견적 문의</option>
              </select>
            </div>
          </div>
          <div>
            <label style="display:block;font-size:10px;letter-spacing:0.25em;text-transform:uppercase;color:#374151;margin-bottom:7px;">추가 내용</label>
            <textarea name="memo" rows="3" placeholder="에어컨 개수, 평수, 희망 날짜 등을 남겨주세요."
              style="background:#f8f8f8;border:1px solid #d1d5db;color:#09090b;padding:12px 14px;font-size:14px;font-family:inherit;outline:none;width:100%;resize:vertical;min-height:88px;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='#2563eb';this.style.background='#fff'" onblur="this.style.borderColor='#d1d5db';this.style.background='#f8f8f8'"></textarea>
          </div>
          <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;margin-top:4px;">
            <button type="submit" class="btn-primary" style="padding:15px 36px;font-size:11px;">보내기</button>
            <a href="tel:010-7237-2122" style="font-size:11px;letter-spacing:0.15em;color:#71717a;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='#2563eb'" onmouseout="this.style.color='#71717a'">
              또는 전화: 010-7237-2122
            </a>
          </div>
        </form>
      </div>
    </div>

  </div>
</section>

<!-- 미리보기 모달 -->
<div id="preview-modal" style="display:none;position:fixed;inset:0;z-index:200;background:rgba(0,0,0,0.6);backdrop-filter:blur(4px);align-items:center;justify-content:center;padding:20px;">
  <div style="background:#ffffff;max-width:520px;width:100%;padding:40px;position:relative;max-height:90vh;overflow-y:auto;">
    <!-- 닫기 -->
    <button onclick="closeModal()" style="position:absolute;top:16px;right:16px;background:none;border:none;cursor:pointer;color:#71717a;font-size:20px;line-height:1;padding:4px 8px;">✕</button>

    <div style="font-size:10px;letter-spacing:0.4em;text-transform:uppercase;color:#2563eb;margin-bottom:8px;">미리보기</div>
    <h3 class="font-display" style="font-size:22px;font-weight:300;color:#09090b;margin-bottom:20px;">전송할 내용 확인</h3>

    <!-- 포맷된 메시지 박스 -->
    <div id="preview-content" style="background:#f8f8f8;border:1px solid #e4e4e7;padding:20px 24px;font-size:13px;color:#09090b;line-height:2;white-space:pre-wrap;font-family:monospace;margin-bottom:24px;"></div>

    <p style="font-size:12px;color:#71717a;margin-bottom:20px;line-height:1.7;">
      위 내용을 클립보드에 복사한 후 카카오톡 채팅창에 붙여넣기 하세요.
    </p>

    <div style="display:flex;gap:10px;flex-wrap:wrap;">
      <!-- 복사 버튼 -->
      <button id="copy-btn" onclick="copyAndOpenKakao()"
        style="display:inline-flex;align-items:center;gap:8px;background:#FEE500;color:#3a2e00;border:none;padding:14px 24px;font-size:12px;font-weight:700;letter-spacing:0.05em;cursor:pointer;transition:background 0.2s;font-family:inherit;"
        onmouseover="this.style.background='#FDD700'" onmouseout="this.style.background='#FEE500'">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#3a2e00">
          <path d="M12 2C6.477 2 2 5.85 2 10.6c0 2.956 1.768 5.558 4.444 7.18-.165.615-.597 2.23-.684 2.576-.108.432.158.426.332.31.136-.092 2.168-1.47 3.046-2.065.609.087 1.232.133 1.862.133 5.523 0 10-3.85 10-8.6C22 5.85 17.523 2 12 2z"/>
        </svg>
        복사 후 카카오톡 열기
      </button>
      <button onclick="closeModal()"
        style="padding:14px 20px;background:none;border:1px solid #d1d5db;color:#52525b;font-size:12px;cursor:pointer;font-family:inherit;transition:border-color 0.2s;"
        onmouseover="this.style.borderColor='#09090b'" onmouseout="this.style.borderColor='#d1d5db'">
        닫기
      </button>
    </div>
  </div>
</div>

</Layout>

<style is:global>
  @media (max-width: 768px) {
    .contact-main-grid { grid-template-columns: 1fr !important; }
    .form-row-2 { grid-template-columns: 1fr !important; }
  }
  input::placeholder, textarea::placeholder { color: #9ca3af; }
  #preview-modal.open { display: flex !important; }
</style>

<script is:inline>
var KAKAO_URL = 'https://open.kakao.com/o/ddinair';
var _previewText = '';

function handleSubmit(e) {
  e.preventDefault();
  var form = e.target;
  var name       = form.name.value.trim();
  var tel        = form.tel.value.trim();
  var address    = form.address.value.trim();
  var acType     = form.ac_type.value || '미선택';
  var serviceType= form.service_type.value || '미선택';
  var memo       = form.memo.value.trim() || '없음';

  _previewText =
    '[DD에어컨 서비스 신청]\n' +
    '━━━━━━━━━━━━━━━━━━━\n' +
    '이름       : ' + name + '\n' +
    '연락처     : ' + tel + '\n' +
    '설치 주소  : ' + address + '\n' +
    '에어컨 종류: ' + acType + '\n' +
    '서비스 종류: ' + serviceType + '\n' +
    '추가 내용  : ' + memo + '\n' +
    '━━━━━━━━━━━━━━━━━━━\n' +
    '※ DD에어컨 사이트를 통해 접수된 문의입니다.';

  document.getElementById('preview-content').textContent = _previewText;
  document.getElementById('preview-modal').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function copyAndOpenKakao() {
  var btn = document.getElementById('copy-btn');
  navigator.clipboard.writeText(_previewText).then(function() {
    btn.textContent = '✓ 복사 완료! 카카오톡 열기...';
    setTimeout(function() {
      window.open(KAKAO_URL, '_blank');
    }, 600);
  }).catch(function() {
    // clipboard API 실패 시 fallback
    window.open(KAKAO_URL, '_blank');
  });
}

function closeModal() {
  document.getElementById('preview-modal').classList.remove('open');
  document.body.style.overflow = '';
}

// ESC 닫기
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeModal();
});

// 모달 배경 클릭 닫기
document.getElementById('preview-modal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

window.handleSubmit = handleSubmit;
window.closeModal = closeModal;
window.copyAndOpenKakao = copyAndOpenKakao;
</script>
