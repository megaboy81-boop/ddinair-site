---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const title = 'DD에어컨 문의하기 | 에어컨 설치·청소·수리 신청';
const description = '남양주·다산신도시 에어컨 설치 문의. DD에어컨 서비스 신청 및 연락처 안내.';

const serviceAreas = [
  '남양주시', '다산신도시', '구리시', '하남시',
  '의정부시', '노원구', '도봉구', '강북구',
  '성북구', '중랑구', '서울 전역',
];
---
<Layout title={title} description={description}>

<!-- 페이지 헤더 (다크 유지) -->
<section style="background:#09090b;padding:160px 8vw 80px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 70% 50%,rgba(79,195,247,0.05),transparent 60%);"></div>
  <div style="max-width:1100px;margin:0 auto;position:relative;">
    <div class="header-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;">
      <div>
        <span class="section-label">Contact Us</span>
        <h1 class="font-display" style="font-size:clamp(42px,7vw,88px);font-weight:300;color:white;line-height:0.95;letter-spacing:0.02em;margin-bottom:24px;">
          문의하기<br/><span class="blue-gradient" style="font-style:italic;">빠르게 연결</span>
        </h1>
        <p style="font-size:16px;color:rgba(255,255,255,0.5);font-weight:300;line-height:1.8;">
          전화 또는 블로그로 문의하시면<br/>빠르게 안내드립니다.
        </p>
      </div>
      <div id="contact-hero-img" class="hero-img-anim" style="position:relative;">
        <div style="position:relative;border-radius:4px;overflow:hidden;">
          <img
            src="https://images.unsplash.com/photo-1423666639041-f56000c27a9a?q=85&w=1000&auto=format&fit=crop"
            alt="에어컨 설치 상담 전화"
            style="width:100%;aspect-ratio:4/3;object-fit:cover;display:block;"
            loading="eager"
          />
          <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(37,99,235,0.12),transparent);"></div>
          <div style="position:absolute;bottom:0;left:0;right:0;padding:20px 24px;background:linear-gradient(to top,rgba(0,0,0,0.7),transparent);">
            <p style="font-size:11px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#93c5fd;margin-bottom:4px;">CONTACT</p>
            <p style="font-size:14px;font-weight:600;color:white;">평일·주말·공휴일 08:00–20:00</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .header-grid { grid-template-columns: 1fr !important; }
    .header-grid > div:last-child { display: none; }
  }

  @keyframes heroImgIn {
    from { opacity: 0; transform: translateX(50px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  .hero-img-anim {
    animation: heroImgIn 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both;
  }
  @media (max-width: 768px) {
    .hero-img-anim { animation: none; }
  }
</style>

<!-- 연락처 + 지도 -->
<section style="background:#ffffff;padding:0 8vw 80px;position:relative;z-index:2;">
  <div style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start;">

    <!-- 연락처 정보 -->
    <div>
      <!-- 전화 카드 -->
      <div style="border:1px solid #e4e4e7;padding:40px;margin-bottom:16px;background:#ffffff;transition:border-color 0.3s;" onmouseover="this.style.borderColor='rgba(79,195,247,0.5)'" onmouseout="this.style.borderColor='#e4e4e7'">
        <div style="font-size:10px;letter-spacing:0.4em;text-transform:uppercase;color:var(--blue);margin-bottom:12px;">Phone</div>
        <a href="tel:010-7237-2122" style="text-decoration:none;display:block;font-family:'Cormorant Garamond',serif;font-size:clamp(28px,4vw,42px);font-weight:700;color:#09090b;letter-spacing:0.05em;margin-bottom:10px;transition:color 0.3s;" onmouseover="this.style.color='var(--blue)'" onmouseout="this.style.color='#09090b'">
          010-7237-2122
        </a>
        <p style="font-size:12px;color:#71717a;">평일·주말·공휴일 08:00 ~ 20:00</p>
        <a href="tel:010-7237-2122" class="btn-primary" style="display:inline-block;margin-top:20px;padding:14px 32px;font-size:11px;">전화 연결하기</a>
      </div>

      <!-- 블로그 카드 -->
      <div style="border:1px solid #e4e4e7;padding:32px;margin-bottom:16px;background:#ffffff;transition:border-color 0.3s;" onmouseover="this.style.borderColor='rgba(79,195,247,0.5)'" onmouseout="this.style.borderColor='#e4e4e7'">
        <div style="font-size:10px;letter-spacing:0.4em;text-transform:uppercase;color:var(--blue);margin-bottom:12px;">Naver Blog</div>
        <p style="font-size:14px;color:#52525b;margin-bottom:16px;">시공사례·가격 정보를 블로그에서 확인하세요</p>
        <a href="https://blog.naver.com/ddinair" target="_blank" rel="noopener"
           style="display:inline-flex;align-items:center;gap:8px;text-decoration:none;font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:#03C75A;border:1px solid rgba(3,199,90,0.4);padding:10px 20px;transition:all 0.3s;"
           onmouseover="this.style.background='rgba(3,199,90,0.08)'" onmouseout="this.style.background='transparent'">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <rect width="24" height="24" rx="4" fill="#03C75A"/>
            <path d="M13.5 12.3L10.2 7H7v10h3.5v-5.3L13.8 17H17V7h-3.5v5.3z" fill="white"/>
          </svg>
          blog.naver.com/ddinair
        </a>
      </div>

      <!-- 카카오톡 카드 -->
      <div style="border:1px solid #e4e4e7;padding:32px;margin-bottom:16px;background:#ffffff;transition:border-color 0.3s;" onmouseover="this.style.borderColor='rgba(254,229,0,0.6)'" onmouseout="this.style.borderColor='#e4e4e7'">
        <div style="font-size:10px;letter-spacing:0.4em;text-transform:uppercase;color:var(--blue);margin-bottom:12px;">KakaoTalk</div>
        <p style="font-size:14px;color:#52525b;margin-bottom:16px;">카카오톡으로 빠르게 문의하세요</p>
        <a href="tel:010-7237-2122"
           style="display:inline-flex;align-items:center;gap:8px;text-decoration:none;font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:#b8860b;border:1px solid rgba(254,229,0,0.6);padding:10px 20px;background:#FEF9C3;transition:all 0.3s;"
           onmouseover="this.style.background='#FEF08A'" onmouseout="this.style.background='#FEF9C3'">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#b8860b">
            <path d="M12 2C6.477 2 2 5.85 2 10.6c0 2.956 1.768 5.558 4.444 7.18-.165.615-.597 2.23-.684 2.576-.108.432.158.426.332.31.136-.092 2.168-1.47 3.046-2.065.609.087 1.232.133 1.862.133 5.523 0 10-3.85 10-8.6C22 5.85 17.523 2 12 2z"/>
          </svg>
          카카오톡 문의
        </a>
      </div>

      <!-- 주소 카드 -->
      <div style="border:1px solid #e4e4e7;padding:32px;background:#ffffff;">
        <div style="font-size:10px;letter-spacing:0.4em;text-transform:uppercase;color:var(--blue);margin-bottom:12px;">Address</div>
        <p style="font-size:15px;color:#09090b;font-weight:500;margin-bottom:6px;">경기도 남양주시 진건읍 고재로 186 1층</p>
        <p style="font-size:12px;color:#71717a;margin-bottom:20px;">DD에어컨 (영문: DD Aircon)</p>
        <div style="display:flex;gap:10px;flex-wrap:wrap;">
          <a href="https://map.naver.com/v5/search/남양주 진건읍 고재로 186" target="_blank" rel="noopener"
             style="display:inline-flex;align-items:center;gap:6px;text-decoration:none;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#374151;border:1px solid #d1d5db;padding:8px 16px;transition:all 0.3s;"
             onmouseover="this.style.borderColor='rgba(79,195,247,0.5)';this.style.color='var(--blue)'" onmouseout="this.style.borderColor='#d1d5db';this.style.color='#374151'">
            네이버 지도 열기 →
          </a>
          <a href="https://map.kakao.com/link/search/남양주시 진건읍 고재로 186" target="_blank" rel="noopener"
             style="display:inline-flex;align-items:center;gap:6px;text-decoration:none;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#374151;border:1px solid #d1d5db;padding:8px 16px;transition:all 0.3s;"
             onmouseover="this.style.borderColor='rgba(79,195,247,0.5)';this.style.color='var(--blue)'" onmouseout="this.style.borderColor='#d1d5db';this.style.color='#374151'">
            카카오 지도 열기 →
          </a>
        </div>
      </div>
    </div>

    <!-- 지도 + 서비스 권역 -->
    <div>
      <!-- 카카오맵 embed -->
      <div style="width:100%;border:1px solid #e4e4e7;overflow:hidden;margin-bottom:20px;">
        <div style="padding:12px 16px;background:#f8f8f8;border-bottom:1px solid #e4e4e7;">
          <span style="font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:var(--blue);">Location</span>
        </div>
        <!-- 구글맵 iframe (좌표: 남양주시 진건읍 고재로 186) -->
        <div style="position:relative;padding-top:60%;background:#f0f4f8;">
          <iframe
            src="https://maps.google.com/maps?q=37.684739,127.215623&z=16&output=embed&hl=ko"
            style="position:absolute;top:0;left:0;width:100%;height:100%;border:none;"
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
            title="DD에어컨 위치"
          ></iframe>
        </div>
        <div style="padding:12px 16px;background:#f8f8f8;border-top:1px solid #e4e4e7;display:flex;gap:8px;">
          <a href="https://map.naver.com/v5/search/남양주 진건읍 고재로 186" target="_blank" rel="noopener"
             style="flex:1;text-align:center;text-decoration:none;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#374151;padding:8px;border:1px solid #d1d5db;transition:all 0.2s;"
             onmouseover="this.style.borderColor='rgba(79,195,247,0.5)';this.style.color='var(--blue)'" onmouseout="this.style.borderColor='#d1d5db';this.style.color='#374151'">
            네이버 지도
          </a>
          <a href="https://map.kakao.com/link/to/DD에어컨,37.6262,127.1889" target="_blank" rel="noopener"
             style="flex:1;text-align:center;text-decoration:none;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#374151;padding:8px;border:1px solid #d1d5db;transition:all 0.2s;"
             onmouseover="this.style.borderColor='rgba(79,195,247,0.5)';this.style.color='var(--blue)'" onmouseout="this.style.borderColor='#d1d5db';this.style.color='#374151'">
            카카오 지도
          </a>
        </div>
      </div>

      <!-- 서비스 권역 -->
      <div style="border:1px solid #e4e4e7;padding:28px;background:#f8f8f8;">
        <div style="font-size:10px;letter-spacing:0.4em;text-transform:uppercase;color:var(--blue);margin-bottom:16px;">Service Area</div>
        <div style="display:flex;flex-wrap:wrap;gap:8px;">
          {serviceAreas.map(area => (
            <span style="font-size:12px;color:#2563eb;background:#eff6ff;border:1px solid #bfdbfe;padding:5px 12px;border-radius:2px;">{area}</span>
          ))}
        </div>
        <p style="font-size:11px;color:#71717a;margin-top:14px;line-height:1.7;">
          위 지역 외에도 원거리 출장 가능합니다.<br/>전화로 문의해 주세요.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- 온라인 신청 폼 -->
<section style="background:#f8f8f8;padding:80px 8vw 100px;position:relative;z-index:2;border-top:1px solid #e4e4e7;">
  <div style="max-width:700px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:56px;">
      <span class="section-label">Online Request</span>
      <h2 class="font-display" style="font-size:clamp(28px,4vw,52px);font-weight:300;color:#09090b;letter-spacing:0.03em;">온라인 서비스 신청</h2>
      <div class="section-divider"></div>

      <!-- 운영시간 배지 -->
      <div style="display:inline-flex;align-items:center;gap:8px;background:#eff6ff;border:1px solid #bfdbfe;border-radius:999px;padding:8px 20px;margin-top:16px;margin-bottom:12px;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        <span style="font-size:12px;color:#2563eb;font-weight:500;letter-spacing:0.02em;">평일·주말·공휴일 08:00 – 20:00</span>
      </div>

      <!-- 빠른 응답 안내 -->
      <p style="font-size:13px;color:#52525b;margin-top:8px;line-height:1.8;">
        전화 또는 블로그 DM으로 문의하시면 보통 <strong style="color:#09090b;">30분~1시간 내 응답</strong>드립니다.<br/>
        아래 폼 제출 시 네이버 블로그로 연결됩니다.
      </p>
    </div>

    <form id="contact-form" style="display:flex;flex-direction:column;gap:16px;" onsubmit="handleSubmit(event)">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        <div>
          <label style="display:block;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#374151;margin-bottom:8px;">이름 *</label>
          <input type="text" name="name" required placeholder="홍길동"
            style="background:#ffffff;border:1px solid #d1d5db;color:#09090b;padding:14px 18px;font-size:14px;font-family:inherit;outline:none;width:100%;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='#2563eb'" onblur="this.style.borderColor='#d1d5db'" />
        </div>
        <div>
          <label style="display:block;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#374151;margin-bottom:8px;">연락처 *</label>
          <input type="tel" name="tel" required placeholder="010-0000-0000"
            style="background:#ffffff;border:1px solid #d1d5db;color:#09090b;padding:14px 18px;font-size:14px;font-family:inherit;outline:none;width:100%;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='#2563eb'" onblur="this.style.borderColor='#d1d5db'" />
        </div>
      </div>
      <div>
        <label style="display:block;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#374151;margin-bottom:8px;">주소 *</label>
        <input type="text" name="address" required placeholder="경기도 남양주시 ..."
          style="background:#ffffff;border:1px solid #d1d5db;color:#09090b;padding:14px 18px;font-size:14px;font-family:inherit;outline:none;width:100%;transition:border-color 0.2s;"
          onfocus="this.style.borderColor='#2563eb'" onblur="this.style.borderColor='#d1d5db'" />
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        <div>
          <label style="display:block;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#374151;margin-bottom:8px;">에어컨 종류</label>
          <select name="ac_type"
            style="background:#ffffff;border:1px solid #d1d5db;color:#09090b;padding:14px 18px;font-size:14px;font-family:inherit;outline:none;width:100%;-webkit-appearance:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='#2563eb'" onblur="this.style.borderColor='#d1d5db'">
            <option value="">선택하세요</option>
            <option>천장형 4WAY</option>
            <option>천장형 1WAY</option>
            <option>스탠드형</option>
            <option>벽걸이형</option>
            <option>기타</option>
          </select>
        </div>
        <div>
          <label style="display:block;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#374151;margin-bottom:8px;">서비스 종류</label>
          <select name="service_type"
            style="background:#ffffff;border:1px solid #d1d5db;color:#09090b;padding:14px 18px;font-size:14px;font-family:inherit;outline:none;width:100%;-webkit-appearance:none;transition:border-color 0.2s;"
            onfocus="this.style.borderColor='#2563eb'" onblur="this.style.borderColor='#d1d5db'">
            <option value="">선택하세요</option>
            <option>신규 설치</option>
            <option>이전 설치</option>
            <option>에어컨 청소</option>
            <option>수리·수검</option>
            <option>견적 문의</option>
          </select>
        </div>
      </div>
      <div>
        <label style="display:block;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#374151;margin-bottom:8px;">추가 내용</label>
        <textarea name="memo" rows="4" placeholder="에어컨 개수, 평수, 희망 날짜 등을 남겨주시면 더 빠르게 답변드립니다."
          style="background:#ffffff;border:1px solid #d1d5db;color:#09090b;padding:14px 18px;font-size:14px;font-family:inherit;outline:none;width:100%;resize:vertical;min-height:100px;transition:border-color 0.2s;"
          onfocus="this.style.borderColor='#2563eb'" onblur="this.style.borderColor='#d1d5db'"></textarea>
      </div>
      <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
        <button type="submit" class="btn-primary" style="padding:16px 40px;font-size:11px;">블로그로 문의하기</button>
        <a href="tel:010-7237-2122" style="font-size:11px;letter-spacing:0.2em;color:#71717a;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='var(--blue)'" onmouseout="this.style.color='#71717a'">
          또는 전화: 010-7237-2122
        </a>
      </div>
    </form>
  </div>
</section>

</Layout>

<style>
  @media (max-width: 768px) {
    section > div[style*="grid-template-columns:1fr 1fr"] {
      display: block !important;
    }
    form [style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
  input::placeholder, textarea::placeholder {
    color: #9ca3af;
  }
</style>

<script is:inline>
window.addEventListener('load', function() {
  if (typeof Lenis !== 'undefined') {
    const lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
    function raf(t) { lenis.raf(t); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);
  }
});

function handleSubmit(e) {
  e.preventDefault();
  const form = e.target;
  const name = form.name.value;
  const tel = form.tel.value;
  const address = form.address.value;
  const acType = form.ac_type.value;
  const serviceType = form.service_type.value;
  const memo = form.memo.value;

  // 네이버 블로그 문의 페이지로 이동 (폼 데이터 정보 포함)
  const message = encodeURIComponent(`[서비스 신청]\n이름: ${name}\n연락처: ${tel}\n주소: ${address}\n에어컨 종류: ${acType}\n서비스: ${serviceType}\n내용: ${memo}`);
  window.open(`https://blog.naver.com/ddinair`, '_blank');

  // 성공 메시지
  form.innerHTML = `<div style="text-align:center;padding:60px 0;">
    <div style="font-size:48px;margin-bottom:16px;">✓</div>
    <h3 style="font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;color:#09090b;margin-bottom:12px;">접수 완료</h3>
    <p style="color:#52525b;font-size:14px;line-height:1.8;">
      네이버 블로그로 이동했습니다.<br/>블로그 DM 또는 <a href="tel:010-7237-2122" style="color:var(--blue);">010-7237-2122</a>로 연락 주세요.
    </p>
  </div>`;
}
window.handleSubmit = handleSubmit;
</script>
