<script is:inline>
(function() {
  // ── 역대 소진 패턴 기반 piecewise 추정 ──
  // 출처: 2024~2025년 한전 소상공인 고효율기기 지원사업 조기마감 패턴
  // 2월 초 개시 → 4~6월 성수기 급증 → 8~9월 조기마감 반복
  var MILESTONES = [
    [0,   0],    // 2026-02-09 개시
    [20,  8],    // 2026-03-01
    [51,  22],   // 2026-04-01
    [81,  40],   // 2026-05-01  ← 성수기 진입
    [112, 60],   // 2026-06-01  ← 에어컨 시즌 피크
    [142, 77],   // 2026-07-01
    [173, 89],   // 2026-08-01
    [204, 96],   // 2026-09-01
    [235, 99],   // 2026-10-01  (사실상 마감)
  ];
  var BUDGET_BILLION = 388; // 억원

  function getDepletion(today) {
    var start = new Date('2026-02-09T00:00:00+09:00');
    var days = Math.max(0, (today - start) / 86400000);
    var m = MILESTONES;
    if (days >= m[m.length - 1][0]) return m[m.length - 1][1];
    for (var i = 0; i < m.length - 1; i++) {
      if (days >= m[i][0] && days < m[i + 1][0]) {
        var t = (days - m[i][0]) / (m[i + 1][0] - m[i][0]);
        return m[i][1] + t * (m[i + 1][1] - m[i][1]);
      }
    }
    return 0;
  }

  function render() {
    var now = new Date();
    var pct = getDepletion(now);
    var remaining = Math.round(BUDGET_BILLION * (1 - pct / 100));
    var pctRound = Math.round(pct * 10) / 10;

    // 퍼센트 표시
    var pctEl = document.getElementById('pct-display');
    if (pctEl) pctEl.textContent = pctRound.toFixed(1) + '%';

    // 잔여 예산
    var remEl = document.getElementById('remaining-display');
    if (remEl) {
      remEl.textContent = remaining > 0 ? '약 ' + remaining + '억원' : '소진';
      remEl.style.color = pct < 50 ? '#22c55e' : pct < 80 ? '#fbbf24' : '#f87171';
    }

    // 프로그레스 바
    var bar = document.getElementById('progress-bar');
    if (bar) {
      bar.style.width = Math.min(pct, 100) + '%';
      bar.style.background = pct < 50
        ? 'linear-gradient(90deg,#1d4ed8,#22c55e)'
        : pct < 80
          ? 'linear-gradient(90deg,#1d4ed8,#fbbf24)'
          : 'linear-gradient(90deg,#1d4ed8,#f87171)';
    }

    // 바 레이블
    var barLabel = document.getElementById('bar-label');
    if (barLabel) barLabel.textContent = pctRound.toFixed(1) + '% 소진';

    // 상태 뱃지 & 도트
    var dot = document.getElementById('status-dot');
    var badge = document.getElementById('status-badge');
    if (pct >= 99) {
      if (dot) { dot.style.background = '#f87171'; dot.style.boxShadow = '0 0 10px #f87171'; }
      if (badge) { badge.textContent = '마감'; badge.style.borderColor = '#f87171'; badge.style.color = '#f87171'; }
    } else if (pct >= 75) {
      if (dot) { dot.style.background = '#fbbf24'; dot.style.boxShadow = '0 0 10px #fbbf24'; }
      if (badge) { badge.textContent = '마감 임박'; badge.style.borderColor = '#fbbf24'; badge.style.color = '#fbbf24'; }
    }

    // 경고 박스
    var wBox = document.getElementById('warning-box');
    var wText = document.getElementById('warning-text');
    if (pct >= 75 && wBox && wText) {
      wBox.style.display = 'block';
      if (pct >= 99) {
        wText.textContent = '⚠️ 2026년 예산이 소진되었거나 거의 소진된 상태입니다. 한전 공식 사이트에서 잔여 예산을 반드시 확인하세요.';
      } else {
        wText.textContent = '⚠️ 예산 소진이 빠르게 진행 중입니다. 늦어지면 신청이 불가할 수 있으니 지금 바로 상담하세요.';
      }
    }

    // 업데이트 시각
    var updEl = document.getElementById('status-updated');
    if (updEl) {
      updEl.textContent = '방문 시간 기준: ' + now.getFullYear() + '.' +
        String(now.getMonth() + 1).padStart(2, '0') + '.' +
        String(now.getDate()).padStart(2, '0') + ' ' +
        String(now.getHours()).padStart(2, '0') + ':' +
        String(now.getMinutes()).padStart(2, '0');
    }
  }

  // 페이지 로드 후 바 애니메이션 위해 살짝 지연
  window.addEventListener('load', function() {
    setTimeout(render, 300);
    if (typeof Lenis !== 'undefined') {
      var lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
      function raf(t) { lenis.raf(t); requestAnimationFrame(raf); }
      requestAnimationFrame(raf);
    }
  });
})();
</script>
