<script is:inline>
(function() {
  // ── 한전 en-ter.co.kr 잔여예산 실값 (매일 KST 08/18시 GitHub Actions로 자동 갱신) ──
  var BUDGET_BILLION = 388; // 억원

  function render(data) {
    var now = new Date();
    var remainingPct = (data && typeof data.remaining === 'number') ? data.remaining : 0;
    var pct = Math.max(0, Math.min(100, 100 - remainingPct)); // 사용예산 = 100 - 잔여
    var remaining = Math.round(BUDGET_BILLION * remainingPct / 100);
    var pctRound = Math.round(pct * 10) / 10;

    // 퍼센트 표시 (한전 사이트와 동일하게 잔여 비율)
    var pctEl = document.getElementById('pct-display');
    if (pctEl) pctEl.textContent = remainingPct + '%';

    // 잔여 예산
    var remEl = document.getElementById('remaining-display');
    if (remEl) {
      remEl.textContent = remaining > 0 ? '약 ' + remaining + '억원' : '소진';
      remEl.style.color = pct < 50 ? '#22c55e' : pct < 80 ? '#fbbf24' : '#f87171';
    }

    // 프로그레스 바
    var bar = document.getElementById('progress-bar');
    if (bar) {
      bar.style.width = Math.min(pct, 100) + '%';
      bar.style.background = pct < 50
        ? 'linear-gradient(90deg,#1d4ed8,#22c55e)'
        : pct < 80
          ? 'linear-gradient(90deg,#1d4ed8,#fbbf24)'
          : 'linear-gradient(90deg,#1d4ed8,#f87171)';
    }

    // 바 레이블 (잔여 기준)
    var barLabel = document.getElementById('bar-label');
    if (barLabel) barLabel.textContent = remainingPct + '% 잔여';

    // 예상 소진일 (사업 시작일 ~ 오늘 사용률 → 선형 외삽)
    var endEl = document.getElementById('bar-end-label');
    if (endEl) {
      var startDate = new Date('2026-02-09T00:00:00+09:00');
      var elapsedDays = Math.max(1, (now - startDate) / 86400000);
      var dailyBurn = pct / elapsedDays; // %/day
      var officialEnd = new Date('2026-12-31T23:59:59+09:00');
      var depletion;
      if (dailyBurn > 0 && remainingPct > 0) {
        var daysLeft = remainingPct / dailyBurn;
        depletion = new Date(now.getTime() + daysLeft * 86400000);
        if (depletion > officialEnd) depletion = officialEnd;
      } else {
        depletion = officialEnd;
      }
      var label = depletion.getFullYear() + '.' +
        String(depletion.getMonth() + 1).padStart(2, '0') + '.' +
        String(depletion.getDate()).padStart(2, '0') + ' 예상소진일';
      endEl.textContent = label;
    }

    // 상태 뱃지 & 도트
    var dot = document.getElementById('status-dot');
    var badge = document.getElementById('status-badge');
    if (pct >= 99) {
      if (dot) { dot.style.background = '#f87171'; dot.style.boxShadow = '0 0 10px #f87171'; }
      if (badge) { badge.textContent = '마감'; badge.style.borderColor = '#f87171'; badge.style.color = '#f87171'; }
    } else if (pct >= 75) {
      if (dot) { dot.style.background = '#fbbf24'; dot.style.boxShadow = '0 0 10px #fbbf24'; }
      if (badge) { badge.textContent = '마감 임박'; badge.style.borderColor = '#fbbf24'; badge.style.color = '#fbbf24'; }
    }

    // 경고 박스
    var wBox = document.getElementById('warning-box');
    var wText = document.getElementById('warning-text');
    if (pct >= 75 && wBox && wText) {
      wBox.style.display = 'block';
      if (pct >= 99) {
        wText.textContent = '⚠️ 2026년 예산이 소진되었거나 거의 소진된 상태입니다. 한전 공식 사이트에서 잔여 예산을 반드시 확인하세요.';
      } else {
        wText.textContent = '⚠️ 예산 소진이 빠르게 진행 중입니다. 늦어지면 신청이 불가할 수 있으니 지금 바로 상담하세요.';
      }
    }

  }

  // 페이지 로드 후 한전 데이터 fetch → 렌더
  window.addEventListener('load', function() {
    fetch('/data/subsidy.json', { cache: 'no-store' })
      .then(function(r) { return r.json(); })
      .then(function(data) { setTimeout(function() { render(data); }, 300); })
      .catch(function() { render({ remaining: 43, used: 57, updated_label: '' }); });
    if (typeof Lenis !== 'undefined') {
      var lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
      function raf(t) { lenis.raf(t); requestAnimationFrame(raf); }
      requestAnimationFrame(raf);
    }
  });
})();
</script>
