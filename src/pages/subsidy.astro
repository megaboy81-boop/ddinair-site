---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const title = '정부지원사업 | 최대 40% 환급 — DD에어컨';
const description = '한전 고효율기기 보급사업으로 에어컨 구매 시 최대 40% 환급. 에너지효율 1~2등급 에어컨 설치 후 한전 앱으로 간단 신청. DD에어컨이 처음부터 끝까지 안내해드립니다.';
---
<Layout title={title} description={description}>

<!-- 페이지 헤더 -->
<section style="background:#09090b;padding:160px 8vw 80px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 60% 50%,rgba(79,195,247,0.07),transparent 60%);"></div>
  <div style="max-width:1100px;margin:0 auto;position:relative;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;" class="header-grid">
    <div>
      <span class="section-label">Government Support</span>
      <h1 class="font-display" style="font-size:clamp(38px,6vw,80px);font-weight:300;color:white;line-height:1;letter-spacing:0.02em;margin-bottom:24px;">
        정부지원사업<br/><span class="blue-gradient" style="font-style:italic;">최대 40% 환급</span>
      </h1>
      <p style="font-size:16px;color:rgba(255,255,255,0.55);font-weight:300;line-height:1.9;max-width:560px;">
        한전 고효율기기 보급사업을 통해<br/>에어컨 구매비용의 최대 40%를 돌려받으세요.<br/>DD에어컨이 신청까지 안내해드립니다.
      </p>
      <div style="margin-top:36px;display:flex;gap:16px;flex-wrap:wrap;">
        <a href={`${base}/contact`} class="btn-primary" style="padding:16px 40px;font-size:11px;">무료 상담 신청</a>
        <a href="tel:010-7237-2122" style="display:inline-flex;align-items:center;gap:8px;padding:15px 38px;font-size:11px;font-weight:600;letter-spacing:0.08em;color:rgba(255,255,255,0.8);border:1px solid rgba(255,255,255,0.25);text-decoration:none;transition:all 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.6)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.25)'">010-7237-2122</a>
      </div>
    </div>
    <div id="subsidy-hero-img" class="hero-img-anim" style="position:relative;">
      <div style="position:relative;border-radius:4px;overflow:hidden;">
        <img
          src="https://images.unsplash.com/photo-1762341123870-d706f257a12e?q=85&w=1000&auto=format&fit=crop"
          alt="한전 고효율기기 지원사업 에어컨"
          style="width:100%;aspect-ratio:4/3;object-fit:cover;display:block;"
          loading="eager"
        />
        <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(37,99,235,0.15),transparent);"></div>
        <div style="position:absolute;bottom:0;left:0;right:0;padding:20px 24px;background:linear-gradient(to top,rgba(0,0,0,0.7),transparent);">
          <p style="font-size:11px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#93c5fd;margin-bottom:4px;">KEPCO 2026</p>
          <p style="font-size:14px;font-weight:600;color:white;">에너지효율 1등급 · 최대 40% 환급</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ 예산 소진 현황 위젯 ══ -->
<section style="background:#eff6ff;padding:48px 8vw 56px;border-top:1px solid #bfdbfe;border-bottom:1px solid #bfdbfe;">
  <div style="max-width:1100px;margin:0 auto;">

    <!-- 헤더 -->
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:12px;">
      <div style="display:flex;align-items:center;gap:12px;">
        <span id="status-dot" style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#22c55e;box-shadow:0 0 10px rgba(34,197,94,0.5);animation:pulse-dot 2s infinite;flex-shrink:0;"></span>
        <span style="font-size:11px;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:#2563eb;">실시간 예산 소진 현황</span>
        <span id="status-badge" style="font-size:9px;padding:2px 10px;border:1px solid #22c55e;color:#16a34a;letter-spacing:0.15em;text-transform:uppercase;">접수 중</span>
      </div>
      <span id="status-updated" style="font-size:11px;color:#71717a;"></span>
    </div>

    <!-- 메인 그리드 -->
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1px;background:#dbeafe;border:1px solid #bfdbfe;margin-bottom:28px;" class="status-grid-3">
      <div style="background:#ffffff;padding:28px 24px;">
        <div style="font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#71717a;margin-bottom:8px;">총 지원 예산</div>
        <div style="font-family:'Cormorant Garamond',serif;font-size:40px;font-weight:300;color:#09090b;line-height:1;">388<span style="font-size:0.5em;font-weight:400;color:#52525b;">억원</span></div>
        <div style="font-size:11px;color:#a1a1aa;margin-top:6px;">2026년 전체 배정 예산</div>
      </div>
      <div style="background:#ffffff;padding:28px 24px;">
        <div style="font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#71717a;margin-bottom:8px;">잔여예산</div>
        <div id="pct-display" style="font-family:'Cormorant Garamond',serif;font-size:40px;font-weight:300;line-height:1;color:#2563eb;">—</div>
        <div style="font-size:11px;color:#a1a1aa;margin-top:6px;">한전 공식 사이트 기준</div>
      </div>
      <div style="background:#ffffff;padding:28px 24px;">
        <div style="font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#71717a;margin-bottom:8px;">잔여예산</div>
        <div id="remaining-display" style="font-family:'Cormorant Garamond',serif;font-size:40px;font-weight:300;color:#16a34a;line-height:1;">—</div>
        <div style="font-size:11px;color:#a1a1aa;margin-top:6px;">
          <a href="https://en-ter.co.kr/ac/main/main.do" target="_blank" rel="noopener" style="color:#2563eb;text-decoration:none;">공식 사이트에서 정확한 현황 확인 →</a>
        </div>
      </div>
    </div>

    <!-- 프로그레스 바 -->
    <div style="margin-bottom:16px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
        <span style="font-size:11px;color:#71717a;">2026.02.09 접수 시작</span>
        <span id="bar-label" style="font-size:11px;font-weight:700;color:#2563eb;"></span>
        <span id="bar-end-label" style="font-size:11px;color:#71717a;">2026.12.31 (조기마감 가능)</span>
      </div>
      <div style="width:100%;height:8px;background:#dbeafe;border-radius:4px;overflow:hidden;">
        <div id="progress-bar" style="height:100%;width:0%;background:linear-gradient(90deg,#1d4ed8,#3b82f6);border-radius:4px;transition:width 1.2s cubic-bezier(0.4,0,0.2,1);"></div>
      </div>
    </div>

    <!-- 경고 메시지 -->
    <div id="warning-box" style="display:none;padding:14px 20px;border:1px solid rgba(251,191,36,0.5);background:#fffbeb;margin-bottom:16px;">
      <p id="warning-text" style="font-size:13px;color:#b45309;margin:0;line-height:1.6;"></p>
    </div>

    <!-- 하단 안내 -->
    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
      <span style="font-size:11px;color:#a1a1aa;">※ 한전 공식 사이트 기준</span>
    </div>

  </div>
</section>

<!-- 지원 내용 요약 -->
<section style="background:#ffffff;padding:80px 8vw;position:relative;z-index:2;">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:60px;">
      <span class="section-label">지원 개요</span>
      <h2 class="font-display" style="font-size:clamp(28px,4vw,52px);font-weight:300;color:#09090b;letter-spacing:0.03em;">한전 고효율기기 보급사업</h2>
      <div class="section-divider"></div>
      <p style="font-size:14px;color:#71717a;margin-top:12px;line-height:1.8;">
        한국전력공사에서 운영하는 에너지 절약 지원 프로그램입니다.
      </p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:#e4e4e7;border:1px solid #e4e4e7;">
      <div style="background:#ffffff;padding:40px 32px;text-align:center;">
        <div style="font-family:'Cormorant Garamond',serif;font-size:56px;font-weight:300;background:linear-gradient(90deg,var(--blue),var(--blue-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;">30~40%</div>
        <div style="font-size:10px;letter-spacing:0.4em;text-transform:uppercase;color:#71717a;margin-top:12px;">환급률</div>
        <p style="font-size:13px;color:#52525b;margin-top:10px;line-height:1.7;">에너지효율 1등급 40%<br/>에너지효율 2등급 30%</p>
      </div>
      <div style="background:#ffffff;padding:40px 32px;text-align:center;">
        <div style="font-family:'Cormorant Garamond',serif;font-size:56px;font-weight:300;background:linear-gradient(90deg,var(--blue),var(--blue-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;">160만원</div>
        <div style="font-size:10px;letter-spacing:0.4em;text-transform:uppercase;color:#71717a;margin-top:12px;">에어컨 최대 환급액</div>
        <p style="font-size:13px;color:#52525b;margin-top:10px;line-height:1.7;">소상공인 1등급 에어컨<br/>1대당 최대 160만원</p>
      </div>
      <div style="background:#ffffff;padding:40px 32px;text-align:center;">
        <div style="font-family:'Cormorant Garamond',serif;font-size:56px;font-weight:300;background:linear-gradient(90deg,var(--blue),var(--blue-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;">30일</div>
        <div style="font-size:10px;letter-spacing:0.4em;text-transform:uppercase;color:#71717a;margin-top:12px;">신청 기한</div>
        <p style="font-size:13px;color:#52525b;margin-top:10px;line-height:1.7;">설치 완료 후 30일 이내<br/>한전 앱에서 신청</p>
      </div>
    </div>
  </div>
</section>

<!-- ══ 얼마나 받나요? — 품목별 지원금 상세 ══ -->
<section style="background:#f8f8f8;padding:80px 8vw;border-top:1px solid #e4e4e7;">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <span class="section-label">지원금 상세</span>
      <h2 class="font-display" style="font-size:clamp(26px,3.5vw,48px);font-weight:300;color:#09090b;">얼마나 받을 수 있나요?</h2>
      <div class="section-divider"></div>
      <p style="font-size:14px;color:#71717a;margin-top:12px;line-height:1.8;">
        구매가의 40%를 현금으로 환급. 에어컨 최대 160만원 돌려받으세요.
      </p>
    </div>

    <!-- 품목별 지원 금액표 -->
    <div style="border:1px solid #e4e4e7;overflow:hidden;margin-bottom:40px;background:#ffffff;">
      <!-- 헤더 -->
      <div style="display:grid;grid-template-columns:1.5fr 1fr 1fr 1.5fr;background:#f8f9ff;border-bottom:1px solid #e4e4e7;">
        <div style="padding:14px 20px;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#71717a;">품목</div>
        <div style="padding:14px 20px;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#4fc3f7;">환급률</div>
        <div style="padding:14px 20px;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#4fc3f7;">최대 환급액</div>
        <div style="padding:14px 20px;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#71717a;">예시</div>
      </div>
      <!-- 에어컨 -->
      <div style="display:grid;grid-template-columns:1.5fr 1fr 1fr 1.5fr;border-bottom:1px solid #f3f4f6;background:#f8f9ff;">
        <div style="padding:20px;display:flex;align-items:center;gap:10px;">
          <span style="display:inline-block;padding:2px 8px;background:rgba(37,99,235,0.12);font-size:9px;letter-spacing:0.15em;color:#2563eb;text-transform:uppercase;">주력</span>
          <span style="font-size:14px;font-weight:600;color:#09090b;">냉난방기 (에어컨)</span>
        </div>
        <div style="padding:20px;font-size:18px;font-weight:700;color:#3b82f6;">40%</div>
        <div style="padding:20px;font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:300;color:#09090b;">160만원</div>
        <div style="padding:20px;font-size:12px;color:#52525b;line-height:1.7;">400만원짜리 1등급 에어컨<br/>→ 160만원 환급 → <strong style="color:#09090b;">실구매가 240만원</strong></div>
      </div>
      <!-- 냉장고 -->
      <div style="display:grid;grid-template-columns:1.5fr 1fr 1fr 1.5fr;border-bottom:1px solid #f3f4f6;">
        <div style="padding:20px;font-size:14px;color:#52525b;">냉장고</div>
        <div style="padding:20px;font-size:16px;font-weight:600;color:#4fc3f7;">40%</div>
        <div style="padding:20px;font-size:16px;color:#52525b;">40만원</div>
        <div style="padding:20px;font-size:12px;color:#71717a;">에너지효율 1등급 냉장고 구매 시</div>
      </div>
      <!-- 세탁기 -->
      <div style="display:grid;grid-template-columns:1.5fr 1fr 1fr 1.5fr;border-bottom:1px solid #f3f4f6;">
        <div style="padding:20px;font-size:14px;color:#52525b;">세탁기</div>
        <div style="padding:20px;font-size:16px;font-weight:600;color:#4fc3f7;">40%</div>
        <div style="padding:20px;font-size:16px;color:#52525b;">80만원</div>
        <div style="padding:20px;font-size:12px;color:#71717a;">1등급 드럼세탁기 등</div>
      </div>
      <!-- 건조기 -->
      <div style="display:grid;grid-template-columns:1.5fr 1fr 1fr 1.5fr;">
        <div style="padding:20px;font-size:14px;color:#52525b;">건조기</div>
        <div style="padding:20px;font-size:16px;font-weight:600;color:#4fc3f7;">40%</div>
        <div style="padding:20px;font-size:16px;color:#52525b;">80만원</div>
        <div style="padding:20px;font-size:12px;color:#71717a;">1등급 히트펌프 건조기 등</div>
      </div>
    </div>

    <div style="padding:20px 24px;background:#f8f9ff;border:1px solid rgba(37,99,235,0.2);display:flex;align-items:flex-start;gap:14px;">
      <span style="font-size:20px;flex-shrink:0;">💡</span>
      <p style="font-size:13px;color:#52525b;line-height:1.8;margin:0;">
        <strong style="color:#09090b;">에어컨 한 대로 최대 160만원 환급.</strong> 예를 들어 400만원짜리 LG 4WAY 40평 1등급 에어컨을 설치하면 40%인 160만원을 현금으로 돌려받아 실구매가는 <strong style="color:#2563eb;">240만원</strong>이 됩니다.
        DD에어컨은 설치부터 지원금 서류 접수까지 원스톱으로 처리해드립니다.
      </p>
    </div>
  </div>
</section>

<!-- ══ 실제 시공 사례 ══ -->
<section style="background:#f8f8f8;padding:80px 8vw;border-top:1px solid #e4e4e7;">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:48px;">
      <span class="section-label">Real Cases</span>
      <h2 class="font-display" style="font-size:clamp(26px,3.5vw,48px);font-weight:300;color:#09090b;">실제 지원금 받은 시공 사례</h2>
      <div class="section-divider"></div>
      <p style="font-size:14px;color:#71717a;margin-top:12px;">DD에어컨이 시공 + 서류까지 한번에 처리해드린 실제 현장들입니다.</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:24px;" class="subsidy-cases-grid">

      <div style="border:1px solid #e4e4e7;overflow:hidden;background:#ffffff;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
        <div style="aspect-ratio:16/9;overflow:hidden;background:#f3f4f6;">
          <img src={`${base}/images/gallery/case02.jpg`} alt="성수 셀렉샵 1등급 에어컨 설치" style="width:100%;height:100%;object-fit:cover;transition:transform 0.5s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'"/>
        </div>
        <div style="padding:20px 24px;">
          <div style="font-size:10px;letter-spacing:0.25em;text-transform:uppercase;color:#3b82f6;margin-bottom:6px;">2026.02 · 성수</div>
          <h3 style="font-size:16px;font-weight:600;color:#09090b;margin-bottom:6px;">셀렉샵 1등급 에어컨 설치</h3>
          <p style="font-size:12px;color:#52525b;line-height:1.7;margin-bottom:12px;">LG 4WAY 25평 1등급 냉난방 설치 완료. 가게 오픈 전 에어컨 교체 + 정부지원 신청까지 완료.</p>
          <span style="font-size:10px;padding:3px 10px;border:1px solid rgba(37,99,235,0.4);color:#2563eb;letter-spacing:0.15em;">지원금 신청 완료</span>
        </div>
      </div>

      <div style="border:1px solid #e4e4e7;overflow:hidden;background:#ffffff;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
        <div style="aspect-ratio:16/9;overflow:hidden;background:#f3f4f6;">
          <img src={`${base}/images/gallery/case05.jpg`} alt="강변 치과 삼성 4WAY 설치" style="width:100%;height:100%;object-fit:cover;transition:transform 0.5s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'"/>
        </div>
        <div style="padding:20px 24px;">
          <div style="font-size:10px;letter-spacing:0.25em;text-transform:uppercase;color:#3b82f6;margin-bottom:6px;">2026.02 · 강변</div>
          <h3 style="font-size:16px;font-weight:600;color:#09090b;margin-bottom:6px;">치과 1등급 시스템에어컨 설치</h3>
          <p style="font-size:12px;color:#52525b;line-height:1.7;margin-bottom:12px;">삼성 4WAY 30평 1등급 냉난방. 의료기관 특성상 쾌적한 실내 환경 필수. 1등급 설치로 전기요금 절감.</p>
          <span style="font-size:10px;padding:3px 10px;border:1px solid rgba(37,99,235,0.4);color:#2563eb;letter-spacing:0.15em;">지원금 신청 완료</span>
        </div>
      </div>

      <div style="border:1px solid #e4e4e7;overflow:hidden;background:#ffffff;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
        <div style="aspect-ratio:16/9;overflow:hidden;background:#f3f4f6;">
          <img src={`${base}/images/gallery/case03.jpg`} alt="안산 네일아트샵 LG 4WAY 설치" style="width:100%;height:100%;object-fit:cover;transition:transform 0.5s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'"/>
        </div>
        <div style="padding:20px 24px;">
