---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const title = '에어컨 설치비용 안내 — 디디에어컨';
const description = '남양주·다산신도시 시스템에어컨 설치비용 안내. 벽걸이·스탠드·천장형 4WAY·이전설치 기종별 상세 가격 및 무료 방문 견적 신청.';

const priceTable = [
  { size: '소형', range: '10평 이하', price: '100~150만원', desc: '소형 벽걸이·천장형 1way' },
  { size: '중형', range: '10~20평', price: '150~250만원', desc: '중형 천장형 4way, 스탠드' },
  { size: '대형', range: '20~30평', price: '250~400만원', desc: '대형 시스템 에어컨' },
  { size: '대형+', range: '30평 이상', price: '별도 견적', desc: '현장 확인 후 안내' },
];

const typeCards = [
  {
    name: '벽걸이형',
    range: '10~16평',
    price: '70~120만원',
    label: '재료비 포함',
    includes: ['기본 5m 배관 자재 포함', '실외기 설치 및 냉매 충전', '전기 연결 및 시운전'],
    recommend: '소형 사무실, 원룸, 침실',
    highlight: false,
  },
  {
    name: '스탠드형',
    range: '16~23평',
    price: '90~140만원',
    label: '재료비 포함',
    includes: ['기본 5m 배관 자재 포함', '실외기 설치 및 냉매 충전', '전기 연결 및 시운전'],
    recommend: '거실, 중형 사무실, 매장',
    highlight: false,
  },
  {
    name: '천장형 4WAY',
    range: '15~40평',
    price: '180~450만원',
    label: '재료비 포함',
    includes: ['천장 매립 및 마감 포함', '기본 5m 배관 자재 포함', '4방향 기류 설계 시공'],
    recommend: '카페, 치과, 사무실, 셀렉샵',
    highlight: true,
  },
  {
    name: '에어컨 이전설치',
    range: '기종·거리 따라 상이',
    price: '50~130만원',
    label: '별도 견적',
    includes: ['실내기·실외기 분리 및 이전', '냉매 보충 및 재충전', '이전 현장 설치 및 시운전'],
    recommend: '이사, 매장 이전, 기기 재활용',
    highlight: false,
  },
];

const brands = [
  {
    name: 'LG',
    price: '고급',
    energy: '1등급',
    feature: '휘센 인버터, DUALCOOL 기술, 자가세척',
    as: '직영 서비스센터 전국망',
  },
  {
    name: '삼성',
    price: '고급',
    energy: '1등급',
    feature: 'WindFree 무풍, AI 절전 모드',
    as: '삼성전자서비스 전국 직영',
  },
  {
    name: '캐리어',
    price: '중고급',
    energy: '1등급',
    feature: '글로벌 냉난방 전문 브랜드, 상업용 강점',
    as: '캐리어 전국 협력점 네트워크',
  },
  {
    name: '위니아',
    price: '중급',
    energy: '1등급',
    feature: '합리적 가격, 국내 생산, 실용 설계',
    as: '위니아 서비스 전국 접수',
  },
];

const extraCosts = [
  { item: '배관 연장', desc: '기본 5m 초과 시 1m당 약 1.5만원 추가' },
  { item: '코어 타공', desc: '층간 관통 1개소당 약 5~8만원' },
  { item: '배전반 공사', desc: '분기 차단기 추가 약 5~10만원' },
  { item: '냉매 추가 충전', desc: 'R32/R410A 종류 및 양에 따라 별도' },
  { item: '기존 에어컨 철거', desc: '기존 기기 철거·처리 약 3~7만원' },
];

const faqs = [
  {
    q: '방문 견적은 무료인가요?',
    a: '네, 완전 무료입니다. 방문 견적은 비용 없이 진행되며, 견적 후 시공 여부와 무관하게 아무런 부담이 없습니다. 정확한 비용은 현장 확인 후에만 산출 가능하기 때문에 방문 견적을 적극 권장드립니다.',
  },
  {
    q: '설치 당일 몇 시간 걸리나요?',
    a: '단독 벽걸이 에어컨은 보통 2~3시간, 스탠드형은 2~4시간, 천장형 4WAY 카세트는 현장 조건에 따라 4~8시간 소요됩니다. 배관 거리가 길거나 타공이 필요한 경우 추가 시간이 발생할 수 있습니다.',
  },
  {
    q: '이사 시 에어컨 이전설치도 가능한가요?',
    a: '네, 이전설치 전문으로 진행합니다. 기존 설치된 에어컨을 분리 후 새로운 현장에 재설치하며, 냉매 보충 및 시운전까지 완전히 처리합니다. 브랜드 무관하게 가능하며, 별도 방문 견적 후 안내드립니다.',
  },
];
---
<Layout title={title} description={description}>

<!-- 페이지 헤더 -->
<section style="background:var(--dark);padding:160px 8vw 80px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 30% 50%,rgba(79,195,247,0.06),transparent 60%);pointer-events:none;"></div>
  <div style="position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(79,195,247,0.15),transparent);"></div>
  <div style="max-width:1100px;margin:0 auto;position:relative;">
    <span class="section-label">Pricing Guide</span>
    <h1 class="font-display" style="font-size:clamp(38px,6vw,80px);font-weight:300;color:white;line-height:1.05;letter-spacing:0.02em;margin-bottom:24px;">
      설치비용 안내<br/><span class="blue-gradient" style="font-style:italic;">투명한 견적</span>
    </h1>
    <p style="font-size:16px;color:rgba(255,255,255,0.55);font-weight:300;line-height:1.9;max-width:560px;">
      시스템에어컨은 설치 환경에 따라 비용이 달라집니다.<br/>무료 방문 견적 후 정확한 금액 안내드립니다.
    </p>
  </div>
</section>

<!-- 정부지원 배너 -->
<section style="background:var(--dark);padding:0 8vw 60px;position:relative;z-index:2;">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="border:1px solid rgba(79,195,247,0.4);background:rgba(79,195,247,0.05);padding:20px 28px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">
      <div>
        <div style="font-size:10px;letter-spacing:0.4em;text-transform:uppercase;color:var(--blue);margin-bottom:6px;">Government Support</div>
        <p style="font-size:14px;color:white;">정부지원 시 최대 40% 할인 가능 — 한전 고효율기기 보급사업</p>
      </div>
      <a href={`${base}/subsidy`} class="subsidy-btn" style="display:inline-flex;align-items:center;gap:8px;text-decoration:none;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:var(--blue);border:1px solid rgba(79,195,247,0.5);padding:10px 20px;white-space:nowrap;transition:all 0.3s;background:transparent;">
        정부지원사업 보기 →
      </a>
    </div>
  </div>
</section>

<!-- 기종별 상세 설치비용 -->
<section style="background:var(--dark2);padding:80px 8vw;border-top:1px solid rgba(79,195,247,0.08);">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <span class="section-label">Type by Cost</span>
      <h2 class="font-display" style="font-size:clamp(26px,3.5vw,48px);font-weight:300;color:white;">기종별 상세 설치비용</h2>
      <div class="section-divider"></div>
      <p style="font-size:14px;color:rgba(255,255,255,0.45);margin-top:16px;line-height:1.8;">재료비(배관·부속품) 포함 기준 참고가격 — 현장 실측 후 정확한 견적 제공</p>
    </div>

    <div class="type-grid">
      {typeCards.map((card) => (
        <div class={`type-card${card.highlight ? ' type-card--highlight' : ''}`}>
          {card.highlight && (
            <div style="position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:linear-gradient(90deg,var(--blue-deep),var(--blue));padding:4px 20px;font-size:9px;letter-spacing:0.3em;text-transform:uppercase;color:white;white-space:nowrap;">주력 상품</div>
          )}
          <div style="margin-bottom:20px;">
            <div style={`font-size:10px;letter-spacing:0.4em;text-transform:uppercase;margin-bottom:8px;color:${card.highlight ? 'var(--blue)' : 'rgba(255,255,255,0.4)'};`}>{card.label}</div>
            <h3 class="font-display" style="font-size:clamp(22px,2.5vw,30px);font-weight:300;color:white;margin-bottom:4px;">{card.name}</h3>
            <p style="font-size:12px;color:rgba(255,255,255,0.4);">{card.range}</p>
          </div>
          <div style="margin-bottom:24px;">
            <span class="font-display" style={`font-size:clamp(28px,3vw,40px);font-weight:300;line-height:1;${card.highlight ? 'background:linear-gradient(90deg,var(--blue),var(--blue-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;' : 'color:white;'}`}>{card.price}</span>
          </div>
          <ul style="list-style:none;padding:0;margin-bottom:24px;display:flex;flex-direction:column;gap:8px;">
            {card.includes.map((inc) => (
              <li style="display:flex;align-items:flex-start;gap:10px;font-size:12px;color:rgba(255,255,255,0.6);line-height:1.6;">
                <span style={`flex-shrink:0;width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;margin-top:1px;${card.highlight ? 'background:rgba(79,195,247,0.2);color:var(--blue);' : 'background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.5);'}`}>✓</span>
                {inc}
              </li>
            ))}
          </ul>
          <div style={`padding:12px 14px;font-size:11px;color:rgba(255,255,255,0.5);line-height:1.6;border-top:1px solid ${card.highlight ? 'rgba(79,195,247,0.2)' : 'rgba(255,255,255,0.06)'};`}>
            <span style={`font-size:9px;letter-spacing:0.3em;text-transform:uppercase;display:block;margin-bottom:4px;${card.highlight ? 'color:var(--blue);' : 'color:rgba(255,255,255,0.3);'}`}>추천 공간</span>
            {card.recommend}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- 브랜드별 비교 -->
<section style="background:var(--dark);padding:80px 8vw;border-top:1px solid rgba(79,195,247,0.08);">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <span class="section-label">Brand Comparison</span>
      <h2 class="font-display" style="font-size:clamp(26px,3.5vw,48px);font-weight:300;color:white;">브랜드별 비교</h2>
      <div class="section-divider"></div>
      <p style="font-size:14px;color:rgba(255,255,255,0.45);margin-top:16px;">LG · 삼성 · 캐리어 · 위니아 — 모든 브랜드 공식 시공 가능</p>
    </div>

    <div style="border:1px solid rgba(79,195,247,0.1);overflow:hidden;">
      <!-- 헤더 -->
      <div class="brand-table-row brand-table-header">
        <div class="brand-table-label" style="font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:rgba(255,255,255,0.3);">항목</div>
        {brands.map((b) => (
          <div style="padding:16px 20px;font-size:13px;font-weight:600;color:white;text-align:center;">
            <span class="font-display" style="font-size:18px;font-weight:300;">{b.name}</span>
          </div>
        ))}
      </div>
      <!-- 가격대 -->
      <div class="brand-table-row">
        <div class="brand-table-label">가격대</div>
        {brands.map((b) => (
          <div class="brand-table-cell">
            <span style={`font-size:12px;padding:3px 10px;border-radius:2px;${b.price === '고급' ? 'background:rgba(79,195,247,0.15);color:var(--blue);' : b.price === '중고급' ? 'background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.7);' : 'background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.5);'}`}>{b.price}</span>
          </div>
        ))}
      </div>
      <!-- 에너지효율 -->
      <div class="brand-table-row">
        <div class="brand-table-label">에너지효율</div>
        {brands.map((b) => (
          <div class="brand-table-cell">
            <span style="font-size:12px;color:rgba(79,195,247,0.9);">{b.energy}</span>
          </div>
        ))}
      </div>
      <!-- 주요 특징 -->
      <div class="brand-table-row">
        <div class="brand-table-label">주요 특징</div>
        {brands.map((b) => (
          <div class="brand-table-cell" style="font-size:11px;color:rgba(255,255,255,0.55);line-height:1.6;text-align:center;">{b.feature}</div>
        ))}
      </div>
      <!-- AS -->
      <div class="brand-table-row" style="border-bottom:none;">
        <div class="brand-table-label">A/S</div>
        {brands.map((b) => (
          <div class="brand-table-cell" style="font-size:11px;color:rgba(255,255,255,0.45);line-height:1.6;text-align:center;">{b.as}</div>
        ))}
      </div>
    </div>

    <p style="font-size:12px;color:rgba(255,255,255,0.3);margin-top:16px;line-height:1.7;">
      * 최종 브랜드·모델 선택은 현장 환경·예산·용도에 맞춰 전문가 상담 후 결정하시길 권장드립니다.
    </p>
  </div>
</section>

<!-- 용량별 가격표 (기존) -->
<section style="background:var(--dark2);padding:80px 8vw;border-top:1px solid rgba(79,195,247,0.08);">
  <div style="max-width:1100px;margin:0 auto;">

    <div style="margin-bottom:40px;">
      <span class="section-label">용량별 참고 가격</span>
      <h2 class="font-display" style="font-size:clamp(26px,3.5vw,48px);font-weight:300;color:white;">평수별 설치 비용</h2>
      <div class="section-divider" style="margin-left:0;"></div>
    </div>

    <div style="border:1px solid rgba(79,195,247,0.1);overflow:hidden;">
      <div class="price-table-header">
        <div class="price-th">구분</div>
        <div class="price-th">용량</div>
        <div class="price-th">참고가격 (재료비 포함)</div>
        <div class="price-th price-th-hide">비고</div>
      </div>
      {priceTable.map((row, i) => (
        <div class={`price-table-row${i % 2 === 0 ? '' : ' price-row-alt'}`}>
          <div class="price-td price-td-name">{row.size}</div>
          <div class="price-td price-td-range">{row.range}</div>
          <div class="price-td price-td-price font-display">{row.price}</div>
          <div class="price-td price-td-desc price-th-hide">{row.desc}</div>
        </div>
      ))}
    </div>

    <p style="font-size:12px;color:rgba(255,255,255,0.3);margin-top:16px;line-height:1.7;">
      * 위 금액은 참고용이며 실제 비용은 현장 확인 후 결정됩니다.<br/>
      * 배관 길이, 층간 관통, 추가 자재 등에 따라 변동될 수 있습니다.
    </p>
  </div>
</section>

<!-- 비용 결정 요소 -->
<section style="background:var(--dark);padding:80px 8vw;border-top:1px solid rgba(79,195,247,0.08);">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <span class="section-label">Cost Factors</span>
      <h2 class="font-display" style="font-size:clamp(26px,3.5vw,48px);font-weight:300;color:white;">이런 요소들로 비용이 달라집니다</h2>
      <div class="section-divider"></div>
    </div>
    <div class="factor-grid">
      <div class="factor-card">
        <div style="font-size:28px;margin-bottom:16px;">📐</div>
        <div style="font-size:13px;font-weight:600;color:white;margin-bottom:8px;">공간 면적</div>
        <div style="font-size:12px;color:rgba(255,255,255,0.4);line-height:1.7;">설치 공간의 평수에 따라 에어컨 용량과 비용이 달라집니다.</div>
      </div>
      <div class="factor-card">
        <div style="font-size:28px;margin-bottom:16px;">🔧</div>
        <div style="font-size:13px;font-weight:600;color:white;margin-bottom:8px;">배관 길이</div>
        <div style="font-size:12px;color:rgba(255,255,255,0.4);line-height:1.7;">실내기~실외기 간 거리가 길수록 배관 자재비가 추가됩니다.</div>
      </div>
      <div class="factor-card">
        <div style="font-size:28px;margin-bottom:16px;">🏢</div>
        <div style="font-size:13px;font-weight:600;color:white;margin-bottom:8px;">설치 환경</div>
        <div style="font-size:12px;color:rgba(255,255,255,0.4);line-height:1.7;">층간 관통, 외벽 타공, 천장 구조에 따라 공임이 달라집니다.</div>
      </div>
      <div class="factor-card">
        <div style="font-size:28px;margin-bottom:16px;">❄️</div>
        <div style="font-size:13px;font-weight:600;color:white;margin-bottom:8px;">에어컨 종류</div>
        <div style="font-size:12px;color:rgba(255,255,255,0.4);line-height:1.7;">천장형 4WAY, 스탠드, 벽걸이 등 기종별로 설치 난이도가 다릅니다.</div>
      </div>
    </div>
  </div>
</section>

<!-- 추가 발생 가능 비용 -->
<section style="background:var(--dark2);padding:80px 8vw;border-top:1px solid rgba(79,195,247,0.08);">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start;" class="extra-grid">
      <div>
        <span class="section-label">Additional Costs</span>
        <h2 class="font-display" style="font-size:clamp(24px,3vw,42px);font-weight:300;color:white;margin-bottom:16px;">추가 발생 가능 비용</h2>
        <div class="section-divider" style="margin-left:0;"></div>
        <p style="font-size:13px;color:rgba(255,255,255,0.45);margin-top:20px;line-height:1.8;">
