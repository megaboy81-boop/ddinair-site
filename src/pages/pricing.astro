<script is:inline>
// FAQ 아코디언
function toggleFaq(index) {
  var body = document.getElementById('faq-body-' + index);
  var icon = document.getElementById('faq-icon-' + index);
  var item = document.getElementById('faq-' + index);
  var isOpen = item.classList.contains('open');

  // 모두 닫기
  document.querySelectorAll('.faq-item').forEach(function(el, i) {
    el.classList.remove('open');
    var b = document.getElementById('faq-body-' + i);
    var ic = document.getElementById('faq-icon-' + i);
    if (b) b.style.maxHeight = '0';
    if (ic) { ic.textContent = '+'; ic.style.transform = 'rotate(0deg)'; }
    var trigger = el.querySelector('.faq-trigger');
    if (trigger) trigger.setAttribute('aria-expanded', 'false');
  });

  if (!isOpen) {
    item.classList.add('open');
    body.style.maxHeight = body.scrollHeight + 'px';
    icon.textContent = '−';
    icon.style.transform = 'rotate(0deg)';
    item.querySelector('.faq-trigger').setAttribute('aria-expanded', 'true');
  }
}

// Lenis smooth scroll
window.addEventListener('load', function() {
  var LenisClass = window.Lenis;
  if (LenisClass) {
    var lenis = new LenisClass({ lerp: 0.1, smoothWheel: true });
    var gsapLib = window.gsap;
    var STLib = window.ScrollTrigger;
    if (gsapLib && STLib) {
      gsapLib.ticker.add(function(time) { lenis.raf(time * 1000); });
      gsapLib.ticker.lagSmoothing(0);
      lenis.on('scroll', STLib.update);
    } else {
      function raf(t) { lenis.raf(t); requestAnimationFrame(raf); }
      requestAnimationFrame(raf);
    }
  }

  // GSAP fade-in on scroll
  if (window.gsap && window.ScrollTrigger) {
    gsap.registerPlugin(ScrollTrigger);
    gsap.utils.toArray('.type-card, .factor-card, .faq-item, .brand-table-row').forEach(function(el) {
      gsap.fromTo(el,
        { opacity: 0, y: 20 },
        {
          opacity: 1, y: 0, duration: 0.6, ease: 'power2.out',
          scrollTrigger: { trigger: el, start: 'top 88%', once: true }
        }
      );
    });
  }
});
</script>
