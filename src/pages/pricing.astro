---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const title = '에어컨 설치비용 안내 — DD에어컨';
const description = '남양주·다산신도시 시스템에어컨 설치비용 안내. 용량별 참고 가격 및 무료 방문 견적 신청.';

const priceTable = [
  { size: '소형', range: '10평 이하', price: '100~150만원', desc: '소형 벽걸이·천장형 1way' },
  { size: '중형', range: '10~20평', price: '150~250만원', desc: '중형 천장형 4way, 스탠드' },
  { size: '대형', range: '20~30평', price: '250~400만원', desc: '대형 시스템 에어컨' },
  { size: '대형+', range: '30평 이상', price: '별도 견적', desc: '현장 확인 후 안내' },
];
---
<Layout title={title} description={description}>

<!-- 페이지 헤더 -->
<section style="background:var(--dark);padding:160px 8vw 80px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 30% 50%,rgba(79,195,247,0.05),transparent 60%);"></div>
  <div style="max-width:1100px;margin:0 auto;position:relative;">
    <span class="section-label">Pricing Guide</span>
    <h1 class="font-display" style="font-size:clamp(38px,6vw,80px);font-weight:300;color:white;line-height:1;letter-spacing:0.02em;margin-bottom:24px;">
      설치비용 안내<br/><span class="blue-gradient" style="font-style:italic;">투명한 견적</span>
    </h1>
    <p style="font-size:16px;color:rgba(255,255,255,0.55);font-weight:300;line-height:1.9;max-width:560px;">
      시스템에어컨은 설치 환경에 따라 비용이 달라집니다.<br/>무료 방문 견적 후 정확한 금액 안내드립니다.
    </p>
  </div>
</section>

<!-- 가격표 -->
<section style="background:var(--dark);padding:0 8vw 80px;position:relative;z-index:2;">
  <div style="max-width:1100px;margin:0 auto;">

    <!-- 정부지원 배너 -->
    <div style="border:1px solid rgba(79,195,247,0.4);background:rgba(79,195,247,0.05);padding:20px 28px;margin-bottom:40px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">
      <div>
        <div style="font-size:10px;letter-spacing:0.4em;text-transform:uppercase;color:var(--blue);margin-bottom:6px;">Government Support</div>
        <p style="font-size:14px;color:white;">정부지원 시 최대 40% 할인 가능 — 한전 고효율기기 보급사업</p>
      </div>
      <a href="{base}/subsidy" style="display:inline-flex;align-items:center;gap:8px;text-decoration:none;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:var(--blue);border:1px solid rgba(79,195,247,0.5);padding:10px 20px;white-space:nowrap;transition:all 0.3s;" onmouseover="this.style.background='rgba(79,195,247,0.1)'" onmouseout="this.style.background='transparent'">
        정부지원사업 보기 →
      </a>
    </div>

    <div style="margin-bottom:40px;">
      <span class="section-label">용량별 참고 가격</span>
      <h2 class="font-display" style="font-size:clamp(26px,3.5vw,48px);font-weight:300;color:white;">설치 비용 안내</h2>
      <div class="section-divider" style="margin-left:0;"></div>
    </div>

    <!-- 가격 테이블 -->
    <div style="border:1px solid rgba(79,195,247,0.1);overflow:hidden;">
      <div style="display:grid;grid-template-columns:100px 1fr 1fr 2fr;background:rgba(79,195,247,0.08);border-bottom:1px solid rgba(79,195,247,0.15);">
        <div style="padding:14px 20px;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:var(--blue);">구분</div>
        <div style="padding:14px 20px;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:var(--blue);">용량</div>
        <div style="padding:14px 20px;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:var(--blue);">참고가격(재료비 포함)</div>
        <div style="padding:14px 20px;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:var(--blue);">비고</div>
      </div>
      {priceTable.map((row, i) => (
        <div style={} onmouseover="this.style.background='rgba(79,195,247,0.04)'" onmouseout={}>
          <div style="padding:18px 20px;font-size:13px;font-weight:600;color:white;">{row.size}</div>
          <div style="padding:18px 20px;font-size:13px;color:rgba(255,255,255,0.65);">{row.range}</div>
          <div style="padding:18px 20px;font-size:15px;font-family:'Cormorant Garamond',serif;font-weight:400;color:var(--blue);">{row.price}</div>
          <div style="padding:18px 20px;font-size:12px;color:rgba(255,255,255,0.4);">{row.desc}</div>
        </div>
      ))}
    </div>

    <p style="font-size:12px;color:rgba(255,255,255,0.3);margin-top:16px;line-height:1.7;">
      * 위 금액은 참고용이며 실제 비용은 현장 확인 후 결정됩니다.<br/>
      * 배관 길이, 층간 관통, 추가 자재 등에 따라 변동될 수 있습니다.
    </p>
  </div>
</section>

<!-- 비용 결정 요소 -->
<section style="background:var(--dark2);padding:80px 8vw;border-top:1px solid rgba(79,195,247,0.08);">
  <div style="max-width:1100px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <span class="section-label">비용 결정 요소</span>
      <h2 class="font-display" style="font-size:clamp(26px,3.5vw,48px);font-weight:300;color:white;">이런 요소들로 비용이 달라집니다</h2>
      <div class="section-divider"></div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;">
      <div style="padding:32px 24px;border:1px solid rgba(79,195,247,0.1);background:rgba(79,195,247,0.02);text-align:center;">
        <div style="font-size:28px;margin-bottom:16px;">📐</div>
        <div style="font-size:13px;font-weight:600;color:white;margin-bottom:8px;">공간 면적</div>
        <div style="font-size:12px;color:rgba(255,255,255,0.4);line-height:1.7;">설치 공간의 평수에 따라 에어컨 용량과 비용이 달라집니다.</div>
      </div>
      <div style="padding:32px 24px;border:1px solid rgba(79,195,247,0.1);background:rgba(79,195,247,0.02);text-align:center;">
        <div style="font-size:28px;margin-bottom:16px;">🔧</div>
        <div style="font-size:13px;font-weight:600;color:white;margin-bottom:8px;">배관 길이</div>
        <div style="font-size:12px;color:rgba(255,255,255,0.4);line-height:1.7;">실내기~실외기 간 거리가 길수록 배관 자재비가 추가됩니다.</div>
      </div>
      <div style="padding:32px 24px;border:1px solid rgba(79,195,247,0.1);background:rgba(79,195,247,0.02);text-align:center;">
        <div style="font-size:28px;margin-bottom:16px;">🏢</div>
        <div style="font-size:13px;font-weight:600;color:white;margin-bottom:8px;">설치 환경</div>
        <div style="font-size:12px;color:rgba(255,255,255,0.4);line-height:1.7;">층간 관통, 외벽 타공, 천장 구조에 따라 공임이 달라집니다.</div>
      </div>
      <div style="padding:32px 24px;border:1px solid rgba(79,195,247,0.1);background:rgba(79,195,247,0.02);text-align:center;">
        <div style="font-size:28px;margin-bottom:16px;">❄️</div>
        <div style="font-size:13px;font-weight:600;color:white;margin-bottom:8px;">에어컨 종류</div>
        <div style="font-size:12px;color:rgba(255,255,255,0.4);line-height:1.7;">천장형 4WAY, 스탠드, 벽걸이 등 기종별로 설치 난이도가 다릅니다.</div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section style="background:var(--dark);padding:80px 8vw;border-top:1px solid rgba(79,195,247,0.08);">
  <div style="max-width:700px;margin:0 auto;text-align:center;">
    <span class="section-label">Free Estimate</span>
    <h2 class="font-display" style="font-size:clamp(28px,4vw,52px);font-weight:300;color:white;margin-bottom:16px;">
      현장 방문 견적<br/><span class="blue-gradient" style="font-style:italic;">무료로 제공합니다</span>
    </h2>
    <div class="section-divider"></div>
    <p style="font-size:14px;color:rgba(255,255,255,0.45);margin-top:20px;margin-bottom:36px;line-height:1.8;">
      정확한 견적은 현장 확인 후에만 가능합니다.<br/>방문 견적은 완전 무료이며 부담 없이 신청하세요.
    </p>
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <a href="tel:010-7237-2122" class="btn-primary" style="padding:18px 48px;font-size:11px;">전화로 견적 신청</a>
      <a href="{base}/contact" class="btn-outline" style="padding:17px 40px;font-size:11px;">온라인 문의</a>
    </div>
  </div>
</section>

</Layout>

<style>
@media (max-width: 768px) {
  section > div[style*="grid-template-columns:repeat(4"] {
    grid-template-columns: repeat(2, 1fr) !important;
  }
  div[style*="grid-template-columns:100px 1fr 1fr 2fr"] {
    grid-template-columns: 80px 1fr 1fr !important;
  }
  div[style*="grid-template-columns:100px 1fr 1fr 2fr"] > div:last-child {
    display: none;
  }
}
@media (max-width: 480px) {
  section > div[style*="grid-template-columns:repeat(4"] {
    grid-template-columns: 1fr 1fr !important;
  }
}
</style>

<script is:inline>
window.addEventListener('load', function() {
  if (typeof Lenis !== 'undefined') {
    const lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
    function raf(t) { lenis.raf(t); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);
  }
});
</script>
