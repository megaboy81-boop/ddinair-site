<section style="padding:120px 8vw;text-align:center;position:relative;overflow:hidden;background:var(--dark2);z-index:2;">
  <div style="position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse at center,rgba(79,195,247,0.06) 0%,transparent 70%);"></div>
  <p class="section-label gsap-fade" style="margin-bottom:20px;">Quick Service</p>
  <h2 class="font-display gsap-fade" style="font-size:clamp(36px,6vw,72px);font-weight:300;color:white;line-height:1.1;margin-bottom:24px;letter-spacing:0.02em;">
