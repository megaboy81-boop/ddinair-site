---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const title = '디디에어컨 | 남양주 에어컨 설치·판매·수리 전문';
const description = '남양주·다산신도시 에어컨 전문 설치 업체. 천장형 4WAY·스탠드·벽걸이 설치, 에어컨 수리·이전. 당일 출장 가능. 70건+ 시공 실적.';
---

<Layout title={title} description={description}>

  <!-- ══════════════════════════════════════════
       SECTION 1: HERO — 정적 배경 이미지
  ══════════════════════════════════════════ -->
  <section id="hero" style="position:relative;height:100dvh;min-height:640px;background:#09090b;overflow:hidden;display:flex;align-items:center;justify-content:center;">

    <!-- 배경 이미지 (천장형 카세트 에어컨) -->
    <img
      src="https://images.unsplash.com/photo-1633098096918-f12258de36f1?q=85&w=2400&auto=format&fit=crop"
      alt="천장형 4WAY 카세트 에어컨"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;"
      fetchpriority="high"
    />

    <!-- 다층 오버레이 -->
    <div style="position:absolute;inset:0;background:linear-gradient(160deg,rgba(0,0,0,0.72) 0%,rgba(0,0,0,0.45) 50%,rgba(0,0,0,0.78) 100%);z-index:1;"></div>

    <!-- 중앙 콘텐츠 -->
    <div id="hero-content" style="position:relative;z-index:2;text-align:center;padding:0 24px;max-width:860px;">

      <!-- 배지 pill -->
      <span id="hero-badge" style="display:inline-block;padding:6px 18px;border-radius:9999px;background:rgba(255,255,255,0.1);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.22);color:rgba(255,255,255,0.92);font-size:11px;font-weight:600;letter-spacing:0.35em;text-transform:uppercase;margin-bottom:30px;opacity:0;transform:scale(0.94);">
        남양주 에어컨 전문 시공팀 · 직영 운영
      </span>

      <!-- 메인 헤드라인 -->
      <h1 id="hero-h1" style="font-size:clamp(56px,10.5vw,136px);font-weight:900;letter-spacing:-0.03em;line-height:1;color:white;margin-bottom:26px;opacity:0;transform:translateY(32px);">
        완벽한 설치<br/><span style="color:rgba(255,255,255,0.55);">디디에어컨</span>
      </h1>

      <!-- 서브 카피 -->
      <p id="hero-p" style="font-size:clamp(15px,1.9vw,20px);color:rgba(255,255,255,0.68);font-weight:300;letter-spacing:0.06em;line-height:1.7;margin-bottom:44px;opacity:0;transform:translateY(20px);">
        정확한 설계 &nbsp;·&nbsp; 깔끔한 배관 &nbsp;·&nbsp; 섬세한 마감
      </p>

      <!-- CTA 버튼 -->
      <div id="hero-cta" style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;opacity:0;transform:translateY(20px);">
        <a href={`${base}/contact`} class="btn-dark" style="font-size:14px;padding:15px 34px;">
          무료 상담 신청 →
        </a>
        <a href={`${base}/cases`} class="btn-outline" style="font-size:14px;padding:15px 34px;">
          시공사례 보기
        </a>
      </div>
    </div>

    <!-- 스크롤 유도 -->
    <div id="scroll-indicator" style="position:absolute;bottom:40px;left:50%;transform:translateX(-50%);z-index:2;display:flex;flex-direction:column;align-items:center;gap:10px;opacity:0;">
      <span style="font-size:10px;letter-spacing:0.35em;color:rgba(255,255,255,0.38);text-transform:uppercase;">Scroll</span>
      <div style="width:1px;height:44px;background:linear-gradient(to bottom,rgba(255,255,255,0.38),transparent);animation:scrollPulse 2.2s ease-in-out infinite;"></div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       NOTICE STRIP — 한전 지원사업 (slim banner)
  ══════════════════════════════════════════ -->
  <div style="background:#1d4ed8;padding:14px 24px;text-align:center;position:relative;z-index:2;">
    <p style="font-size:13px;font-weight:600;color:white;letter-spacing:0.04em;">
      📋 &nbsp;2026년 한전 고효율기기 지원사업 — 1등급 에어컨 설치 시 최대 <strong>160만원</strong> 현금 환급 &nbsp;
      <a href={`${base}/subsidy`} style="color:rgba(255,255,255,0.8);text-decoration:underline;font-size:12px;letter-spacing:0.1em;">자세히 보기 →</a>
    </p>
  </div>

  <!-- ══════════════════════════════════════════
       SECTION 2: BRAND STORY — 2컬럼 (텍스트 + 이미지)
  ══════════════════════════════════════════ -->
  <section style="padding:120px 48px;background:#ffffff;">
    <div class="section-container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;" class="brand-grid">

        <!-- 텍스트 -->
        <div class="reveal-left">
          <span class="section-label-sm">About 디디에어컨</span>
          <h2 style="font-size:clamp(34px,4.8vw,62px);font-weight:900;letter-spacing:-0.03em;line-height:1.1;margin-bottom:28px;color:#09090b;">
            전문 기술팀<br/>직영 운영
          </h2>
          <p style="font-size:16px;color:#71717a;line-height:1.95;font-weight:300;margin-bottom:16px;">
            디디에어컨은 남양주·다산신도시를 거점으로 하는 에어컨 전문 <strong style="color:#09090b;font-weight:600;">직영 시공팀</strong>입니다.
            삼성·LG 공식 인증 기술자가 직접 현장에 나가 설계부터 시공까지 원스톱으로 처리합니다.
          </p>
          <p style="font-size:16px;color:#71717a;line-height:1.95;font-weight:300;margin-bottom:40px;">
            천장형 4WAY 카세트 · 덕트형 · 스탠드 · 벽걸이 전 기종 설치 가능.
            배관 정리, 드레인 레벨링, 냉매 충전까지 완벽히 마무리합니다.
          </p>

          <!-- 핵심 수치 3개 -->
          <div style="display:flex;gap:32px;margin-bottom:44px;flex-wrap:wrap;">
            <div>
              <span style="font-size:36px;font-weight:900;letter-spacing:-0.03em;color:#09090b;display:block;line-height:1;">70<span style="font-size:0.55em;font-weight:400;">+</span></span>
              <span style="font-size:11px;color:#a1a1aa;letter-spacing:0.2em;text-transform:uppercase;">시공 실적</span>
            </div>
            <div style="width:1px;background:#e4e4e7;"></div>
            <div>
              <span style="font-size:36px;font-weight:900;letter-spacing:-0.03em;color:#09090b;display:block;line-height:1;">5<span style="font-size:0.55em;font-weight:400;">년+</span></span>
              <span style="font-size:11px;color:#a1a1aa;letter-spacing:0.2em;text-transform:uppercase;">현장 경력</span>
            </div>
            <div style="width:1px;background:#e4e4e7;"></div>
            <div>
              <span style="font-size:36px;font-weight:900;letter-spacing:-0.03em;color:#09090b;display:block;line-height:1;">100<span style="font-size:0.55em;font-weight:400;">%</span></span>
              <span style="font-size:11px;color:#a1a1aa;letter-spacing:0.2em;text-transform:uppercase;">AS 보장</span>
            </div>
          </div>

          <a href={`${base}/cases`} style="display:inline-flex;align-items:center;gap:8px;font-size:13px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#09090b;text-decoration:none;padding-bottom:3px;border-bottom:2px solid #09090b;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.45'" onmouseout="this.style.opacity='1'">
            시공사례 보기 →
          </a>
        </div>

        <!-- 이미지 -->
        <div class="reveal-scale">
          <div class="card-image-wrap" style="aspect-ratio:4/5;border-radius:24px;">
            <img
              src="https://images.unsplash.com/photo-1765371514777-73aaaab1c6d3?q=80&w=1200&auto=format&fit=crop"
              alt="에어컨 시공 완료 후 쾌적한 인테리어"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       SECTION 3: SERVICES — 3컬럼 × 2행 카드 그리드
  ══════════════════════════════════════════ -->
  <section style="padding:120px 48px;background:#fafafa;border-top:1px solid #f4f4f5;">
    <div class="section-container">

      <!-- 섹션 헤더 -->
      <div class="reveal" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:72px;gap:24px;flex-wrap:wrap;">
        <div>
          <span class="section-label-sm">Our Services</span>
          <h2 style="font-size:clamp(30px,4.2vw,54px);font-weight:900;letter-spacing:-0.03em;color:#09090b;margin-bottom:8px;">시공 서비스</h2>
          <p style="font-size:16px;color:#71717a;">전문 직영팀의 에어컨 설치 · 수리 · 관리 전 서비스</p>
        </div>
        <a href={`${base}/contact`} class="btn-outline-dark" style="white-space:nowrap;">상담 신청 →</a>
      </div>

      <!-- Row 1 -->
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:28px;" class="services-grid">

        <!-- 천장형 4WAY -->
        <div class="reveal service-card">
          <div class="card-image-wrap" style="aspect-ratio:4/3;margin-bottom:22px;border-radius:16px;">
            <img
              src="https://images.unsplash.com/photo-1633098096918-f12258de36f1?q=80&w=1200&auto=format&fit=crop"
              alt="천장형 4WAY 카세트 에어컨 설치"
              loading="lazy"
            />
          </div>
          <span style="font-size:10px;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:#a1a1aa;display:block;margin-bottom:8px;">System AC · Cassette</span>
          <h3 style="font-size:19px;font-weight:700;letter-spacing:-0.02em;margin-bottom:10px;color:#09090b;">천장형 4WAY 설치</h3>
          <p style="font-size:14px;color:#71717a;line-height:1.75;">카세트형 · 덕트형 시스템에어컨 정밀 설계 및 시공. 배관 정리·드레인 레벨링·전기 작업 포함. 상업공간·사무실 전문.</p>
        </div>

        <!-- 수리·이전 -->
        <div class="reveal service-card">
          <div class="card-image-wrap" style="aspect-ratio:4/3;margin-bottom:22px;border-radius:16px;">
            <img
              src="https://images.unsplash.com/photo-1770838773417-08b18661c62f?q=80&w=1200&auto=format&fit=crop"
              alt="에어컨 수리 및 이전설치 시공"
              loading="lazy"
            />
          </div>
          <span style="font-size:10px;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:#a1a1aa;display:block;margin-bottom:8px;">Repair · Relocation</span>
          <h3 style="font-size:19px;font-weight:700;letter-spacing:-0.02em;margin-bottom:10px;color:#09090b;">수리 · 이전설치</h3>
          <p style="font-size:14px;color:#71717a;line-height:1.75;">냉매 충전, 소음·누수 원인 정밀 진단, 부품 교체. 이전설치 시 배관 재정리 · 드레인 재레벨링 원스톱 처리.</p>
        </div>

        <!-- 한전 지원사업 -->
        <div class="reveal service-card">
          <div class="card-image-wrap" style="aspect-ratio:4/3;margin-bottom:22px;border-radius:16px;position:relative;">
            <img
              src="https://images.unsplash.com/photo-1762341123870-d706f257a12e?q=80&w=1200&auto=format&fit=crop"
              alt="에너지 절약형 1등급 에어컨 설치"
              loading="lazy"
            />
            <div style="position:absolute;top:12px;left:12px;padding:5px 12px;background:#1d4ed8;color:white;font-size:10px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;border-radius:6px;">최대 160만원</div>
          </div>
          <span style="font-size:10px;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:#2563eb;display:block;margin-bottom:8px;">KEPCO 2026 · 정부지원</span>
          <h3 style="font-size:19px;font-weight:700;letter-spacing:-0.02em;margin-bottom:10px;color:#09090b;">한전 지원사업</h3>
          <p style="font-size:14px;color:#71717a;line-height:1.75;">2026 한전 고효율기기 보조사업. 1등급 에어컨 설치 시 구매가의 <strong style="color:#09090b;">40% 현금 환급</strong>. DD에어컨이 신청 대행.</p>
        </div>
      </div>

      <!-- Row 2 -->
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:28px;margin-top:28px;" class="services-grid">

        <!-- 당일 출장 -->
        <div class="reveal service-card">
          <div class="card-image-wrap" style="aspect-ratio:4/3;margin-bottom:22px;border-radius:16px;">
            <img
              src="https://images.unsplash.com/photo-1732395805034-e0bf859665e5?q=80&w=1200&auto=format&fit=crop"
              alt="에어컨 당일 출장 서비스 기사"
              loading="lazy"
            />
          </div>
          <span style="font-size:10px;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:#a1a1aa;display:block;margin-bottom:8px;">Same Day · Express</span>
          <h3 style="font-size:19px;font-weight:700;letter-spacing:-0.02em;margin-bottom:10px;color:#09090b;">당일 출장</h3>
          <p style="font-size:14px;color:#71717a;line-height:1.75;">남양주 · 구리 · 하남 · 의정부 · 서울 전역 당일 방문. 오전 접수 시 당일 오후 출동 가능. 365일 운영.</p>
        </div>

        <!-- 벽걸이·스탠드 -->
        <div class="reveal service-card">
          <div class="card-image-wrap" style="aspect-ratio:4/3;margin-bottom:22px;border-radius:16px;">
            <img
              src="https://images.unsplash.com/photo-1757219525975-03b5984bc6e8?q=80&w=1200&auto=format&fit=crop"
              alt="벽걸이 에어컨 설치"
              loading="lazy"
            />
          </div>
          <span style="font-size:10px;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:#a1a1aa;display:block;margin-bottom:8px;">Wall · Stand Type</span>
          <h3 style="font-size:19px;font-weight:700;letter-spacing:-0.02em;margin-bottom:10px;color:#09090b;">스탠드 · 벽걸이</h3>
          <p style="font-size:14px;color:#71717a;line-height:1.75;">가정용 벽걸이 · 스탠드형 전 기종 설치. 실외기 위치 선정, 배관 홀 가공, 전용 회로 작업 포함.</p>
        </div>

        <!-- 청소·가스충전 -->
        <div class="reveal service-card">
          <div class="card-image-wrap" style="aspect-ratio:4/3;margin-bottom:22px;border-radius:16px;">
            <img
              src="https://images.unsplash.com/photo-1601659404194-97d2daca8383?q=80&w=1200&auto=format&fit=crop"
              alt="에어컨 분해 청소 및 냉매 가스 충전"
              loading="lazy"
            />
          </div>
          <span style="font-size:10px;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:#a1a1aa;display:block;margin-bottom:8px;">Maintenance · Cleaning</span>
          <h3 style="font-size:19px;font-weight:700;letter-spacing:-0.02em;margin-bottom:10px;color:#09090b;">청소 · 가스충전</h3>
          <p style="font-size:14px;color:#71717a;line-height:1.75;">실내기 분해 클리닝, 필터·열교환기 세척. 냉매(R32 · R410A) 부족 진단 및 충전. 냄새·결로 완전 제거.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       SECTION 4: CASES — NOVA Journal 스타일 3컬럼
  ══════════════════════════════════════════ -->
  <section style="padding:120px 48px;background:#ffffff;border-top:1px solid #f4f4f5;">
    <div class="section-container">
      <div class="reveal" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:64px;flex-wrap:wrap;gap:16px;">
        <div>
          <span class="section-label-sm">Installation Cases</span>
          <h2 style="font-size:clamp(30px,4.2vw,54px);font-weight:900;letter-spacing:-0.03em;color:#09090b;">최근 시공사례</h2>
        </div>
        <a href={`${base}/cases`} style="font-size:12px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#09090b;text-decoration:none;opacity:0.5;display:flex;align-items:center;gap:6px;transition:opacity 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.5'">
          전체 시공사례 →
        </a>
      </div>

      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:32px;row-gap:60px;" class="cases-grid">

        <!-- case 1: 상업공간 -->
        <a href={`${base}/cases`} style="display:flex;flex-direction:column;gap:20px;text-decoration:none;cursor:pointer;" class="reveal case-card">
          <div class="card-image-wrap" style="aspect-ratio:4/3;border-radius:16px;">
            <img
              src="https://images.unsplash.com/photo-1758691736933-bb0f88fe2e0c?q=80&w=1200&auto=format&fit=crop"
              alt="오피스 상업공간 4WAY 에어컨 시공"
              loading="lazy"
            />
          </div>
          <div>
            <p style="font-size:10px;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:#a1a1aa;margin-bottom:10px;">Commercial · Office</p>
            <h3 style="font-size:19px;font-weight:700;letter-spacing:-0.02em;margin-bottom:8px;color:#09090b;">성수 오피스 4WAY 설치</h3>
            <p style="font-size:14px;color:#71717a;line-height:1.7;">100평 오피스 천장형 카세트 에어컨 6대 동시 시공. 배관 은닉 처리 및 드레인 통합 배선 완료.</p>
            <p style="font-size:12px;color:#a1a1aa;margin-top:12px;letter-spacing:0.05em;">2026년 2월 · 서울 성동구</p>
          </div>
        </a>

        <!-- case 2: 의료시설 -->
        <a href={`${base}/cases`} style="display:flex;flex-direction:column;gap:20px;text-decoration:none;cursor:pointer;" class="reveal case-card">
          <div class="card-image-wrap" style="aspect-ratio:4/3;border-radius:16px;">
            <img
              src="https://images.unsplash.com/photo-1762625570087-6d98fca29531?q=80&w=1200&auto=format&fit=crop"
              alt="치과 의원 4WAY 에어컨 시공사례"
              loading="lazy"
            />
          </div>
          <div>
            <p style="font-size:10px;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;color:#a1a1aa;margin-bottom:10px;">Medical · Clinic</p>
            <h3 style="font-size:19px;font-weight:700;letter-spacing:-0.02em;margin-bottom:8px;color:#09090b;">치과·피부과 시스템 설치</h3>
            <p style="font-size:14px;color:#71717a;line-height:1.7;">진료실 3개 + 대기실 카세트 에어컨 설치. 진동 차단재 적용으로 소음 최소화. 의료환경 특화 시공.</p>
            <p style="font-size:12px;color:#a1a1aa;margin-top:12px;letter-spacing:0.05em;">2026년 2월 · 서울 광진구</p>
          </div>
        </a>

        <!-- case 3: 카페·식음 -->
