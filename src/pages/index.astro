<script>
  // ══════════════════════════════════════════════════════════════════════════
  // 1. 파티클 캔버스
  // ══════════════════════════════════════════════════════════════════════════
  const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    let W = canvas.width = window.innerWidth;
    let H = canvas.height = window.innerHeight;
    window.addEventListener('resize', () => { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; });

    const pts = Array.from({ length: 55 }, () => ({
      x: Math.random() * W, y: Math.random() * H,
      vx: (Math.random() - 0.5) * 0.3, vy: (Math.random() - 0.5) * 0.3,
      r: Math.random() * 1.2 + 0.3,
    }));

    function drawParticles() {
      ctx.clearRect(0, 0, W, H);
      pts.forEach(p => {
        p.x += p.vx; p.y += p.vy;
        if (p.x < 0) p.x = W; if (p.x > W) p.x = 0;
        if (p.y < 0) p.y = H; if (p.y > H) p.y = 0;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(79,195,247,0.5)';
        ctx.fill();
      });
      for (let i = 0; i < pts.length; i++) {
        for (let j = i + 1; j < pts.length; j++) {
          const dx = pts[i].x - pts[j].x, dy = pts[i].y - pts[j].y;
          const d = Math.sqrt(dx * dx + dy * dy);
          if (d < 120) {
            ctx.beginPath();
            ctx.strokeStyle = `rgba(79,195,247,${0.08 * (1 - d / 120)})`;
            ctx.lineWidth = 0.5;
            ctx.moveTo(pts[i].x, pts[i].y);
            ctx.lineTo(pts[j].x, pts[j].y);
            ctx.stroke();
          }
        }
      }
      requestAnimationFrame(drawParticles);
    }
    drawParticles();
  }

  // ══════════════════════════════════════════════════════════════════════════
  // 2. GSAP 스크롤 스토리텔링 (window.load 후 실행 — CDN 스크립트 보장)
  // ══════════════════════════════════════════════════════════════════════════
  window.addEventListener('load', () => {
    const gsap = (window as any).gsap;
    const ScrollTrigger = (window as any).ScrollTrigger;
    const LenisLib = (window as any).Lenis;

    if (!gsap || !ScrollTrigger) return;
    gsap.registerPlugin(ScrollTrigger);

    // ── Lenis + ScrollTrigger 올바른 연결 ────────────────────────────────
    // Layout.astro가 만든 인스턴스는 raf 방식이므로 교체
    if ((window as any).__lenis) { try { (window as any).__lenis.destroy(); } catch(_) {} }
    if (LenisLib) {
      const lenis = new LenisLib({ lerp: 0.08, smoothWheel: true });
      (window as any).__lenis = lenis;
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((time: number) => { lenis.raf(time * 1000); });
      gsap.ticker.lagSmoothing(0);
    }

    // 데스크탑: 고정 배경 + 패널 전환
    const fixedBg = document.getElementById('story-fixed-bg');
    const bgSlides = document.querySelectorAll<HTMLElement>('.story-bg-slide');
    const panels = document.querySelectorAll<HTMLElement>('.story-panel');

    if (window.innerWidth > 900 && fixedBg) {
      fixedBg.style.display = 'block';

      panels.forEach((panel, i) => {
        ScrollTrigger.create({
          trigger: panel,
          start: 'top 55%',
          onEnter: () => {
            bgSlides.forEach((s, si) => { s.style.opacity = si === i ? '1' : '0'; });
          },
          onEnterBack: () => {
            bgSlides.forEach((s, si) => { s.style.opacity = si === i ? '1' : '0'; });
          },
        });
      });

      ScrollTrigger.create({
        trigger: '#story-container',
        start: 'top top',
        end: 'bottom bottom',
        onLeave: () => { if (fixedBg) fixedBg.style.opacity = '0'; },
        onEnterBack: () => { if (fixedBg) fixedBg.style.opacity = '1'; },
      });
    }

    // GSAP fade 요소들
    document.querySelectorAll('.gsap-fade').forEach(el => {
      gsap.to(el, {
        opacity: 1, y: 0, duration: 0.9, ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' },
      });
    });

    // 리뷰 카드 순차 등장
    document.querySelectorAll<HTMLElement>('.review-card').forEach((card) => {
      const delay = parseFloat(card.dataset.delay || '0');
      gsap.to(card, {
        opacity: 1, y: 0, duration: 0.8, delay, ease: 'power2.out',
        scrollTrigger: { trigger: card, start: 'top 85%', toggleActions: 'play none none none' },
      });
    });

    // ── 지원사업 패널: 한번에 빠르게 등장 ───────────────────────────────
    const subEyebrow = document.getElementById('sub-eyebrow');
    const subTitle   = document.getElementById('sub-title');
    const subLine    = document.getElementById('sub-line');
    const subDesc    = document.getElementById('sub-desc');
    const subBtns    = document.getElementById('sub-btns');
    const budgetBox  = document.getElementById('budget-box');

    if (subTitle) {
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: '#subsidy-panel',
          start: 'top 70%',
          toggleActions: 'play none none none',
        },
      });
      // 모든 요소 동시에 빠르게
      const items = [subEyebrow, subTitle, subDesc, subBtns, budgetBox].filter(Boolean);
      tl.to(items, { opacity: 1, y: 0, duration: 0.35, ease: 'power3.out', stagger: 0 }, 0)
        .to(subLine, { width: '40px', duration: 0.4, ease: 'power2.out' }, 0);
    }

    // 마그네틱 버튼
    document.querySelectorAll('.magnetic').forEach(btn => {
      btn.addEventListener('mousemove', (e: any) => {
        const rect = (btn as HTMLElement).getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        gsap.to(btn, { x: x * 0.18, y: y * 0.18, duration: 0.4, ease: 'power2.out' });
      });
      btn.addEventListener('mouseleave', () => {
        gsap.to(btn, { x: 0, y: 0, duration: 0.5, ease: 'elastic.out(1, 0.4)' });
      });
    });


    // ── 히어로 글자 폭발 ─────────────────────────────────────────────────────
    (function scatterHeroTitle() {
      const heroTitle = document.getElementById('hero-title');
      if (!heroTitle) return;

      heroTitle.querySelectorAll('div').forEach((d: any) => { d.style.overflow = 'visible'; });
      heroTitle.style.overflow = 'visible';

      const spans = heroTitle.querySelectorAll<HTMLElement>('span.title-slide-up');
      const allChars: HTMLElement[] = [];

      spans.forEach(span => {
        const text = span.textContent || '';
        span.textContent = '';
        span.style.cssText += ';-webkit-text-fill-color:white;background:none;';
        text.split('').forEach(ch => {
          const el = document.createElement('span');
          el.className = 'sc';
          el.textContent = ch;
          el.style.cssText = 'display:inline-block;will-change:transform,opacity;';
          span.appendChild(el);
          allChars.push(el);
        });
      });

      if (!allChars.length) return;

      const rx = allChars.map(() => (Math.random() - 0.5) * window.innerWidth * 2.6);
      const ry = allChars.map(() => (Math.random() - 0.5) * window.innerHeight * 2.6);
      const rr = allChars.map(() => Math.random() * 720 - 360);
      const rs = allChars.map(() => Math.random() * 0.4 + 0.05);

      const heroPanel = document.querySelector<HTMLElement>('.story-panel[data-index=0]');
      if (!heroPanel) return;

      gsap.to(allChars, {
        x: (i: number) => rx[i],
        y: (i: number) => ry[i],
        rotation: (i: number) => rr[i],
        opacity: 0,
        scale: (i: number) => rs[i],
        ease: 'power3.in',
        stagger: { each: 0.025, from: 'center' },
        scrollTrigger: {
          trigger: heroPanel,
          start: 'top top',
          end: 'bottom top',
          scrub: 1.0,
        },
      });
    })();

    // ── 히어로 캔버스 스크롤 프레임 애니메이션 ─────────────────────────────
    const heroCanvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
    if (heroCanvas && window.innerWidth > 900) {
      const ctx = heroCanvas.getContext('2d')!;
      const FRAME_COUNT = 100;
      const siteBase = document.querySelector('meta[name="site-base"]')?.getAttribute('content') || '';
      const frames: HTMLImageElement[] = new Array(FRAME_COUNT);
      let currentFrame = 0;

      function resizeCanvas() {
        heroCanvas.width = window.innerWidth;
        heroCanvas.height = window.innerHeight;
        drawFrame(currentFrame);
      }

      function drawFrame(idx: number) {
        const img = frames[idx];
        if (!img?.complete || !img.naturalWidth) return;
        const W = heroCanvas.width, H = heroCanvas.height;
        const scale = Math.max(W / img.naturalWidth, H / img.naturalHeight);
        const x = (W - img.naturalWidth * scale) / 2;
        const y = (H - img.naturalHeight * scale) / 2;
        ctx.clearRect(0, 0, W, H);
        ctx.drawImage(img, x, y, img.naturalWidth * scale, img.naturalHeight * scale);
      }

      resizeCanvas();
      window.addEventListener('resize', resizeCanvas);

      for (let i = 0; i < FRAME_COUNT; i++) {
        const img = new Image();
        img.src = `${siteBase}/images/hero-frames/frame_${String(i + 1).padStart(3, '0')}.webp`;
        img.onload = () => { if (i === 0) { resizeCanvas(); } };
        frames[i] = img;
      }

      const scrubObj = { frame: 0 };
      gsap.to(scrubObj, {
        frame: FRAME_COUNT - 1,
        ease: 'none',
        scrollTrigger: {
          trigger: '.story-panel[data-index="0"]',
          start: 'top top',
          end: 'bottom top',
          scrub: 0.5,
        },
        onUpdate() {
          const f = Math.round(scrubObj.frame);
          if (f !== currentFrame) {
            currentFrame = f;
            drawFrame(f);
          }
        },
      });
    }

    ScrollTrigger.refresh();
  });

  // ══════════════════════════════════════════════════════════════════════════
  // 3. 히어로 진입 애니메이션
  // ══════════════════════════════════════════════════════════════════════════
  window.addEventListener('load', () => {
    const eyebrowLine = document.getElementById('eyebrow-line');
    const eyebrowText = document.getElementById('eyebrow-text');
    const heroSub = document.getElementById('hero-sub');
    const heroCta = document.getElementById('hero-cta');

    setTimeout(() => {
      if (eyebrowLine) eyebrowLine.style.width = '48px';
      if (eyebrowText) eyebrowText.style.opacity = '1';
    }, 100);
    setTimeout(() => {
      if (heroSub) { heroSub.style.opacity = '1'; heroSub.style.transform = 'translateY(0)'; heroSub.style.transition = 'opacity 0.9s ease, transform 0.9s ease'; }
    }, 1100);
    setTimeout(() => {
      if (heroCta) { heroCta.style.opacity = '1'; heroCta.style.transform = 'translateY(0)'; heroCta.style.transition = 'opacity 0.9s ease, transform 0.9s ease'; }
    }, 1350);
  });

  // ══════════════════════════════════════════════════════════════════════════
  // 4. 카운터 애니메이션
  // ══════════════════════════════════════════════════════════════════════════
  const counterObs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseInt(el.dataset.target || '0');
      const suffix = el.dataset.suffix || '';
      const duration = 1800;
      const start = performance.now();
      function update(now: number) {
        const t = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - t, 3);
        el.textContent = Math.round(eased * target) + suffix;
        if (t < 1) requestAnimationFrame(update);
      }
      requestAnimationFrame(update);
      counterObs.unobserve(el);
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('.counter-num').forEach(el => counterObs.observe(el));

  // ══════════════════════════════════════════════════════════════════════════
  // 5. 가로 갤러리 드래그
  // ══════════════════════════════════════════════════════════════════════════
  const track = document.getElementById('hgal-track');
  if (track) {
    let isDown = false, startX = 0, scrollLeft = 0;
    track.addEventListener('mousedown', e => {
      isDown = true; (track as HTMLElement).style.cursor = 'grabbing';
      startX = e.pageX - (track as HTMLElement).offsetLeft; scrollLeft = (track as HTMLElement).scrollLeft;
    });
    track.addEventListener('mouseleave', () => { isDown = false; (track as HTMLElement).style.cursor = 'grab'; });
    track.addEventListener('mouseup', () => { isDown = false; (track as HTMLElement).style.cursor = 'grab'; });
    track.addEventListener('mousemove', e => {
      if (!isDown) return;
      e.preventDefault();
      const x = (e as MouseEvent).pageX - (track as HTMLElement).offsetLeft;
      (track as HTMLElement).scrollLeft = scrollLeft - (x - startX) * 1.5;
    });
  }

  // ══════════════════════════════════════════════════════════════════════════
  // 6. 한전 지원사업 예산 실시간 표시
  // ══════════════════════════════════════════════════════════════════════════
  (async function loadBudget() {
    const base = document.querySelector('meta[name="site-base"]')?.getAttribute('content') || '';
    try {
      const r = await fetch(`${base}/data/subsidy.json`);
      if (!r.ok) throw new Error('fetch failed');
      const d = await r.json();
      const remaining = typeof d.remaining === 'number' ? d.remaining : 67;
      const used = typeof d.used === 'number' ? d.used : (100 - remaining);

      const elLoading = document.getElementById('budget-loading');
      const elData = document.getElementById('budget-data');
      const elRemaining = document.getElementById('budget-remaining');
      const elBar = document.getElementById('budget-bar');
      const elUsed = document.getElementById('budget-used');
      const elUpdated = document.getElementById('budget-updated');

      if (elRemaining) elRemaining.textContent = remaining + '%';
      if (elUsed) elUsed.textContent = String(used);
      if (elUpdated) elUpdated.textContent = d.updated_label || d.updated || '';

      if (elLoading) elLoading.style.display = 'none';
      if (elData) elData.style.display = 'block';

      // 프로그레스 바 애니메이션 (잔여예산 %)
      setTimeout(() => {
        if (elBar) elBar.style.width = remaining + '%';
      }, 300);
    } catch (_) {
      // 조용히 실패 — 기본 텍스트 유지
      const elLoading = document.getElementById('budget-loading');
      if (elLoading) elLoading.textContent = '잔여예산 확인 중';
    }
  })();
</script>
