---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const title = '디디에어컨 | 남양주 에어컨 설치·판매·수리 전문';
const description = '남양주·다산신도시 에어컨 전문 설치 업체. 천장형 4WAY·스탠드·벽걸이 설치, 에어컨 수리·이전. 당일 출장 가능. 70건+ 시공 실적.';
---

<Layout title={title} description={description}>

  <!-- ══════════════════════════════════════════
       SECTION 1: HERO (full-screen dark, centered)
  ══════════════════════════════════════════ -->
  <section id="hero" style="position:relative;height:100dvh;min-height:600px;background:#09090b;overflow:hidden;display:flex;align-items:center;justify-content:center;">
    <!-- bg video -->
    <video id="hero-video" autoplay muted loop playsinline
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.7;">
      <source src={`${base}/images/hero-bg.mp4`} type="video/mp4" />
    </video>
    <!-- canvas overlay for WebP scroll animation -->
    <canvas id="hero-canvas"
      style="position:absolute;inset:0;width:100%;height:100%;opacity:0;transition:opacity 0.4s ease;"></canvas>
    <!-- dark gradient overlay -->
    <div style="position:absolute;inset:0;background:linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.1) 40%, rgba(0,0,0,0.5) 100%);z-index:1;"></div>

    <!-- centered content -->
    <div id="hero-content" style="position:relative;z-index:2;text-align:center;padding:0 24px;max-width:900px;">
      <!-- badge pill -->
      <span id="hero-badge" style="display:inline-block;padding:6px 16px;border-radius:9999px;background:rgba(255,255,255,0.1);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.9);font-size:11px;font-weight:600;letter-spacing:0.3em;text-transform:uppercase;margin-bottom:28px;opacity:0;transform:scale(0.95);">
        남양주 에어컨 전문 시공팀
      </span>
      <!-- h1 -->
      <h1 id="hero-h1" style="font-size:clamp(60px,11vw,140px);font-weight:900;letter-spacing:-0.03em;line-height:1;color:white;margin-bottom:24px;opacity:0;transform:translateY(30px);">
        완벽한 설치<br/><span style="color:rgba(255,255,255,0.7);">디디에어컨</span>
      </h1>
      <!-- tagline -->
      <p id="hero-p" style="font-size:clamp(15px,2vw,20px);color:rgba(255,255,255,0.7);font-weight:300;letter-spacing:0.02em;margin-bottom:40px;opacity:0;transform:translateY(20px);">
        정확한 설계 · 깔끔한 배관 · 섬세한 마감
      </p>
      <!-- CTAs -->
      <div id="hero-cta" style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;opacity:0;transform:translateY(20px);">
        <a href={`${base}/contact`} class="btn-dark">상담신청 →</a>
        <a href={`${base}/cases`} class="btn-outline">시공사례 보기</a>
      </div>
    </div>

    <!-- scroll indicator -->
    <div id="scroll-indicator" style="position:absolute;bottom:40px;left:50%;transform:translateX(-50%);z-index:2;display:flex;flex-direction:column;align-items:center;gap:10px;opacity:0;">
      <span style="font-size:10px;letter-spacing:0.3em;color:rgba(255,255,255,0.4);text-transform:uppercase;">Scroll</span>
      <div style="width:1px;height:40px;background:linear-gradient(to bottom,rgba(255,255,255,0.4),transparent);animation:scrollPulse 2s ease-in-out infinite;"></div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       SECTION 2: BRAND STORY (2-col text + image)
  ══════════════════════════════════════════ -->
  <section style="padding:128px 48px;background:#ffffff;">
    <div class="section-container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;" class="brand-grid">
        <!-- text col -->
        <div class="reveal-left">
          <span class="section-label-sm">About DD에어컨</span>
          <h2 style="font-size:clamp(36px,5vw,64px);font-weight:900;letter-spacing:-0.03em;line-height:1.1;margin-bottom:32px;color:#09090b;">
            전문 기술팀<br/>직영 운영
          </h2>
          <p style="font-size:17px;color:#71717a;line-height:1.9;font-weight:300;margin-bottom:40px;">
            디디에어컨은 남양주·다산신도시를 기반으로 한 에어컨 전문 직영 시공팀입니다.
            천장형 4WAY 카세트부터 스탠드·벽걸이까지, 현장 진단부터 배관 정리·드레인 레벨링까지 원스톱으로 처리합니다.
          </p>
          <a href={`${base}/cases`} style="display:inline-flex;align-items:center;gap:8px;font-size:13px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#09090b;text-decoration:none;padding-bottom:4px;border-bottom:2px solid #09090b;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.5'" onmouseout="this.style.opacity='1'">
            시공사례 보기 →
          </a>
        </div>
        <!-- image col -->
        <div class="reveal-scale">
          <div class="card-image-wrap" style="aspect-ratio:4/5;border-radius:24px;">
            <img src={`${base}/images/bg/h1_bedroom_ac.jpg`} alt="에어컨 시공 현장" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       SECTION 3: SERVICES (3-col × 2-row product grid)
  ══════════════════════════════════════════ -->
  <section style="padding:128px 48px;background:#ffffff;border-top:1px solid #f4f4f5;">
    <div class="section-container">
      <!-- section header -->
      <div class="reveal" style="display:flex;flex-direction:row;justify-content:space-between;align-items:flex-end;margin-bottom:80px;gap:24px;flex-wrap:wrap;">
        <div>
          <h2 style="font-size:clamp(32px,4.5vw,56px);font-weight:900;letter-spacing:-0.03em;margin-bottom:8px;color:#09090b;">시공 서비스</h2>
          <p style="font-size:16px;color:#71717a;">전문 직영팀의 에어컨 설치·수리·관리</p>
        </div>
        <a href={`${base}/cases`} class="btn-outline-dark" style="white-space:nowrap;">전체보기 →</a>
      </div>

      <!-- row 1 -->
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;" class="services-grid">
        <!-- card 1 -->
        <div class="reveal service-card" style="cursor:default;">
          <div class="card-image-wrap" style="aspect-ratio:4/3;margin-bottom:20px;border-radius:16px;">
            <img src={`${base}/images/gallery/case01.jpg`} alt="천장형 4WAY 시스템에어컨 설치" loading="lazy" />
          </div>
          <span style="font-size:11px;font-weight:700;letter-spacing:0.25em;text-transform:uppercase;color:#a1a1aa;display:block;margin-bottom:8px;">System AC</span>
          <h3 style="font-size:20px;font-weight:700;letter-spacing:-0.02em;margin-bottom:8px;color:#09090b;">천장형 4WAY 설치</h3>
          <p style="font-size:14px;color:#71717a;line-height:1.7;">카세트형·덕트형 시스템에어컨 정밀 설계·시공. 배관 정리와 드레인 레벨링까지 완벽 처리.</p>
        </div>
        <!-- card 2 -->
        <div class="reveal service-card" style="cursor:default;">
          <div class="card-image-wrap" style="aspect-ratio:4/3;margin-bottom:20px;border-radius:16px;">
            <img src={`${base}/images/gallery/case02.jpg`} alt="에어컨 수리 이전설치" loading="lazy" />
          </div>
          <span style="font-size:11px;font-weight:700;letter-spacing:0.25em;text-transform:uppercase;color:#a1a1aa;display:block;margin-bottom:8px;">Repair · Relocation</span>
          <h3 style="font-size:20px;font-weight:700;letter-spacing:-0.02em;margin-bottom:8px;color:#09090b;">수리·이전설치</h3>
          <p style="font-size:14px;color:#71717a;line-height:1.7;">냉매충전, 소음·누수 정밀 진단, 이전설치 시 배관 재정리까지. 100% AS 보장.</p>
        </div>
        <!-- card 3 (한전 지원사업) -->
        <div class="reveal service-card" style="cursor:default;">
          <div class="card-image-wrap" style="aspect-ratio:4/3;margin-bottom:20px;border-radius:16px;">
            <img src={`${base}/images/bg/h1.jpg`} alt="한전 고효율기기 지원사업" loading="lazy" />
            <div style="position:absolute;top:12px;left:12px;padding:4px 10px;background:#09090b;color:white;font-size:10px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;border-radius:4px;">지원금 160만원</div>
          </div>
          <span style="font-size:11px;font-weight:700;letter-spacing:0.25em;text-transform:uppercase;color:#2563eb;display:block;margin-bottom:8px;">KEPCO 2026</span>
          <h3 style="font-size:20px;font-weight:700;letter-spacing:-0.02em;margin-bottom:8px;color:#09090b;">한전 지원사업</h3>
          <p style="font-size:14px;color:#71717a;line-height:1.7;">1등급 에어컨 설치 시 구매가의 40% 현금 환급. 최대 160만원 지원.</p>
        </div>
      </div>

      <!-- row 2 -->
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:24px;" class="services-grid">
        <div class="reveal service-card" style="cursor:default;">
          <div class="card-image-wrap" style="aspect-ratio:4/3;margin-bottom:20px;border-radius:16px;">
            <img src={`${base}/images/gallery/case05.jpg`} alt="당일 출장 서비스" loading="lazy" />
          </div>
          <span style="font-size:11px;font-weight:700;letter-spacing:0.25em;text-transform:uppercase;color:#a1a1aa;display:block;margin-bottom:8px;">Same Day</span>
          <h3 style="font-size:20px;font-weight:700;letter-spacing:-0.02em;margin-bottom:8px;color:#09090b;">당일 출장</h3>
          <p style="font-size:14px;color:#71717a;line-height:1.7;">남양주·구리·하남·의정부 등 경기 전역 당일 출장. 전화 한 통으로 즉시 연결.</p>
        </div>
        <div class="reveal service-card" style="cursor:default;">
          <div class="card-image-wrap" style="aspect-ratio:4/3;margin-bottom:20px;border-radius:16px;">
            <img src={`${base}/images/gallery/case03.jpg`} alt="스탠드 벽걸이 에어컨 설치" loading="lazy" />
          </div>
          <span style="font-size:11px;font-weight:700;letter-spacing:0.25em;text-transform:uppercase;color:#a1a1aa;display:block;margin-bottom:8px;">Wall · Floor</span>
          <h3 style="font-size:20px;font-weight:700;letter-spacing:-0.02em;margin-bottom:8px;color:#09090b;">스탠드·벽걸이</h3>
          <p style="font-size:14px;color:#71717a;line-height:1.7;">가정용 스탠드형·벽걸이형 에어컨 설치. 배관 정리와 전기 작업 포함.</p>
        </div>
        <div class="reveal service-card" style="cursor:default;">
          <div class="card-image-wrap" style="aspect-ratio:4/3;margin-bottom:20px;border-radius:16px;">
            <img src={`${base}/images/gallery/case06.jpg`} alt="가스충전 에어컨 청소" loading="lazy" />
          </div>
          <span style="font-size:11px;font-weight:700;letter-spacing:0.25em;text-transform:uppercase;color:#a1a1aa;display:block;margin-bottom:8px;">Maintenance</span>
          <h3 style="font-size:20px;font-weight:700;letter-spacing:-0.02em;margin-bottom:8px;color:#09090b;">가스충전·청소</h3>
          <p style="font-size:14px;color:#71717a;line-height:1.7;">냉매 부족 진단 및 충전. 에어컨 실내기·실외기 전문 청소 서비스.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       SECTION 4: CASES / JOURNAL (3-col grid)
  ══════════════════════════════════════════ -->
  <section style="padding:128px 48px;background:#fafafa;border-top:1px solid #f4f4f5;">
    <div class="section-container">
      <div class="reveal" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:64px;flex-wrap:wrap;gap:16px;">
        <div>
          <span class="section-label-sm">Installation Cases</span>
          <h2 style="font-size:clamp(32px,4.5vw,56px);font-weight:900;letter-spacing:-0.03em;color:#09090b;">시공사례</h2>
        </div>
        <a href={`${base}/cases`} style="font-size:13px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#09090b;text-decoration:none;display:flex;align-items:center;gap:8px;opacity:0.6;transition:opacity 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">
          전체보기 →
        </a>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap-x:32px;gap-y:64px;" class="cases-grid">
        <!-- case 1 -->
        <div class="reveal" style="display:flex;flex-direction:column;gap:20px;cursor:pointer;" onclick={`location.href='${base}/cases'`}>
          <div class="card-image-wrap" style="aspect-ratio:4/3;border-radius:16px;">
            <img src={`${base}/images/gallery/case02.jpg`} alt="셀렉샵 4WAY 설치" loading="lazy" />
          </div>
          <div>
            <p style="font-size:11px;font-weight:700;letter-spacing:0.25em;text-transform:uppercase;color:#a1a1aa;margin-bottom:8px;">Commercial</p>
            <h3 style="font-size:20px;font-weight:700;letter-spacing:-0.02em;margin-bottom:8px;color:#09090b;transition:color 0.2s;">셀렉샵 4WAY 설치</h3>
            <p style="font-size:14px;color:#71717a;line-height:1.7;">성수 셀렉샵 천장형 카세트 에어컨. 개업 일정에 맞춰 당일 시공 완료.</p>
          </div>
        </div>
        <!-- case 2 -->
        <div class="reveal" style="display:flex;flex-direction:column;gap:20px;cursor:pointer;" onclick={`location.href='${base}/cases'`}>
          <div class="card-image-wrap" style="aspect-ratio:4/3;border-radius:16px;">
            <img src={`${base}/images/gallery/case05.jpg`} alt="치과 4WAY 설치" loading="lazy" />
          </div>
          <div>
            <p style="font-size:11px;font-weight:700;letter-spacing:0.25em;text-transform:uppercase;color:#a1a1aa;margin-bottom:8px;">Medical</p>
            <h3 style="font-size:20px;font-weight:700;letter-spacing:-0.02em;margin-bottom:8px;color:#09090b;">치과 4WAY 설치</h3>
            <p style="font-size:14px;color:#71717a;line-height:1.7;">강변 치과·피부과 시스템에어컨. 진료 환경을 고려한 소음 최소화 시공.</p>
          </div>
        </div>
        <!-- case 3 -->
        <div class="reveal" style="display:flex;flex-direction:column;gap:20px;cursor:pointer;" onclick={`location.href='${base}/cases'`}>
          <div class="card-image-wrap" style="aspect-ratio:4/3;border-radius:16px;">
            <img src={`${base}/images/gallery/case04.jpg`} alt="카페 이전설치" loading="lazy" />
          </div>
          <div>
            <p style="font-size:11px;font-weight:700;letter-spacing:0.25em;text-transform:uppercase;color:#a1a1aa;margin-bottom:8px;">Relocation</p>
            <h3 style="font-size:20px;font-weight:700;letter-spacing:-0.02em;margin-bottom:8px;color:#09090b;">카페 이전설치</h3>
            <p style="font-size:14px;color:#71717a;line-height:1.7;">수원 인계동 카페 이전설치. 배관 재정리·냉매충전 포함 하루 완료.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       SECTION 5: STATS + SERVICE AREA (dark — NOVA Experience Centers)
  ══════════════════════════════════════════ -->
  <section style="padding:128px 48px;background:#09090b;color:white;">
    <div class="section-container">
      <h2 class="reveal" style="font-size:clamp(32px,5vw,64px);font-weight:900;letter-spacing:-0.03em;color:white;margin-bottom:80px;">
        서비스 권역 &amp; 실적
      </h2>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start;" class="stats-area-grid">
        <!-- left: location list -->
        <div>
          <div class="stat-row reveal">
            <div>
              <p style="font-size:18px;font-weight:700;color:white;margin-bottom:4px;">남양주 · 다산신도시</p>
              <p style="font-size:13px;color:rgba(255,255,255,0.4);">주요 서비스 권역</p>
            </div>
            <span style="font-size:13px;font-weight:600;letter-spacing:0.1em;color:rgba(255,255,255,0.3);">MAIN</span>
          </div>
          <div class="stat-row reveal">
            <div>
              <p style="font-size:18px;font-weight:700;color:white;margin-bottom:4px;">구리 · 하남 · 의정부</p>
              <p style="font-size:13px;color:rgba(255,255,255,0.4);">당일 출장 가능</p>
            </div>
            <span style="font-size:13px;font-weight:600;letter-spacing:0.1em;color:rgba(255,255,255,0.3);">SAME DAY</span>
          </div>
          <div class="stat-row reveal">
            <div>
              <p style="font-size:18px;font-weight:700;color:white;margin-bottom:4px;">서울 전역 · 경기 전역</p>
              <p style="font-size:13px;color:rgba(255,255,255,0.4);">예약 상담 후 방문</p>
            </div>
            <span style="font-size:13px;font-weight:600;letter-spacing:0.1em;color:rgba(255,255,255,0.3);">BY APPT</span>
          </div>
          <div class="stat-row reveal" style="border-bottom:none;">
            <div>
              <p style="font-size:18px;font-weight:700;color:white;margin-bottom:4px;">전화 한 통으로 즉시 연결</p>
              <p style="font-size:13px;color:rgba(255,255,255,0.4);">010-7237-2122</p>
            </div>
            <a href="tel:010-7237-2122" style="font-size:13px;font-weight:600;letter-spacing:0.1em;color:#93c5fd;text-decoration:none;">전화하기 →</a>
          </div>
        </div>
        <!-- right: big numbers -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1px;background:rgba(255,255,255,0.08);">
          <div style="padding:40px;background:#09090b;text-align:center;" class="reveal">
            <span style="display:block;font-size:clamp(48px,6vw,80px);font-weight:900;letter-spacing:-0.04em;color:white;line-height:1;">70<span style="font-size:0.5em;font-weight:300;">+</span></span>
            <span style="font-size:11px;font-weight:600;letter-spacing:0.3em;text-transform:uppercase;color:rgba(255,255,255,0.4);margin-top:8px;display:block;">시공 실적</span>
          </div>
          <div style="padding:40px;background:#09090b;text-align:center;" class="reveal">
            <span style="display:block;font-size:clamp(48px,6vw,80px);font-weight:900;letter-spacing:-0.04em;color:white;line-height:1;">5<span style="font-size:0.5em;font-weight:300;">년+</span></span>
            <span style="font-size:11px;font-weight:600;letter-spacing:0.3em;text-transform:uppercase;color:rgba(255,255,255,0.4);margin-top:8px;display:block;">현장 경력</span>
          </div>
          <div style="padding:40px;background:#09090b;text-align:center;" class="reveal">
            <span style="display:block;font-size:clamp(48px,6vw,80px);font-weight:900;letter-spacing:-0.04em;color:white;line-height:1;">100<span style="font-size:0.5em;font-weight:300;">%</span></span>
            <span style="font-size:11px;font-weight:600;letter-spacing:0.3em;text-transform:uppercase;color:rgba(255,255,255,0.4);margin-top:8px;display:block;">AS 보장</span>
          </div>
          <div style="padding:40px;background:#09090b;text-align:center;" class="reveal">
            <span style="display:block;font-size:clamp(48px,6vw,80px);font-weight:900;letter-spacing:-0.04em;color:white;line-height:1;">1<span style="font-size:0.5em;font-weight:300;">일</span></span>
            <span style="font-size:11px;font-weight:600;letter-spacing:0.3em;text-transform:uppercase;color:rgba(255,255,255,0.4);margin-top:8px;display:block;">당일 출장</span>
          </div>
        </div>
