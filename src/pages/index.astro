---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const title = '디디에어컨 | 남양주 에어컨 설치·판매·수리 전문';
const description = '남양주·다산신도시 에어컨 전문 설치 업체. 천장형 4WAY·스탠드·벽걸이 설치, 에어컨 수리·이전. 당일 출장 가능. 70건+ 시공 실적.';

const storyPanels = [
  {
    bg: `${base}/images/bg/h1.jpg`,
    eyebrow: '남양주 시스템에어컨 전문 시공팀 · 자체 기술팀 직영',
    title: '디디',
    titleSub: '에어컨',
    titleItalic: true,
    desc: '정확한 설계 · 깔끔한 배관 · 섬세한 마감',
    isHero: true,
  },
  {
    bg: `${base}/images/bg/h1_cand1.jpg`,
    eyebrow: 'System AC Installation',
    title: '시스템에어컨\n직영 시공',
    desc: '천장형 4WAY·스탠드·벽걸이 전 기종 설치. LG·삼성·캐리어·위니아 전 브랜드 취급. 자체 기술팀 직영시공으로 책임 시공을 보장합니다.',
    stat: '70+',
    statLabel: '시공 실적',
  },
  {
    bg: `${base}/images/bg/h2.jpg`,
    eyebrow: 'Repair · Relocation · Gas Charge',
    title: '수리·\n이전설치',
    desc: '냉매충전, 부품 교체, 소음·누수 원인 정밀 진단. 이전설치 시 배관 재정리·드레인 레벨링까지 원스톱 처리.',
    stat: '100%',
    statLabel: 'AS 보장',
  },
  {
    bg: `${base}/images/bg/h1_bedroom_ac.jpg`,
    eyebrow: 'Same-Day Field Service',
    title: '당일\n출장 가능',
    desc: '남양주·구리·하남·의정부·수원·용인 등 경기 전역. 전화 한 통으로 당일 연결. 이전설치·배관 정리·냉매 충전 현장 즉시 처리.',
    stat: '1일',
    statLabel: '당일 출장',
  },
];

const galleryItems = [
  { src: `${base}/images/gallery/case01.jpg`, label: '요양병원 벽걸이 설치' },
  { src: `${base}/images/gallery/case02.jpg`, label: '셀렉샵 4WAY 설치' },
  { src: `${base}/images/gallery/case03.jpg`, label: '네일샵 4WAY 설치' },
  { src: `${base}/images/gallery/case04.jpg`, label: '마포 4WAY 설치' },
  { src: `${base}/images/gallery/case05.jpg`, label: '치과 4WAY 설치' },
  { src: `${base}/images/gallery/case06.jpg`, label: '헤어샵 4WAY 설치' },
  { src: `${base}/images/gallery/case07.jpg`, label: '관리실 스탠드 설치' },
  { src: `${base}/images/gallery/case08.jpg`, label: '사무실 벽걸이 설치' },
];

const reviews = [
  {
    text: '천장형 4WAY 설치인데 배관 정리랑 마감이 정말 깔끔했어요. 개업 전 일정에 맞춰 당일 완료해 주셔서 감사합니다.',
    name: '성수 셀렉샵 사장님',
    date: '2026년 2월 시공',
    img: `${base}/images/gallery/case02.jpg`,
  },
  {
    text: '치과 특성상 환자 환경이 중요한데, 현장 진단부터 시공까지 전문적으로 처리해 주셨어요. 소음도 없고 마감도 완벽합니다.',
    name: '강변 치과·피부과',
    date: '2026년 2월 시공',
    img: `${base}/images/gallery/case05.jpg`,
  },
  {
    text: '이전설치라 걱정했는데 배관 재정리부터 냉매 충전까지 하루 만에 깔끔하게 끝냈습니다. 역시 전문 시공팀이네요.',
    name: '수원 인계동 카페',
    date: '2026년 1월 시공',
    img: `${base}/images/gallery/case04.jpg`,
  },
];

const stats = [
  { num: 70,  suffix: '+',  label: '시공 실적' },
  { num: 5,   suffix: '년+', label: '현장 경력' },
  { num: 100, suffix: '%',  label: 'AS 보장'   },
  { num: 1,   suffix: '일', label: '당일 출장'  },
];
---
<Layout title={title} description={description}>

<!-- ══════ 파티클 캔버스 ══════════════════════════════════════════════════ -->
<canvas id="particle-canvas" style="position:fixed;inset:0;z-index:1;pointer-events:none;opacity:0.5;"></canvas>

<!-- ══════ 스크롤 스토리텔링 배경 (데스크탑) ════════════════════════════ -->
<div id="story-fixed-bg" style="position:fixed;inset:0;z-index:0;pointer-events:none;display:none;">
  <!-- 히어로 패널 0: 비디오 프레임 캔버스 -->
  <canvas
    id="hero-canvas"
    class="story-bg-slide"
    data-index="0"
    style="position:absolute;inset:0;width:100%;height:100%;opacity:1;transition:opacity 1s ease;"
  ></canvas>
  <!-- 패널 1–3: 일반 배경 이미지 -->
  {storyPanels.slice(1).map((panel, i) => (
    <div
      class="story-bg-slide"
      data-index={i + 1}
      style={`position:absolute;inset:0;background-image:url('${panel.bg}');background-size:cover;background-position:center top;opacity:0;transition:opacity 1s ease;`}
    ></div>
  ))}
  <!-- 다층 오버레이 -->
  <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(5,9,15,0.45) 0%,rgba(5,9,15,0.05) 40%,rgba(5,9,15,0.05) 60%,rgba(5,9,15,0.9) 100%);"></div>
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at center,transparent 40%,rgba(5,9,15,0.5) 100%);"></div>
</div>

<!-- ══════ 스크롤 스토리텔링 섹션들 ══════════════════════════════════════ -->
<div id="story-container">

  <!-- 패널 0: 히어로 -->
  {storyPanels.slice(0, 1).map((panel, i) => (
    <section
      class="story-panel"
      data-index={i}
      style={`position:relative;height:100dvh;min-height:600px;display:flex;flex-direction:column;justify-content:flex-end;padding:0 8vw 12vh;z-index:2;`}
    >
      <!-- 모바일용 배경 -->
      <div class="mobile-bg" style={`display:none;position:absolute;inset:0;background-image:url('${panel.bg}');background-size:cover;background-position:center top;z-index:0;`}></div>
      <div class="mobile-bg" style="display:none;position:absolute;inset:0;background:linear-gradient(to bottom,rgba(5,9,15,0.35) 0%,rgba(5,9,15,0.0) 35%,rgba(5,9,15,0.75) 85%,rgba(5,9,15,0.92) 100%);z-index:1;"></div>

      <!-- 콘텐츠 -->
      <div class={`story-content${i===0?' hero-content':''}`} style="position:relative;z-index:3;max-width:750px;">
        {i === 0 ? (
          <>
            <!-- 아이브로우 라인 -->
            <div id="hero-eyebrow" style="display:flex;align-items:center;gap:16px;margin-bottom:28px;overflow:hidden;">
              <span id="eyebrow-line" style="display:block;height:1px;width:0;background:linear-gradient(90deg,transparent,rgba(79,195,247,0.6));transition:width 1.2s ease 0.5s;"></span>
              <span style="font-size:10px;letter-spacing:0.55em;text-transform:uppercase;color:rgba(255,255,255,0.45);opacity:0;transition:opacity 0.8s ease 0.9s;" id="eyebrow-text">{panel.eyebrow}</span>
            </div>
            <!-- 히어로 타이틀 -->
            <h1 id="hero-title" style="font-size:clamp(72px,13vw,160px);line-height:0.9;letter-spacing:-0.01em;margin-bottom:30px;">
              <div style="overflow:hidden;display:block;">
                <span class="title-slide-up font-impact" style="display:block;animation-delay:0.4s;color:white;">{panel.title}</span>
              </div>
              <div style="overflow:hidden;display:block;">
                <span class="title-slide-up font-impact blue-gradient" style="display:block;animation-delay:0.65s;">{panel.titleSub}</span>
              </div>
            </h1>
            <!-- 서브타이틀 -->
            <p id="hero-sub" style="font-size:clamp(14px,1.8vw,19px);color:rgba(255,255,255,0.58);font-weight:300;letter-spacing:0.08em;margin-bottom:40px;opacity:0;transform:translateY(16px);">
              {panel.desc}
            </p>
            <!-- CTA 버튼 -->
            <div id="hero-cta" style="display:flex;gap:14px;flex-wrap:wrap;opacity:0;transform:translateY(16px);">
              <a href={`${base}/contact`} class="btn-primary magnetic">서비스 신청하기</a>
              <a href={`${base}/cases`} class="btn-outline magnetic">시공사례 보기</a>
            </div>
          </>
        ) : (
          <>
            <p style="font-size:10px;letter-spacing:0.5em;text-transform:uppercase;color:rgba(79,195,247,0.75);margin-bottom:16px;">{panel.eyebrow}</p>
            <div style="display:flex;align-items:flex-end;gap:28px;margin-bottom:20px;flex-wrap:wrap;">
              <h2 class="font-display" style="font-size:clamp(44px,8vw,100px);font-weight:300;color:white;line-height:0.92;letter-spacing:0.02em;white-space:pre-line;">{panel.title}</h2>
              {panel.stat && (
                <div style="padding-bottom:8px;">
                  <span class="font-display" style="font-size:clamp(36px,5vw,60px);font-weight:300;background:linear-gradient(90deg,#4FC3F7,#81D4FA);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;display:block;">{panel.stat}</span>
                  <p style="font-size:9px;letter-spacing:0.45em;text-transform:uppercase;color:rgba(255,255,255,0.35);margin-top:5px;">{panel.statLabel}</p>
                </div>
              )}
            </div>
            <p style="font-size:clamp(14px,1.6vw,17px);color:rgba(255,255,255,0.55);font-weight:300;max-width:480px;line-height:1.75;">{panel.desc}</p>
          </>
        )}
      </div>

      <!-- 패널 번호 -->
      <div style="position:absolute;bottom:40px;right:8vw;z-index:3;text-align:right;">
        <p style="font-family:'Cormorant Garamond',serif;font-size:11px;color:rgba(255,255,255,0.25);letter-spacing:0.2em;">{String(i+1).padStart(2,'0')} / {String(storyPanels.length).padStart(2,'0')}</p>
      </div>

      <!-- 첫 패널 스크롤 유도 -->
      {i === 0 && (
        <div id="scroll-arrow" style="position:absolute;bottom:40px;left:50%;transform:translateX(-50%);z-index:3;display:flex;flex-direction:column;align-items:center;gap:8px;">
          <span style="font-size:11px;letter-spacing:0.2em;color:rgba(255,255,255,0.45);font-family:'Pretendard Variable',sans-serif;">아래로 내려보세요</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(79,195,247,0.7)" stroke-width="1.5" style="animation:bounce 1.8s ease-in-out infinite;"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
        </div>
      )}
    </section>
  ))}

  <!-- ══ 지원사업 배너 패널 (히어로 바로 뒤, 전체화면 덮기) ══ -->
  <section
    id="subsidy-panel"
    style="position:relative;padding:56px 8vw;display:flex;flex-direction:column;justify-content:center;align-items:center;z-index:2;overflow:hidden;text-align:center;"
  >
    <!-- 불투명 파란 배경 — 뒤의 fixed bg 이미지를 완전히 덮음 -->
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,#0D47A1 0%,#1565C0 45%,#1E88E5 100%);"></div>
    <!-- 미묘한 격자 오버레이 -->
    <div style="position:absolute;inset:0;opacity:0.04;background-image:repeating-linear-gradient(0deg,transparent,transparent 60px,rgba(255,255,255,0.5) 60px,rgba(255,255,255,0.5) 61px),repeating-linear-gradient(90deg,transparent,transparent 60px,rgba(255,255,255,0.5) 60px,rgba(255,255,255,0.5) 61px);"></div>
    <!-- 장식 원 -->
    <div style="position:absolute;top:-120px;left:-120px;width:400px;height:400px;border-radius:50%;background:rgba(255,255,255,0.04);pointer-events:none;"></div>
    <div style="position:absolute;bottom:-160px;right:-160px;width:500px;height:500px;border-radius:50%;background:rgba(255,255,255,0.03);pointer-events:none;"></div>
    <!-- 상단 라인 -->
    <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.15),transparent);"></div>

    <!-- 콘텐츠 (중앙 정렬) -->
    <div style="max-width:800px;padding:0;position:relative;z-index:1;width:100%;text-align:center;">
      <p id="sub-eyebrow" style="font-size:10px;letter-spacing:0.55em;text-transform:uppercase;color:rgba(255,255,255,0.45);margin-bottom:16px;opacity:0;transform:translateY(16px);">2026 KEPCO Support Program</p>

      <!-- 타이틀 -->
      <h2 id="sub-title" class="font-impact" style="font-size:clamp(32px,5.5vw,64px);color:white;line-height:1.1;letter-spacing:0.02em;margin-bottom:16px;opacity:0;transform:translateY(32px);">
        한전 고효율기기 지원사업
      </h2>

      <!-- 구분선 -->
      <div id="sub-line" style="width:0;height:1px;background:rgba(255,255,255,0.3);margin:0 auto 20px;"></div>

      <!-- 설명 + 예산 가로 카드 -->
      <div style="display:flex;gap:20px;align-items:stretch;justify-content:center;flex-wrap:wrap;margin-bottom:28px;">
        <!-- 설명 텍스트 -->
        <p id="sub-desc" style="font-size:clamp(14px,1.6vw,17px);color:rgba(255,255,255,0.75);font-weight:300;line-height:1.9;opacity:0;transform:translateY(20px);text-align:left;flex:1;min-width:200px;max-width:340px;">
          1등급 에어컨 설치 시 구매가의<br/>
          <strong style="color:#81D4FA;font-weight:600;">40% 현금 환급</strong> · <strong style="color:white;font-weight:600;">최대 160만원</strong>
        </p>
        <!-- 예산 현황 박스 -->
        <div id="budget-box" style="flex:0 0 auto;min-width:200px;max-width:280px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.2);border-radius:4px;padding:18px 22px;opacity:0;transform:translateY(20px);text-align:left;">
          <p style="font-size:9px;letter-spacing:0.4em;text-transform:uppercase;color:rgba(255,255,255,0.5);margin-bottom:10px;">예산 현황 · 실시간</p>
          <div id="budget-loading" style="font-size:12px;color:rgba(255,255,255,0.4);">불러오는 중...</div>
          <div id="budget-data" style="display:none;">
            <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:8px;">
              <span style="font-size:11px;color:rgba(255,255,255,0.6);">잔여예산</span>
              <span id="budget-remaining" style="font-size:26px;font-family:'Cormorant Garamond',serif;font-weight:600;color:#81D4FA;line-height:1;">—%</span>
            </div>
            <div style="height:4px;background:rgba(255,255,255,0.15);border-radius:2px;overflow:hidden;margin-bottom:7px;">
              <div id="budget-bar" style="height:100%;background:linear-gradient(90deg,#81D4FA,#4FC3F7);border-radius:2px;width:0%;transition:width 1.2s ease;"></div>
            </div>
            <div style="display:flex;justify-content:space-between;">
              <span style="font-size:10px;color:rgba(255,255,255,0.4);">소진 <span id="budget-used">—</span>%</span>
              <span id="budget-updated" style="font-size:9px;color:rgba(255,255,255,0.3);">—</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 버튼 -->
      <div id="sub-btns" style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;opacity:0;transform:translateY(20px);">
        <a href={`${base}/contact`}
           style="display:inline-block;background:white;color:#1E88E5;padding:13px 36px;font-size:11px;letter-spacing:0.25em;text-transform:uppercase;text-decoration:none;font-family:inherit;transition:opacity 0.3s;"
           onmouseover="this.style.opacity='0.88'" onmouseout="this.style.opacity='1'">지원금 신청하기</a>
        <a href={`${base}/subsidy`}
           style="display:inline-block;border:1px solid rgba(255,255,255,0.45);color:white;padding:13px 36px;font-size:11px;letter-spacing:0.25em;text-transform:uppercase;text-decoration:none;transition:all 0.3s;"
           onmouseover="this.style.background='rgba(255,255,255,0.1)'" onmouseout="this.style.background='transparent'">지원사업 안내</a>
      </div>
    </div>

  </section>

  <!-- 패널 1–3: 나머지 스토리 패널 -->
  {storyPanels.slice(1).map((panel, i) => (
    <section
      class="story-panel"
      data-index={i + 1}
      style={`position:relative;height:100dvh;min-height:600px;display:flex;flex-direction:column;justify-content:flex-end;padding:0 8vw 12vh;z-index:2;`}
    >
      <div class="mobile-bg" style={`display:none;position:absolute;inset:0;background-image:url('${panel.bg}');background-size:cover;background-position:center top;z-index:0;`}></div>
      <div class="mobile-bg" style="display:none;position:absolute;inset:0;background:linear-gradient(to bottom,rgba(5,9,15,0.35) 0%,rgba(5,9,15,0.0) 35%,rgba(5,9,15,0.75) 85%,rgba(5,9,15,0.92) 100%);z-index:1;"></div>
      <div class="story-content" style="position:relative;z-index:3;max-width:750px;">
        <p style="font-size:10px;letter-spacing:0.5em;text-transform:uppercase;color:rgba(79,195,247,0.75);margin-bottom:16px;">{panel.eyebrow}</p>
        <div style="display:flex;align-items:flex-end;gap:28px;margin-bottom:20px;flex-wrap:wrap;">
          <h2 class="font-display" style="font-size:clamp(44px,8vw,100px);font-weight:300;color:white;line-height:0.92;letter-spacing:0.02em;white-space:pre-line;">{panel.title}</h2>
          {panel.stat && (
            <div style="padding-bottom:8px;">
              <span class="font-display" style="font-size:clamp(36px,5vw,60px);font-weight:300;background:linear-gradient(90deg,#4FC3F7,#81D4FA);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;display:block;">{panel.stat}</span>
              <p style="font-size:9px;letter-spacing:0.45em;text-transform:uppercase;color:rgba(255,255,255,0.35);margin-top:5px;">{panel.statLabel}</p>
            </div>
          )}
        </div>
        <p style="font-size:clamp(14px,1.6vw,17px);color:rgba(255,255,255,0.55);font-weight:300;max-width:480px;line-height:1.75;">{panel.desc}</p>
      </div>
      <div style="position:absolute;bottom:40px;right:8vw;z-index:3;text-align:right;">
        <p style="font-family:'Cormorant Garamond',serif;font-size:11px;color:rgba(255,255,255,0.25);letter-spacing:0.2em;">{String(i+2).padStart(2,'0')} / {String(storyPanels.length).padStart(2,'0')}</p>
      </div>
    </section>
  ))}

</div>

<!-- ══════ STATS 섹션 ══════════════════════════════════════════════════════ -->
<section id="stats-section" style="background:var(--dark);position:relative;z-index:2;overflow:hidden;">
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:600px;height:300px;background:radial-gradient(ellipse,rgba(79,195,247,0.05) 0%,transparent 70%);pointer-events:none;"></div>
  <div style="max-width:900px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);position:relative;">
    {stats.map((s) => (
      <div class="stat-item">
        <span class="stat-num counter-num" data-target={s.num} data-suffix={s.suffix}>0{s.suffix}</span>
        <span class="stat-label">{s.label}</span>
      </div>
    ))}
  </div>
  <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(79,195,247,0.15),transparent);"></div>
