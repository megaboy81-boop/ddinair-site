    <a href="tel:010-7237-2122" class="btn-primary magnetic" style="font-size:13px;padding:18px 48px;letter-spacing:0.2em;">
      010-7237-2122 전화하기
    </a>
    <a href={`${base}/contact`} class="btn-blue magnetic">온라인 신청</a>
  </div>
