<script>
  window.addEventListener('load', () => {
    const gsap = (window as any).gsap;
    const ScrollTrigger = (window as any).ScrollTrigger;
    const LenisLib = (window as any).Lenis;
    if (!gsap || !ScrollTrigger) return;
    gsap.registerPlugin(ScrollTrigger);

    // Lenis 초기화
    if ((window as any).__lenis) {
      try { (window as any).__lenis.destroy(); } catch(_) {}
    }
    if (LenisLib) {
      const lenis = new LenisLib({ lerp: 0.08, smoothWheel: true });
      (window as any).__lenis = lenis;
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((t: number) => { lenis.raf(t * 1000); });
      gsap.ticker.lagSmoothing(0);
    }

    // ── 히어로 진입 애니메이션 ──
    const badge = document.getElementById('hero-badge');
    const h1    = document.getElementById('hero-h1');
    const heroP = document.getElementById('hero-p');
    const cta   = document.getElementById('hero-cta');
    const ind   = document.getElementById('scroll-indicator');

    if (badge) gsap.to(badge, { opacity:1, scale:1, duration:1.1, delay:0.25, ease:'power3.out' });
    if (h1)    gsap.to(h1,    { opacity:1, y:0,     duration:1.1, delay:0.45, ease:'power3.out' });
    if (heroP) gsap.to(heroP, { opacity:1, y:0,     duration:1.0, delay:0.65, ease:'power3.out' });
    if (cta)   gsap.to(cta,   { opacity:1, y:0,     duration:1.0, delay:0.85, ease:'power3.out' });
    if (ind)   gsap.to(ind,   { opacity:1,           duration:1.0, delay:1.6,  ease:'power2.out' });

    // ── 히어로 콘텐츠 패럴랙스 + 3D 회전 ──
    const heroContent = document.getElementById('hero-content');
    if (heroContent) {
      heroContent.style.transformOrigin = 'center bottom';
      heroContent.style.willChange = 'transform';
      gsap.to(heroContent, {
        y: -80,
        rotateX: 12,
        scale: 0.93,
        ease: 'none',
        scrollTrigger: { trigger: '#hero', start: 'top top', end: '60% top', scrub: 0.8 }
      });
    }
    // 히어로 배경 이미지/캔버스 살짝 확대
    const heroBg = document.getElementById('hero-bg-img');
    if (heroBg) {
      gsap.to(heroBg, {
        scale: 1.08, ease: 'none',
        scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: true }
      });
    }
    // 지원사업 배너 스크롤 시 페이드아웃
    const subsidyBanner = document.getElementById('subsidy-banner');
    if (subsidyBanner) {
      gsap.to(subsidyBanner, {
        opacity: 0, y: 10, ease: 'none',
        scrollTrigger: { trigger: '#hero', start: '30% top', end: '70% top', scrub: true }
      });
    }

    // ── 스크롤 reveal 애니메이션 ──
    document.querySelectorAll<HTMLElement>('.reveal').forEach(el => {
      gsap.fromTo(el, { opacity:0, y:28 }, {
        opacity:1, y:0, duration:0.85, ease:'power2.out',
        scrollTrigger: { trigger: el, start:'top 89%', toggleActions:'play none none none' }
      });
    });
    document.querySelectorAll<HTMLElement>('.reveal-left').forEach(el => {
      gsap.fromTo(el, { opacity:0, x:-44 }, {
        opacity:1, x:0, duration:1.05, ease:'power2.out',
        scrollTrigger: { trigger: el, start:'top 86%', toggleActions:'play none none none' }
      });
    });
    document.querySelectorAll<HTMLElement>('.reveal-scale').forEach(el => {
      gsap.fromTo(el, { opacity:0, scale:0.94 }, {
        opacity:1, scale:1, duration:1.05, ease:'power2.out',
        scrollTrigger: { trigger: el, start:'top 86%', toggleActions:'play none none none' }
      });
    });

    // ── WebP 캔버스 스크롤 애니메이션 ──
    const heroCanvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
    const heroBgImg  = document.getElementById('hero-bg-img') as HTMLImageElement | null;

    if (heroCanvas) {
      const ctx = heroCanvas.getContext('2d')!;
      const FRAME_COUNT = 100;
      const siteBase = document.querySelector('meta[name="site-base"]')?.getAttribute('content') || '';
      const frames: HTMLImageElement[] = new Array(FRAME_COUNT);
      let currentFrame = 0;
      let canvasReady = false;

      function resizeCanvas() {
        if (!heroCanvas) return;
        heroCanvas.width  = window.innerWidth;
        heroCanvas.height = window.innerHeight;
        drawFrame(currentFrame);
      }

      function drawFrame(idx: number) {
        if (!heroCanvas) return;
        const img = frames[idx];
        if (!img?.complete || !img.naturalWidth) return;
        const W = heroCanvas.width, H = heroCanvas.height;
        const scale = Math.max(W / img.naturalWidth, H / img.naturalHeight);
        const x = (W - img.naturalWidth * scale) / 2;
        const y = (H - img.naturalHeight * scale) / 2;
        ctx.clearRect(0, 0, W, H);
        ctx.drawImage(img, x, y, img.naturalWidth * scale, img.naturalHeight * scale);
        if (!canvasReady) {
          canvasReady = true;
          heroCanvas.style.opacity = '1';
          // 캔버스 준비되면 fallback 이미지 숨김
          if (heroBgImg) heroBgImg.style.opacity = '0';
        }
      }

      resizeCanvas();
      window.addEventListener('resize', resizeCanvas);

      // 프레임 프리로드 (첫 프레임 우선)
      for (let i = 0; i < FRAME_COUNT; i++) {
        const img = new Image();
        img.src = `${siteBase}/images/hero-frames/frame_${String(i + 1).padStart(3, '0')}.webp`;
        img.onload = () => { if (i === 0) resizeCanvas(); };
        frames[i] = img;
      }

      // GSAP scrub — 히어로 섹션 스크롤 시 프레임 진행
      const scrubObj = { frame: 0 };
      gsap.to(scrubObj, {
        frame: FRAME_COUNT - 1,
        ease: 'none',
        scrollTrigger: {
          trigger: '#hero',
          start: 'top top',
          end: 'bottom top',
          scrub: 0.6,
        },
        onUpdate() {
          const f = Math.round(scrubObj.frame);
          if (f !== currentFrame) { currentFrame = f; drawFrame(f); }
        },
      });
    }

    // ── 히어로 배너 소진율 ──
    (function() {
      var MILESTONES = [[0,0],[20,8],[51,22],[81,40],[112,60],[142,77],[173,89],[204,96],[235,99]];
      var start = new Date('2026-02-09T00:00:00+09:00');
      var days = Math.max(0, (Date.now() - start.getTime()) / 86400000);
      var pct = 0, m = MILESTONES;
      if (days >= m[m.length-1][0]) { pct = m[m.length-1][1]; }
      else { for (var i=0;i<m.length-1;i++) { if (days>=m[i][0]&&days<m[i+1][0]){ pct=m[i][1]+(days-m[i][0])/(m[i+1][0]-m[i][0])*(m[i+1][1]-m[i][1]); break; } } }
      var pctRound = Math.round(pct * 10) / 10;
      setTimeout(function() {
        var bar = document.getElementById('hero-budget-bar');
        var lbl = document.getElementById('hero-budget-pct');
        if (bar) bar.style.width = Math.min(pct, 100) + '%';
        if (lbl) lbl.textContent = pctRound.toFixed(1) + '% 소진';
        if (bar && pct >= 75) bar.style.background = 'linear-gradient(90deg,#1d4ed8,#fbbf24)';
      }, 800);
    })();

    ScrollTrigger.refresh();
  });
</script>
