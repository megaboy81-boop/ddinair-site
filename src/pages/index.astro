  }
</style>

<script>
  window.addEventListener('load', () => {
    const gsap = (window as any).gsap;
    const ScrollTrigger = (window as any).ScrollTrigger;
    const LenisLib = (window as any).Lenis;
    if (!gsap || !ScrollTrigger) return;
    gsap.registerPlugin(ScrollTrigger);

    // Lenis — destroy old, create new with ScrollTrigger integration
    if ((window as any).__lenis) {
      try { (window as any).__lenis.destroy(); } catch(_) {}
    }
    if (LenisLib) {
      const lenis = new LenisLib({ lerp: 0.08, smoothWheel: true });
      (window as any).__lenis = lenis;
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((t: number) => { lenis.raf(t * 1000); });
      gsap.ticker.lagSmoothing(0);
    }

    // ── Hero entrance animations ──
    const badge = document.getElementById('hero-badge');
    const h1 = document.getElementById('hero-h1');
    const heroP = document.getElementById('hero-p');
    const heroCta = document.getElementById('hero-cta');
    const scrollInd = document.getElementById('scroll-indicator');

    if (badge) gsap.to(badge, { opacity: 1, scale: 1, duration: 1, delay: 0.3, ease: 'power3.out' });
    if (h1) gsap.to(h1, { opacity: 1, y: 0, duration: 1, delay: 0.5, ease: 'power3.out' });
    if (heroP) gsap.to(heroP, { opacity: 1, y: 0, duration: 1, delay: 0.7, ease: 'power3.out' });
    if (heroCta) gsap.to(heroCta, { opacity: 1, y: 0, duration: 1, delay: 0.9, ease: 'power3.out' });
    if (scrollInd) gsap.to(scrollInd, { opacity: 1, duration: 1, delay: 1.5, ease: 'power2.out' });

    // ── Hero content parallax on scroll ──
    const heroContent = document.getElementById('hero-content');
    if (heroContent) {
      gsap.to(heroContent, {
        y: -80, ease: 'none',
        scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: true }
      });
    }

    // ── Reveal animations ──
    document.querySelectorAll('.reveal').forEach(el => {
      gsap.fromTo(el,
        { opacity: 0, y: 24 },
        {
          opacity: 1, y: 0, duration: 0.8, ease: 'power2.out',
          scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' }
        }
      );
    });
    document.querySelectorAll('.reveal-left').forEach(el => {
      gsap.fromTo(el,
        { opacity: 0, x: -40 },
        {
          opacity: 1, x: 0, duration: 1, ease: 'power2.out',
          scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' }
        }
      );
    });
    document.querySelectorAll('.reveal-scale').forEach(el => {
      gsap.fromTo(el,
        { opacity: 0, scale: 0.95 },
        {
          opacity: 1, scale: 1, duration: 1, ease: 'power2.out',
          scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' }
        }
      );
    });

    // ── WebP canvas scroll animation (desktop only) ──
    const heroCanvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
    if (heroCanvas && window.innerWidth > 768) {
      const ctx = heroCanvas.getContext('2d')!;
      const FRAME_COUNT = 100;
      const siteBase = document.querySelector('meta[name="site-base"]')?.getAttribute('content') || '';
      const frames: HTMLImageElement[] = new Array(FRAME_COUNT);
      let currentFrame = 0;
      let canvasReady = false;

      function resizeCanvas() {
        if (!heroCanvas) return;
        heroCanvas.width = window.innerWidth;
        heroCanvas.height = window.innerHeight;
        drawFrame(currentFrame);
      }

      function drawFrame(idx: number) {
        if (!heroCanvas) return;
        const img = frames[idx];
        if (!img?.complete || !img.naturalWidth) return;
        const W = heroCanvas.width, H = heroCanvas.height;
        const scale = Math.max(W / img.naturalWidth, H / img.naturalHeight);
        const x = (W - img.naturalWidth * scale) / 2;
        const y = (H - img.naturalHeight * scale) / 2;
        ctx.clearRect(0, 0, W, H);
        ctx.drawImage(img, x, y, img.naturalWidth * scale, img.naturalHeight * scale);
        if (!canvasReady) {
          canvasReady = true;
          heroCanvas.style.opacity = '0.85';
        }
      }

      resizeCanvas();
      window.addEventListener('resize', resizeCanvas);

      for (let i = 0; i < FRAME_COUNT; i++) {
        const img = new Image();
        img.src = `${siteBase}/images/hero-frames/frame_${String(i + 1).padStart(3, '0')}.webp`;
        img.onload = () => { if (i === 0) resizeCanvas(); };
        frames[i] = img;
      }

      const scrubObj = { frame: 0 };
      gsap.to(scrubObj, {
        frame: FRAME_COUNT - 1, ease: 'none',
        scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: 0.5 },
        onUpdate() {
          const f = Math.round(scrubObj.frame);
          if (f !== currentFrame) { currentFrame = f; drawFrame(f); }
        }
      });
    }

    ScrollTrigger.refresh();
  });
</script>
