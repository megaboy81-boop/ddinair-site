---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const title = 'DD에어컨 | 남양주 에어컨 설치·판매·청소 전문';
const description = '남양주·다산신도시 에어컨 전문 설치 업체. 천장형 4WAY·스탠드·벽걸이 설치, 에어컨 청소·수리·이전. 당일 출장 가능. 70건+ 시공 실적.';

const heroImages = [
  `${base}/images/bg/h1.jpg`,
  `${base}/images/bg/h2.jpg`,
  `${base}/images/bg/h3.jpg`,
  `${base}/images/bg/h4.jpg`,
];

const stats = [
  { number: 70,  suffix: '+',  label: '시공 실적' },
  { number: 5,   suffix: '년+', label: '현장 경력' },
  { number: 100, suffix: '%',  label: 'AS 보장'   },
  { number: 1,   suffix: '일', label: '당일 출장'  },
];

const features = [
  {
    icon: '❄',
    title: '시스템 에어컨 설치',
    desc: '천장형 4WAY, 스탠드형, 벽걸이형 전문 설치. LG·삼성·캐리어 공식 시공.',
    badge: 'Installation',
    delay: ''
  },
  {
    icon: '🔧',
    title: '에어컨 청소·수리',
    desc: '분해청소, 가스충전, 부품교체. 냄새 제거 전문.',
    badge: 'Maintenance',
    delay: 'delay-200'
  },
  {
    icon: '🚚',
    title: '당일 출장 가능',
    desc: '남양주·구리·하남·의정부·노원·서울 전역. 긴급 수리도 빠르게.',
    badge: 'Fast Service',
    delay: 'delay-400'
  },
];

const galleryItems = [
  { src: `${base}/images/gallery/case01.jpg`, label: '요양병원 벽걸이 설치', delay: 'delay-100' },
  { src: `${base}/images/gallery/case02.jpg`, label: '셀렉샵 4WAY 설치', delay: 'delay-200' },
  { src: `${base}/images/gallery/case03.jpg`, label: '네일샵 4WAY 설치', delay: 'delay-300' },
  { src: `${base}/images/gallery/case04.jpg`, label: '마포 4WAY 설치', delay: 'delay-400' },
  { src: `${base}/images/gallery/case05.jpg`, label: '치과 4WAY 설치', delay: 'delay-100' },
  { src: `${base}/images/gallery/case06.jpg`, label: '헤어샵 4WAY 설치', delay: 'delay-200' },
  { src: `${base}/images/gallery/case07.jpg`, label: '관리실 스탠드 설치', delay: 'delay-300' },
  { src: `${base}/images/gallery/case08.jpg`, label: '사무실 벽걸이 설치', delay: 'delay-400' },
];

const reviews = [
  {
    text: '시공이 깔끔하고 빠르게 완료됐어요. 천장형 설치인데 마감까지 완벽했습니다.',
    name: '남양주 원룸 사장님',
    date: '2025년 11월 시공',
    img: `${base}/images/gallery/case01.jpg`
  },
  {
    text: '다산신도시 식당 4WAY 설치했는데 정말 꼼꼼하게 해주셨어요. 추천합니다.',
    name: '다산 식당 사장님',
    date: '2025년 8월 시공',
    img: `${base}/images/gallery/case02.jpg`
  },
  {
    text: '급하게 연락했는데 당일 출장 와주셨어요. 가격도 합리적이고 친절했습니다.',
    name: '의정부 헤어샵',
    date: '2025년 6월 시공',
    img: `${base}/images/gallery/case03.jpg`
  },
];
---
<Layout title={title} description={description}>

  <!-- ====== HERO 섹션 — 슬라이더 ====== -->
  <section class='relative h-screen min-h-[600px] overflow-hidden' style='background: #05090F;'>
    <!-- 배경 슬라이더 이미지 -->
    {heroImages.map((src, i) => (
      <div class={`hero-slide absolute inset-0 ${i === 0 ? 'active' : ''}`} data-index={i}>
        <img src={src} alt={`DD에어컨 시공 ${i+1}`}
          class='w-full h-full object-cover object-center'
          loading={i === 0 ? 'eager' : 'lazy'} />
        <div class='absolute inset-0' style='background: linear-gradient(to bottom, rgba(5,9,15,0.45) 0%, rgba(5,9,15,0.1) 40%, rgba(5,9,15,0.85) 100%);'></div>
      </div>
    ))}

    <!-- 히어로 텍스트 오버레이 -->
    <div class='absolute inset-0 flex flex-col justify-end z-10'>
      <div class='max-w-6xl mx-auto w-full px-8 pb-28 md:pb-32'>
        <p class='hero-text-1 text-white/60 text-xs tracking-[0.6em] uppercase mb-4 font-light'>Namyangju HVAC Specialist · 70+ Projects</p>
        <h1 class='font-display leading-none mb-5'>
          <span class='hero-text-2 block text-5xl md:text-7xl lg:text-8xl text-white font-light tracking-wider'>DD</span>
          <span class='hero-text-3 block text-5xl md:text-7xl lg:text-8xl font-light tracking-wider' style='color: #81D4FA; font-style: italic;'>에어컨</span>
        </h1>
        <p class='hero-text-4 text-white/70 text-lg md:text-xl font-light mb-8'>
          남양주 · 구리 · 의정부 시스템에어컨 전문
        </p>
        <div class='hero-text-4 flex flex-col sm:flex-row gap-4'>
          <a href={`${base}/contact`}
             class='inline-block text-white px-10 py-4 text-sm tracking-[0.2em] uppercase font-light hover:opacity-90 transition-all duration-300 shadow-lg'
             style='background: linear-gradient(135deg, #1E88E5, #0D47A1);'>
            서비스 신청하기
          </a>
          <a href={`${base}/cases`}
             class='inline-block border border-white/40 text-white/80 px-10 py-4 text-sm tracking-[0.2em] uppercase font-light hover:border-white hover:text-white transition-all duration-300'>
            시공사례 보기
          </a>
        </div>
      </div>
    </div>

    <!-- 슬라이더 인디케이터 -->
    <div class='absolute bottom-8 right-8 flex gap-2 z-10' id='slide-indicators'>
      {heroImages.map((_, i) => (
        <button
          class={`slide-dot rounded-full transition-all duration-300 h-2 ${i === 0 ? 'bg-white w-6' : 'bg-white/40 w-2'}`}
          data-slide={i}
          aria-label={`슬라이드 ${i+1}`}></button>
      ))}
    </div>

    <!-- 스크롤 유도 -->
    <div class='absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:flex flex-col items-center gap-2 z-10 text-white/40'>
      <span class='text-[10px] tracking-[0.4em] uppercase'>Scroll</span>
      <div class='w-px h-10' style='background: linear-gradient(to bottom, rgba(79,195,247,0.4), transparent);'></div>
    </div>
  </section>

  <!-- ====== 숫자 스탯 — 카운터 애니메이션 ====== -->
  <section class='py-14 border-b' style='background: linear-gradient(135deg, #080D15 0%, #05090F 100%); border-color: rgba(79,195,247,0.15);'>
    <div class='max-w-5xl mx-auto px-6'>
      <div class='grid grid-cols-2 md:grid-cols-4 gap-8 text-center'>
        {stats.map((stat, i) => (
          <div class={`fade-in-up delay-${i * 100}`}>
            <p class='font-display text-4xl md:text-5xl font-light mb-1' style='color: #4FC3F7;'>
              <span class='counter-num' data-target={stat.number} data-suffix={stat.suffix}>0</span>
            </p>
            <p class='text-xs tracking-[0.25em] uppercase font-light' style='color: #81D4FA;'>{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== 브랜드 특징 — VanillaTilt 3D 카드 ====== -->
  <section class='py-24 px-6' style='background: #080D15;'>
    <div class='max-w-6xl mx-auto'>
      <div class='text-center mb-16'>
        <p class='fade-in-up text-xs tracking-[0.5em] uppercase font-light mb-4' style='color: #4FC3F7;'>Why DD에어컨</p>
        <h2 class='fade-in-up delay-100 font-display text-4xl md:text-5xl font-light text-white mb-5'>왜 DD에어컨인가요?</h2>
        <div class='fade-in-up delay-200 section-divider'></div>
        <p class='fade-in-up delay-300 font-light text-sm mt-4' style='color: rgba(255,255,255,0.45);'>남양주·다산신도시 고객들이 DD에어컨을 선택하는 이유</p>
      </div>
      <div class='grid grid-cols-1 md:grid-cols-3 gap-8'>
        {features.map((feat) => (
          <div
            class={`tilt-card fade-in-up ${feat.delay} relative border p-10 overflow-hidden cursor-default`}
            style='background: #080D15; border-color: rgba(79,195,247,0.15);'
            data-tilt
            data-tilt-max='8'
            data-tilt-speed='400'
            data-tilt-glare='true'
            data-tilt-max-glare='0.15'
          >
            <span class='absolute top-5 right-5 text-[10px] tracking-[0.3em] uppercase border px-2 py-0.5' style='color: #4FC3F7; border-color: rgba(79,195,247,0.6);'>{feat.badge}</span>
            <div class='font-display text-2xl mb-5' style='color: #4FC3F7;'>{feat.icon}</div>
            <div class='w-8 h-px mb-5' style='background: linear-gradient(90deg, #1E88E5, #81D4FA);'></div>
            <h3 class='font-display text-2xl font-light text-white mb-4'>{feat.title}</h3>
            <p class='text-sm leading-relaxed font-light' style='color: rgba(255,255,255,0.55);'>{feat.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== 갤러리 섹션 — 마소너리 그리드 ====== -->
  <section class='py-20' style='background: #05090F;'>
    <div class='max-w-6xl mx-auto px-6 mb-10'>
      <div class='flex items-end justify-between'>
        <div>
          <p class='fade-in-left text-xs tracking-[0.5em] uppercase font-light mb-3' style='color: rgba(79,195,247,0.6);'>Our Installation Cases</p>
          <h2 class='fade-in-left delay-100 font-display text-4xl md:text-5xl font-light text-white'>시공 갤러리</h2>
        </div>
        <a href={`${base}/cases`} class='fade-in-right hidden md:inline-block text-xs tracking-[0.3em] uppercase pb-0.5 hover:text-white hover:border-white transition-colors font-light' style='color: rgba(79,195,247,0.6); border-bottom: 1px solid rgba(79,195,247,0.6);'>
          전체 보기 →
        </a>
      </div>
    </div>

    <div class='grid grid-cols-2 md:grid-cols-4 gap-px' style='background: #05090F;'>
      <div class='col-span-2 overflow-hidden group relative fade-in-scale' style='height: 380px;'>
        <img src={`${base}/images/gallery/case01.jpg`} alt='DD에어컨 대표 시공'
             class='w-full h-full object-cover transition-transform duration-700 group-hover:scale-105' />
        <div class='absolute inset-0 bg-black/0 group-hover:bg-black/15 transition-colors duration-500'></div>
        <div class='absolute bottom-0 left-0 right-0 p-6 translate-y-full group-hover:translate-y-0 transition-transform duration-500' style='background: linear-gradient(to top, rgba(5,9,15,0.8), transparent);'>
          <p class='text-white/90 text-sm font-light tracking-wider'>대표 시공사례</p>
        </div>
      </div>
      {galleryItems.slice(1, 5).map((img) => (
        <div class={`aspect-square overflow-hidden group relative fade-in-scale ${img.delay}`}>
          <img src={img.src} alt={`DD에어컨 ${img.label}`} class='w-full h-full object-cover transition-transform duration-700 group-hover:scale-110' loading='lazy' />
          <div class='absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-end justify-start p-3'>
            <span class='text-white/0 group-hover:text-white/90 transition-all duration-300 text-xs tracking-wider font-light'>{img.label}</span>
          </div>
        </div>
      ))}
      {galleryItems.slice(5, 8).map((img, i) => (
        <div class={`aspect-square overflow-hidden group relative fade-in-scale delay-${(i+1)*100}`}>
          <img src={img.src} alt={`DD에어컨 ${img.label}`} class='w-full h-full object-cover transition-transform duration-700 group-hover:scale-110' loading='lazy' />
          <div class='absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-end justify-start p-3'>
            <span class='text-white/0 group-hover:text-white/90 transition-all duration-300 text-xs tracking-wider font-light'>{img.label}</span>
          </div>
        </div>
      ))}
    </div>

    <div class='text-center mt-10 px-6'>
      <a href={`${base}/cases`}
         id='gallery-cta'
         class='fade-in-up inline-block px-12 py-4 text-xs tracking-[0.3em] uppercase font-light transition-all duration-300'
         style='border: 1px solid rgba(79,195,247,0.6); color: rgba(79,195,247,0.6);'>
        전체 갤러리 보기
      </a>
    </div>
  </section>

  <!-- ====== 한전 지원사업 배너 ====== -->
  <section class='py-20 px-6 relative overflow-hidden text-center' style='background: linear-gradient(135deg, #1E88E5 0%, #0D47A1 100%);'>
    <div class='absolute top-0 left-0 w-64 h-64 rounded-full opacity-10 -translate-x-32 -translate-y-32' style='background: #080D15;'></div>
    <div class='absolute bottom-0 right-0 w-96 h-96 rounded-full opacity-10 translate-x-48 translate-y-48' style='background: #05090F;'></div>
    <div class='absolute top-8 left-1/2 -translate-x-1/2 w-px h-12 opacity-30' style='background: #81D4FA;'></div>

    <div class='max-w-4xl mx-auto relative z-10'>
      <p class='fade-in-up text-white/70 text-xs tracking-[0.5em] uppercase font-light mb-4'>2026 KEPCO Support Program</p>
      <h2 class='fade-in-up delay-100 font-display text-4xl md:text-5xl font-light text-white mb-5'>한전 고효율기기 지원사업</h2>
      <div class='fade-in-up delay-200 w-12 h-px mx-auto mb-6' style='background: rgba(255,255,255,0.4);'></div>
      <p class='fade-in-up delay-300 text-white/80 font-light text-lg mb-8'>
        2026년 참여 업체 — 에어컨 교체 시<br/>
        <strong style='color: #81D4FA;'>최대 40% 환급</strong> 혜택을 받으세요.
      </p>
      <div class='fade-in-up delay-400 flex flex-col sm:flex-row gap-4 justify-center'>
        <a href={`${base}/contact`}
           class='inline-block bg-white px-12 py-4 text-sm tracking-[0.2em] uppercase font-medium hover:opacity-95 transition-colors shadow-lg'
           style='color: #1E88E5;'>
          지원금 신청하기
        </a>
        <a href={`${base}/subsidy`}
           class='inline-block border border-white/50 text-white px-12 py-4 text-sm tracking-[0.2em] uppercase font-light hover:bg-white/10 transition-all duration-300'>
          지원사업 안내
        </a>
      </div>
    </div>
  </section>

  <!-- ====== 고객 후기 ====== -->
  <section class='py-24 px-6' style='background: #080D15;'>
    <div class='max-w-6xl mx-auto'>
      <div class='text-center mb-16'>
        <p class='fade-in-up text-xs tracking-[0.5em] uppercase font-light mb-4' style='color: #4FC3F7;'>Customer Reviews</p>
        <h2 class='fade-in-up delay-100 font-display text-4xl md:text-5xl font-light text-white mb-5'>고객들의 이야기</h2>
        <div class='fade-in-up delay-200 section-divider'></div>
      </div>
      <div class='grid grid-cols-1 md:grid-cols-3 gap-8'>
        {reviews.map((review, i) => (
          <div class={`fade-in-up delay-${i*200} border p-8 relative hover:shadow-xl transition-all duration-500 hover:-translate-y-1`} style='background: rgba(79,195,247,0.03); border-color: rgba(79,195,247,0.12);'>
            <div class='font-display text-6xl leading-none mb-4 font-light select-none' style='color: rgba(79,195,247,0.15);'>"</div>
            <div class='w-14 h-14 rounded-full overflow-hidden mb-5 border-2' style='border-color: rgba(79,195,247,0.6);'>
              <img src={review.img} alt='고객 시공사례' class='w-full h-full object-cover' loading='lazy' />
            </div>
            <div class='flex gap-0.5 mb-4'>
              {[1,2,3,4,5].map(() => <span class='text-sm' style='color: #4FC3F7;'>★</span>)}
            </div>
            <p class='text-sm leading-relaxed mb-5 font-light italic' style='color: rgba(255,255,255,0.65);'>"{review.text}"</p>
            <div class='border-t pt-4' style='border-color: rgba(79,195,247,0.12);'>
              <p class='text-xs tracking-wider font-medium' style='color: #4FC3F7;'>{review.name}</p>
              <p class='text-xs mt-0.5' style='color: rgba(255,255,255,0.35);'>{review.date}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== 최종 CTA ====== -->
  <section class='py-32 px-6 text-center relative overflow-hidden' style='background: #05090F;'>
    <div class='absolute inset-0 pointer-events-none' style='background: radial-gradient(ellipse at center, rgba(79,195,247,0.06) 0%, transparent 70%);'></div>
    <p class='fade-in-up text-xs tracking-[0.5em] uppercase font-light mb-5' style='color: #4FC3F7;'>Quick Service</p>
    <h2 class='fade-in-up delay-100 font-display text-4xl md:text-6xl font-light text-white mb-6'>
      지금 바로 상담 신청하세요<br/>
      <span class='font-light blue-gradient' style='font-style: italic;'>당일 출장 가능합니다</span>
    </h2>
    <div class='fade-in-up delay-200 section-divider mb-8'></div>
    <p class='fade-in-up delay-300 font-light mb-10 text-lg' style='color: rgba(255,255,255,0.5);'>
      남양주·구리·하남 전역 당일 출장 가능합니다.<br/>
      전화 한 통으로 바로 연결됩니다.
    </p>
    <div class='fade-in-up delay-400 flex flex-col sm:flex-row gap-4 justify-center'>
      <a href='tel:010-7237-2122'
         class='inline-block text-white px-16 py-5 text-sm tracking-[0.3em] uppercase font-light shadow-xl hover:shadow-2xl hover:-translate-y-1 transition-all duration-300'
         style='background: linear-gradient(135deg, #1E88E5, #0D47A1);'>
        010-7237-2122 전화하기
      </a>
      <a href={`${base}/contact`}
         class='inline-block border border-white/20 text-white/75 px-12 py-5 text-sm tracking-[0.2em] uppercase font-light hover:border-[#4FC3F7] hover:text-[#4FC3F7] transition-all duration-300'>
        온라인 신청
      </a>
    </div>
  </section>

</Layout>

<script>
  // ============================================================
  // 1. 히어로 슬라이더
  // ============================================================
  const slides = document.querySelectorAll<HTMLElement>('.hero-slide');
  const dots = document.querySelectorAll<HTMLElement>('.slide-dot');
  let current = 0;

  function goToSlide(n: number) {
    slides[current].classList.remove('active');
    (dots[current] as HTMLElement).style.width = '8px';
    dots[current].classList.add('bg-white/40');
    dots[current].classList.remove('bg-white');
    current = n;
    slides[current].classList.add('active');
    (dots[current] as HTMLElement).style.width = '24px';
    dots[current].classList.remove('bg-white/40');
    dots[current].classList.add('bg-white');
  }

  let slideTimer = setInterval(() => goToSlide((current + 1) % slides.length), 5500);
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      clearInterval(slideTimer);
      goToSlide(i);
      slideTimer = setInterval(() => goToSlide((current + 1) % slides.length), 5500);
    });
  });

  // ============================================================
  // 2. 카운터 애니메이션 (IntersectionObserver)
  // ============================================================
  const counterObs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseInt(el.dataset.target || '0');
      const suffix = el.dataset.suffix || '';
      const duration = 1800;
      const start = performance.now();
      function update(now: number) {
        const t = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - t, 3);
        el.textContent = Math.round(eased * target) + suffix;
        if (t < 1) requestAnimationFrame(update);
      }
      requestAnimationFrame(update);
      counterObs.unobserve(el);
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('.counter-num').forEach(el => counterObs.observe(el));

  // ============================================================
  // 3. VanillaTilt 초기화
  // ============================================================
  const VT = (window as any).VanillaTilt;
  if (VT) {
    VT.init(document.querySelectorAll('[data-tilt]'), {
      max: 8, speed: 400, glare: true, 'max-glare': 0.15,
    });
  }

  // ============================================================
  // 4. 페이드인 옵저버
  // ============================================================
  const fadeObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        fadeObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in-up,.fade-in-left,.fade-in-right,.fade-in-scale').forEach(el => fadeObs.observe(el));

  // ============================================================
  // 5. Nav 스크롤 효과
  // ============================================================
  const header = document.getElementById('main-nav');
  if (header) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) header.classList.add('scrolled');
      else header.classList.remove('scrolled');
    }, { passive: true });
  }

  // ============================================================
  // 6. 갤러리 CTA 호버
  // ============================================================
  const galleryCta = document.getElementById('gallery-cta');
  if (galleryCta) {
    galleryCta.addEventListener('mouseover', () => {
      galleryCta.style.background = '#4FC3F7';
      galleryCta.style.color = '#05090F';
    });
    galleryCta.addEventListener('mouseout', () => {
      galleryCta.style.background = 'transparent';
      galleryCta.style.color = 'rgba(79,195,247,0.6)';
    });
  }
</script>

