---
import Layout from '../layouts/Layout.astro';
import rawCases from '../data/blog-cases.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const title = 'DD에어컨 시공사례 | 2000건+ 현장 포트폴리오';
const description = 'DD에어컨의 실제 시공 현장 사례. 식당, 헤어샵, 의원, 학교, 사무실 등 다양한 업종의 에어컨 설치 포트폴리오.';

// 블로그 자동 동기화 데이터 (scripts/sync-blog.py → src/data/blog-cases.json)
const cases = (rawCases as any[]).map(c => ({
  ...c,
  // 너무 긴 spec은 카드용으로 축약
  specShort: c.spec.length > 40 ? c.spec.slice(0, 38) + '…' : c.spec,
  // 너무 긴 place도 축약
  placeShort: c.place.length > 18 ? c.place.slice(0, 16) + '…' : c.place,
  // blogLink에서 RSS 파라미터 제거
  blogLink: c.blogLink.split('?')[0],
}));

const typeColors: Record<string, string> = {
  '4WAY': '#4fc3f7',
  '스탠드': '#1e88e5',
  '벽걸이': '#81d4fa',
  '멀티': '#00bcd4',
};
---
<Layout title={title} description={description}>

<!-- 페이지 헤더 -->
<section style="background:#09090b;padding:160px 8vw 80px;position:relative;overflow:hidden;">
  <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(79,195,247,0.2),transparent);"></div>
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 30% 50%,rgba(79,195,247,0.05),transparent 60%);"></div>
  <div style="max-width:1100px;margin:0 auto;position:relative;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;" class="header-grid">
    <div>
      <span class="section-label" style="margin-bottom:12px;">Installation Portfolio</span>
      <h1 class="font-display" style="font-size:clamp(42px,7vw,88px);font-weight:300;color:white;line-height:0.95;letter-spacing:0.02em;margin-bottom:24px;">
        시공사례<br/><span class="blue-gradient" style="font-style:italic;">2000건+</span>
      </h1>
      <p style="font-size:16px;color:rgba(255,255,255,0.5);font-weight:300;line-height:1.8;max-width:480px;">
        식당·헤어샵·의원·학교·사무실 등<br/>다양한 업종의 실제 시공 현장입니다.
      </p>
    </div>
    <div id="cases-hero-img" class="hero-img-anim" style="position:relative;">
      <div style="position:relative;border-radius:4px;overflow:hidden;">
        <img
          src="https://images.unsplash.com/photo-1633098096918-f12258de36f1?q=85&w=1000&auto=format&fit=crop"
          alt="천장형 4WAY 에어컨 시공 현장"
          style="width:100%;aspect-ratio:4/3;object-fit:cover;display:block;"
          loading="eager"
        />
        <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(37,99,235,0.15),transparent);"></div>
        <div style="position:absolute;bottom:0;left:0;right:0;padding:20px 24px;background:linear-gradient(to top,rgba(0,0,0,0.7),transparent);">
          <p style="font-size:11px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#93c5fd;margin-bottom:4px;">INSTALLATION</p>
          <p style="font-size:14px;font-weight:600;color:white;">천장형 4WAY · 전국 2000건+ 시공 완료</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 필터 탭 -->
<section style="background:#ffffff;position:sticky;top:60px;z-index:10;border-bottom:1px solid #e4e4e7;">
  <div style="max-width:1100px;margin:0 auto;padding:0 8vw;display:flex;gap:4px;overflow-x:auto;scrollbar-width:none;">
    {['전체', '4WAY', '스탠드', '벽걸이', '멀티'].map(f => (
      <button
        class="filter-btn"
        data-filter={f}
        style={`flex-shrink:0;padding:16px 20px;background:none;border:none;cursor:pointer;font-size:11px;letter-spacing:0.25em;text-transform:uppercase;color:#a1a1aa;transition:all 0.2s;border-bottom:2px solid transparent;font-family:inherit;${f==='전체'?'color:#2563eb;border-bottom-color:#2563eb;':''}`}
      >{f}</button>
    ))}
  </div>
</section>

<!-- 케이스 3×3 그리드 -->
<section style="background:#f8f8f8;padding:48px 8vw 100px;">
  <div style="max-width:1100px;margin:0 auto;">
    <div class="case-grid-3" id="case-grid">
      {cases.map((c, i) => (
        <div
          class="case-card-item gsap-fade"
          data-type={c.type}
          data-delay={Math.min(i*0.04, 0.48)}
          data-blog-img={c.blogImg || ''}
          data-excerpt={c.excerpt || ''}
          data-blog-link={c.blogLink || ''}
          data-place={c.place}
          data-spec={c.spec}
          data-date={c.date}
          onclick={c.blogLink ? 'openCaseModal(this)' : ''}
          style={c.blogLink ? 'cursor:pointer;' : ''}
        >
          <!-- 이미지 영역 -->
          <div class="case-img-wrap">
            <img
              src={c.blogImg ? `${base}${c.blogImg}` : `${base}/images/gallery/${c.img}`}
              alt={`DD에어컨 ${c.place} ${c.specShort}`}
              loading="lazy"
            />
            <!-- 호버 오버레이 -->
            <div class="case-hover-overlay">
              <span style="font-size:11px;font-weight:600;color:white;letter-spacing:0.1em;">자세히 보기 →</span>
            </div>
          </div>
          <!-- 이미지 하단 텍스트 -->
          <div class="case-caption">
            <span class="case-caption-date">{c.date}<span style="margin-left:8px;font-size:9px;color:#2563eb;border:1px solid #bfdbfe;padding:1px 6px;border-radius:2px;">블로그</span></span>
            <h3 class="case-caption-place">{c.placeShort}</h3>
            <p class="case-caption-spec">{c.specShort}</p>
          </div>
        </div>
      ))}
    </div>
    <!-- 결과 없음 -->
    <div id="no-results" style="display:none;text-align:center;padding:80px 0;color:#a1a1aa;font-size:14px;">해당 타입의 시공사례가 없습니다.</div>
  </div>
</section>

<!-- 시공사례 상세 모달 -->
<div id="case-modal" style="display:none;position:fixed;inset:0;z-index:200;background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);align-items:center;justify-content:center;padding:20px;">
  <div style="background:#ffffff;max-width:560px;width:100%;position:relative;max-height:90vh;overflow-y:auto;">
    <!-- 닫기 -->
    <button onclick="closeCaseModal()" style="position:absolute;top:12px;right:12px;z-index:10;background:rgba(0,0,0,0.4);border:none;cursor:pointer;color:white;width:32px;height:32px;border-radius:50%;font-size:16px;line-height:1;display:flex;align-items:center;justify-content:center;">✕</button>
    <!-- 이미지 -->
    <div style="aspect-ratio:16/9;overflow:hidden;background:#1a1a1a;">
      <img id="modal-img" src="" alt="" style="width:100%;height:100%;object-fit:cover;display:block;" />
    </div>
    <!-- 내용 -->
    <div style="padding:28px 32px 32px;">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
        <span id="modal-date" style="font-size:10px;letter-spacing:0.2em;color:#a1a1aa;text-transform:uppercase;"></span>
        <span style="font-size:10px;color:#2563eb;border:1px solid #bfdbfe;padding:1px 8px;">블로그 연동</span>
      </div>
      <h3 id="modal-place" class="font-display" style="font-size:26px;font-weight:400;color:#09090b;margin-bottom:6px;"></h3>
      <p id="modal-spec" style="font-size:12px;color:#2563eb;letter-spacing:0.1em;margin-bottom:20px;"></p>
      <p id="modal-excerpt" style="font-size:14px;color:#52525b;line-height:1.9;margin-bottom:28px;"></p>
      <a id="modal-link" href="" target="_blank" rel="noopener"
        style="display:inline-flex;align-items:center;gap:8px;background:#03C75A;color:white;text-decoration:none;padding:13px 24px;font-size:12px;font-weight:700;letter-spacing:0.05em;transition:background 0.2s;"
        onmouseover="this.style.background='#02a84e'" onmouseout="this.style.background='#03C75A'">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><rect width="24" height="24" rx="4" fill="white" fill-opacity="0.3"/><path d="M13.5 12.3L10.2 7H7v10h3.5v-5.3L13.8 17H17V7h-3.5v5.3z" fill="white"/></svg>
        네이버 블로그에서 전체 글 보기
      </a>
    </div>
  </div>
</div>

<!-- CTA -->
<section style="background:#09090b;padding:80px 8vw;text-align:center;">
  <div style="max-width:500px;margin:0 auto;">
    <h2 class="font-display" style="font-size:clamp(28px,4vw,48px);font-weight:300;color:white;margin-bottom:16px;">견적 문의하기</h2>
    <p style="font-size:14px;color:rgba(255,255,255,0.45);line-height:1.8;margin-bottom:32px;">시공 전 무료 현장 방문 견적을 제공합니다.</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="tel:010-7237-2122" class="btn-primary">전화 문의하기</a>
      <a href={`${base}/contact`} style="display:inline-flex;align-items:center;gap:8px;padding:14px 28px;font-size:13px;font-weight:600;letter-spacing:0.04em;color:rgba(255,255,255,0.8);border:1px solid rgba(255,255,255,0.25);text-decoration:none;border-radius:9999px;transition:border-color 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.6)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.25)'">온라인 신청</a>
    </div>
  </div>
</section>

</Layout>

<style>
  /* ── 3×3 그리드 ── */
  .case-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  @media (max-width: 900px) {
    .case-grid-3 { grid-template-columns: repeat(2, 1fr); gap: 20px; }
  }
  @media (max-width: 560px) {
    .case-grid-3 { grid-template-columns: 1fr; gap: 28px; }
  }

  /* ── 카드 ── */
  .case-card-item {
    opacity: 0;
    transform: translateY(24px);
    cursor: pointer;
  }

  /* ── 이미지 래퍼 — 고정 비율 ── */
  .case-img-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #1a1a1a;
  }
  .case-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    display: block;
  }
  .case-card-item:hover .case-img-wrap img {
    transform: scale(1.06);
  }

  /* ── 호버 오버레이 ── */
  .case-hover-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .case-card-item:hover .case-hover-overlay {
    opacity: 1;
  }

  /* ── 이미지 하단 캡션 ── */
  .case-caption {
    padding: 14px 4px 0;
  }
  .case-caption-date {
    display: block;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: #a1a1aa;
    margin-bottom: 5px;
    text-transform: uppercase;
  }
  .case-caption-place {
    font-size: 15px;
    font-weight: 600;
    color: #09090b;
    margin: 0 0 4px;
    letter-spacing: -0.01em;
  }
  .case-caption-spec {
    font-size: 12px;
    color: #71717a;
    margin: 0;
    line-height: 1.5;
  }
</style>

<script is:inline>
// ── 시공사례 상세 모달 ──
function openCaseModal(el) {
  // 카드에 이미 로드된 이미지 src 그대로 사용
  var cardImg = el.querySelector('.case-img-wrap img');
  var img     = cardImg ? cardImg.src : '';
  var excerpt = el.dataset.excerpt;
  var link    = el.dataset.blogLink;
  var place   = el.dataset.place;
  var spec    = el.dataset.spec;
  var date    = el.dataset.date;

  document.getElementById('modal-img').src = img;
  document.getElementById('modal-img').alt = place;
  document.getElementById('modal-place').textContent = place;
  document.getElementById('modal-spec').textContent = spec;
  document.getElementById('modal-date').textContent = date;
  document.getElementById('modal-excerpt').textContent = excerpt;
  document.getElementById('modal-link').href = link;

  var modal = document.getElementById('case-modal');
  modal.style.display = 'flex';
  document.body.style.overflow = 'hidden';
}
function closeCaseModal() {
  document.getElementById('case-modal').style.display = 'none';
  document.body.style.overflow = '';
}
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeCaseModal();
});
document.getElementById('case-modal').addEventListener('click', function(e) {
  if (e.target === this) closeCaseModal();
});
window.openCaseModal = openCaseModal;
window.closeCaseModal = closeCaseModal;

window.addEventListener('load', function() {
  // Lenis
  if (typeof Lenis !== 'undefined') {
    const lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
    function raf(t) { lenis.raf(t); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);
  }

  // GSAP
  if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);
    gsap.utils.toArray('.gsap-fade').forEach(function(el) {
      var delay = parseFloat(el.dataset.delay || 0);
      gsap.to(el, {
        opacity: 1, y: 0, duration: 0.7, delay: delay,
        ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 90%', toggleActions: 'play none none none' }
      });
    });
  }

  // 필터
  var filterBtns = document.querySelectorAll('.filter-btn');
  var cards = document.querySelectorAll('.case-card-item');
  filterBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      filterBtns.forEach(function(b) {
        b.style.color = '#a1a1aa';
        b.style.borderBottomColor = 'transparent';
      });
      btn.style.color = '#2563eb';
      btn.style.borderBottomColor = '#2563eb';
      var filter = btn.dataset.filter;
      var visible = 0;
      cards.forEach(function(card) {
        if (filter === '전체' || card.dataset.type === filter) {
          card.style.display = '';
          visible++;
        } else {
          card.style.display = 'none';
        }
      });
      document.getElementById('no-results').style.display = visible === 0 ? 'block' : 'none';
    });
  });
});
</script>
