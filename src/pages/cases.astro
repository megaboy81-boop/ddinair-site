---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const title = 'DD에어컨 시공사례 | 70건+ 현장 포트폴리오';
const description = 'DD에어컨의 실제 시공 현장 사례. 식당, 헤어샵, 의원, 학교, 사무실 등 다양한 업종의 에어컨 설치 포트폴리오.';

const cases = [
  { img: 'case01.jpg', date: '2026.03', place: '수유 노원솔요양병원', spec: '삼성 벽걸이 9평 냉난방', type: '벽걸이' },
  { img: 'case02.jpg', date: '2026.02', place: '성수 셀렉샵', spec: 'LG 4WAY 25평 1등급', type: '4WAY' },
  { img: 'case03.jpg', date: '2026.02', place: '안산 네일아트샵', spec: 'LG 4WAY 25평 1등급', type: '4WAY' },
  { img: 'case04.jpg', date: '2026.02', place: '마포 사무실', spec: 'LG 4WAY 25평 + 벽걸이 16평', type: '4WAY' },
  { img: 'case05.jpg', date: '2026.02', place: '강변 치과', spec: '삼성 4WAY 30평 1등급', type: '4WAY' },
  { img: 'case06.jpg', date: '2025.11', place: '에이바헤어 건대점', spec: 'LG 4WAY 40평 1등급 + 28평', type: '4WAY' },
  { img: 'case07.jpg', date: '2025.11', place: '강동구 관리실', spec: 'LG 스탠드 40평 냉난방', type: '스탠드' },
  { img: 'case08.jpg', date: '2025.10', place: '송능리 사무실', spec: '캐리어 벽걸이 12평 2조', type: '벽걸이' },
  { img: 'case09.jpg', date: '2025.09', place: '익산 헤어샵', spec: '4WAY 40평 2대', type: '4WAY' },
  { img: 'case10.jpg', date: '2025.07', place: '구리 오리고기집', spec: 'LG 스탠드 80평 냉난방 2조', type: '스탠드' },
  { img: 'case11.jpg', date: '2025.06', place: '무교동 시그너스빌딩', spec: 'LG 멀티 12마력 4WAY 30평 3조', type: '멀티' },
  { img: 'case12.jpg', date: '2025.06', place: '방배동 라멘집', spec: 'LG 4WAY 30평 + 벽걸이 16평', type: '4WAY' },
  { img: 'case13.jpg', date: '2025.05', place: '이태원 식당', spec: 'LG 4WAY 40평 1등급', type: '4WAY' },
  { img: 'case14.jpg', date: '2025.05', place: '안산 치과의원', spec: '삼성 멀티 4WAY 3조 + 1WAY 1조', type: '멀티' },
  { img: 'case15.jpg', date: '2025.04', place: '에이바헤어 구리토평점', spec: 'LG 4WAY 40평 1등급', type: '4WAY' },
  { img: 'case16.jpg', date: '2025.04', place: '양재동 치과', spec: '삼성 멀티 4WAY 2조 + 1WAY', type: '멀티' },
  { img: 'case17.jpg', date: '2025.04', place: '에이바헤어 장위점', spec: 'LG 4WAY 40평 1등급', type: '4WAY' },
  { img: 'case18.jpg', date: '2025.03', place: '에이바헤어 본사', spec: 'LG 4WAY 25평 + 캐리어 7평 3조', type: '4WAY' },
  { img: 'case19.jpg', date: '2025.02', place: '잠실 국민통닭', spec: 'LG 4WAY 40평 1등급', type: '4WAY' },
];

const typeColors: Record<string, string> = {
  '4WAY': '#4fc3f7',
  '스탠드': '#1e88e5',
  '벽걸이': '#81d4fa',
  '멀티': '#00bcd4',
};
---
<Layout title={title} description={description}>

<!-- 페이지 헤더 -->
<section style="background:#09090b;padding:160px 8vw 80px;position:relative;overflow:hidden;">
  <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(79,195,247,0.2),transparent);"></div>
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 30% 50%,rgba(79,195,247,0.05),transparent 60%);"></div>
  <div style="max-width:1100px;margin:0 auto;position:relative;">
    <span class="section-label" style="margin-bottom:12px;">Installation Portfolio</span>
    <h1 class="font-display" style="font-size:clamp(42px,7vw,88px);font-weight:300;color:white;line-height:0.95;letter-spacing:0.02em;margin-bottom:24px;">
      시공사례<br/><span class="blue-gradient" style="font-style:italic;">70건+</span>
    </h1>
    <p style="font-size:16px;color:rgba(255,255,255,0.5);font-weight:300;line-height:1.8;max-width:480px;">
      식당·헤어샵·의원·학교·사무실 등<br/>다양한 업종의 실제 시공 현장입니다.
    </p>
  </div>
</section>

<!-- 필터 탭 -->
<section style="background:#ffffff;position:sticky;top:60px;z-index:10;border-bottom:1px solid #e4e4e7;">
  <div style="max-width:1100px;margin:0 auto;padding:0 8vw;display:flex;gap:4px;overflow-x:auto;scrollbar-width:none;">
    {['전체', '4WAY', '스탠드', '벽걸이', '멀티'].map(f => (
      <button
        class="filter-btn"
        data-filter={f}
        style={`flex-shrink:0;padding:16px 20px;background:none;border:none;cursor:pointer;font-size:11px;letter-spacing:0.25em;text-transform:uppercase;color:#a1a1aa;transition:all 0.2s;border-bottom:2px solid transparent;font-family:inherit;${f==='전체'?'color:#2563eb;border-bottom-color:#2563eb;':''}`}
      >{f}</button>
    ))}
  </div>
</section>

<!-- 케이스 3×3 그리드 -->
<section style="background:#f8f8f8;padding:48px 8vw 100px;">
  <div style="max-width:1100px;margin:0 auto;">
    <div class="case-grid-3" id="case-grid">
      {cases.map((c, i) => (
        <div class="case-card-item gsap-fade" data-type={c.type} data-delay={Math.min(i*0.04, 0.48)}>
          <!-- 이미지 영역 -->
          <div class="case-img-wrap">
            <img
              src={`${base}/images/gallery/${c.img}`}
              alt={`DD에어컨 ${c.place} ${c.spec}`}
              loading="lazy"
            />
            <!-- 호버 오버레이 -->
            <div class="case-hover-overlay">
              <span style={`font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:${typeColors[c.type]||'#4fc3f7'};border:1px solid ${typeColors[c.type]||'rgba(79,195,247,0.4)'};padding:3px 10px;`}>{c.type}</span>
            </div>
          </div>
          <!-- 이미지 하단 텍스트 -->
          <div class="case-caption">
            <span class="case-caption-date">{c.date}</span>
            <h3 class="case-caption-place">{c.place}</h3>
            <p class="case-caption-spec">{c.spec}</p>
          </div>
        </div>
      ))}
    </div>
    <!-- 결과 없음 -->
    <div id="no-results" style="display:none;text-align:center;padding:80px 0;color:#a1a1aa;font-size:14px;">해당 타입의 시공사례가 없습니다.</div>
  </div>
</section>

<!-- CTA -->
<section style="background:#09090b;padding:80px 8vw;text-align:center;">
  <div style="max-width:500px;margin:0 auto;">
    <h2 class="font-display" style="font-size:clamp(28px,4vw,48px);font-weight:300;color:white;margin-bottom:16px;">견적 문의하기</h2>
    <p style="font-size:14px;color:rgba(255,255,255,0.45);line-height:1.8;margin-bottom:32px;">시공 전 무료 현장 방문 견적을 제공합니다.</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="tel:010-7237-2122" class="btn-primary">전화 문의하기</a>
      <a href={`${base}/contact`} style="display:inline-flex;align-items:center;gap:8px;padding:14px 28px;font-size:13px;font-weight:600;letter-spacing:0.04em;color:rgba(255,255,255,0.8);border:1px solid rgba(255,255,255,0.25);text-decoration:none;border-radius:9999px;transition:border-color 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.6)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.25)'">온라인 신청</a>
    </div>
  </div>
</section>

</Layout>

<style>
  /* ── 3×3 그리드 ── */
  .case-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  @media (max-width: 900px) {
    .case-grid-3 { grid-template-columns: repeat(2, 1fr); gap: 20px; }
  }
  @media (max-width: 560px) {
    .case-grid-3 { grid-template-columns: 1fr; gap: 28px; }
  }

  /* ── 카드 ── */
  .case-card-item {
    opacity: 0;
    transform: translateY(24px);
    cursor: pointer;
  }

  /* ── 이미지 래퍼 — 고정 비율 ── */
  .case-img-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #1a1a1a;
  }
  .case-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    display: block;
  }
  .case-card-item:hover .case-img-wrap img {
    transform: scale(1.06);
  }

  /* ── 호버 오버레이 ── */
  .case-hover-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .case-card-item:hover .case-hover-overlay {
    opacity: 1;
  }

  /* ── 이미지 하단 캡션 ── */
  .case-caption {
    padding: 14px 4px 0;
  }
  .case-caption-date {
    display: block;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: #a1a1aa;
    margin-bottom: 5px;
    text-transform: uppercase;
  }
  .case-caption-place {
    font-size: 15px;
    font-weight: 600;
    color: #09090b;
    margin: 0 0 4px;
    letter-spacing: -0.01em;
  }
  .case-caption-spec {
    font-size: 12px;
    color: #71717a;
    margin: 0;
    line-height: 1.5;
  }
</style>

<script is:inline>
window.addEventListener('load', function() {
  // Lenis
  if (typeof Lenis !== 'undefined') {
    const lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
    function raf(t) { lenis.raf(t); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);
  }

  // GSAP
  if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);
    gsap.utils.toArray('.gsap-fade').forEach(function(el) {
      var delay = parseFloat(el.dataset.delay || 0);
      gsap.to(el, {
        opacity: 1, y: 0, duration: 0.7, delay: delay,
        ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 90%', toggleActions: 'play none none none' }
      });
    });
  }

  // 필터
  var filterBtns = document.querySelectorAll('.filter-btn');
  var cards = document.querySelectorAll('.case-card-item');
  filterBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      filterBtns.forEach(function(b) {
        b.style.color = '#a1a1aa';
        b.style.borderBottomColor = 'transparent';
      });
      btn.style.color = '#2563eb';
      btn.style.borderBottomColor = '#2563eb';
      var filter = btn.dataset.filter;
      var visible = 0;
      cards.forEach(function(card) {
        if (filter === '전체' || card.dataset.type === filter) {
          card.style.display = '';
          visible++;
        } else {
          card.style.display = 'none';
        }
      });
      document.getElementById('no-results').style.display = visible === 0 ? 'block' : 'none';
    });
  });
});
</script>
